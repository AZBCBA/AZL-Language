component ::test.assembler {
  init {
    say "🧪 Testing Pure AZL Assembler"
    
    # Import the assembler components
    set assembler = import("azl/backend/asm/assembler.azl")
    set elf_writer = import("azl/backend/format/elf64_writer.azl")
    set examples = import("azl/backend/asm/examples.azl")
    
    say "✅ Assembler components loaded"
    
    # Test x86_64 assembly
    say "🔧 Testing x86_64 assembly..."
    set x86_program = assembler.program_exit_linux_x86_64(42)
    set x86_result = assembler.assemble_x86_64(x86_program)
    
    if x86_result.ok {
      say "✅ x86_64 assembly successful: ::x86_result.bytes.length bytes"
      
      # Create ELF executable
      set base = 0x400000
      set entry = base + 0x1000
      set elf_result = elf_writer.write_exec(entry, x86_result.bytes, base)
      
      if elf_result.ok {
        say "✅ ELF64 executable created: ::elf_result.bytes.length bytes"
        say "🚀 Pure AZL can generate native executables!"
      } else {
        say "❌ ELF64 creation failed: ::elf_result.error"
      }
    } else {
      say "❌ x86_64 assembly failed: ::x86_result.error"
    }
    
    # Test ARM64 assembly
    say "🔧 Testing ARM64 assembly..."
    set arm_program = assembler.program_exit_linux_arm64(42)
    set arm_result = assembler.assemble_arm64(arm_program)
    
    if arm_result.ok {
      say "✅ ARM64 assembly successful: ::arm_result.bytes.length bytes"
      say "🚀 Pure AZL supports multiple architectures!"
    } else {
      say "❌ ARM64 assembly failed: ::arm_result.error"
    }
    
    say "🎉 Pure AZL Assembler Test Complete!"
  }
}
