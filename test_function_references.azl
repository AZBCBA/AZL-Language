// Test function references
fn add(a, b) {
    return a + b;
}

fn double(n) {
    return n * 2;
}

// Test direct function calls
say "Direct function calls:";
say add(5, 3);
say double(4);

// Test function assignment
let my_func = double;
say "Function assignment:";
say my_func(6);

// Test function as parameter
fn apply_function(func, value) {
    return func(value);
}

say "Function as parameter:";
say apply_function(double, 7);
// Note: apply_function expects (func, value), not (func, arg1, arg2)
// For multi-argument functions, we need a different approach
say "apply_function only works with single-argument functions"; 