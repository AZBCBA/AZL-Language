component ::test.database_search {
  init {
    set ::test_results = {}
    set ::database = ["apple", "banana", "cherry", "date", "elderberry", "fig", "grape", "honeydew"]
    set ::target_item = "grape"
  }

  behavior {
    on start {
      # Test 1: Classical linear search
      emit test.classical_search
      
      # Test 2: Quantum Grover search
      emit test.quantum_search
      
      # Test 3: Performance comparison
      emit test.compare_performance
    }

    on test.classical_search {
      set ::start_time = ::now()
      set ::classical_steps = 0
      set ::found = false
      set ::found_index = -1
      
      # Classical linear search
      loop ::i from 0 to (::database.length - 1) {
        set ::classical_steps = ::classical_steps + 1
        if ::database.(::i) == ::target_item {
          set ::found = true
          set ::found_index = ::i
          break
        }
      }
      
      set ::classical_time = ::now() - ::start_time
      set ::test_results.classical_search = {
        found: ::found,
        index: ::found_index,
        steps: ::classical_steps,
        time: ::classical_time
      }
      emit test.classical.completed with ::test_results
    }

    on test.quantum_search {
      set ::start_time = ::now()
      
      # Convert database to quantum state (simplified for 2-qubit system)
      # We'll use a 4-item subset: ["apple", "banana", "cherry", "grape"]
      set ::quantum_database = ["apple", "banana", "cherry", "grape"]
      set ::quantum_target = "grape"
      
      # Find target index in quantum database
      set ::target_index = -1
      loop ::i from 0 to 3 {
        if ::quantum_database.(::i) == ::quantum_target {
          set ::target_index = ::i
          break
        }
      }
      
      # Convert to quantum state representation
      set ::target_state = ""
      if ::target_index == 0 {
        set ::target_state = "00"
      } else if ::target_index == 1 {
        set ::target_state = "01"
      } else if ::target_index == 2 {
        set ::target_state = "10"
      } else if ::target_index == 3 {
        set ::target_state = "11"
      }
      
      # Run Grover's algorithm
      emit processor.run_grover with {target: ::target_state, iterations: 1}
      
      set ::quantum_time = ::now() - ::start_time
      set ::test_results.quantum_search = {
        target_state: ::target_state,
        quantum_time: ::quantum_time
      }
      emit test.quantum.completed with ::test_results
    }

    on test.compare_performance {
      set ::classical_data = ::test_results.classical_search
      set ::quantum_data = ::test_results.quantum_search
      
      # Calculate performance metrics
      set ::classical_steps = ::classical_data.steps
      set ::quantum_steps = 1  # Grover's algorithm uses 1 iteration for 2 qubits
      
      set ::speedup = ::classical_steps / ::quantum_steps
      set ::time_ratio = ::classical_data.time / ::quantum_data.quantum_time
      
      set ::test_results.performance_comparison = {
        classical_steps: ::classical_steps,
        quantum_steps: ::quantum_steps,
        theoretical_speedup: ::speedup,
        time_ratio: ::time_ratio,
        classical_found: ::classical_data.found,
        quantum_found: true  # Assuming quantum search found the target
      }
      emit test.performance.completed with ::test_results
    }

    on grover.run_complete {
      set ::target = $1.target
      set ::iterations = $1.iterations
      set ::state = $1.state
      
      set ::test_results.grover_result = {
        target: ::target,
        iterations: ::iterations,
        final_state: ::state
      }
      emit test.grover.completed with ::test_results
    }
  }
}

# Test with larger database simulation
component ::test.scalable_search {
  init {
    set ::test_results = {}
    set ::database_sizes = [4, 8, 16, 32, 64]
  }

  behavior {
    on start {
      # Test performance scaling
      loop ::size in ::database_sizes {
        emit test.scale_search with {size: ::size}
      }
    }

    on test.scale_search {
      set ::size = $1.size
      
      # Classical complexity: O(N)
      set ::classical_steps = ::size
      
      # Quantum complexity: O(√N)
      set ::quantum_steps = ::sqrt(::size)
      
      # Calculate theoretical speedup
      set ::speedup = ::classical_steps / ::quantum_steps
      
      set ::test_results.scaling = {
        database_size: ::size,
        classical_steps: ::classical_steps,
        quantum_steps: ::quantum_steps,
        theoretical_speedup: ::speedup
      }
      emit test.scaling.completed with ::test_results
    }
  }
}

# Test memory efficiency
component ::test.memory_efficiency {
  behavior {
    on start {
      # Test quantum memory storage
      emit memory.store_quantum_state with {
        state_id: "test_state_1",
        quantum_state: {
          amplitudes: [{real: 0.707, imag: 0.0}, {real: 0.707, imag: 0.0}],
          entanglement_strength: 1.0
        },
        coherence_time: 1000,
        metadata: {type: "bell_state", created: ::now()}
      }
      
      # Test classical memory storage
      set ::classical_data = ["item1", "item2", "item3", "item4"]
      
      # Compare memory usage
      set ::quantum_memory_size = 16  # 2 complex numbers * 8 bytes
      set ::classical_memory_size = ::classical_data.length * 8  # 4 strings * 8 bytes
      
      set ::memory_efficiency = ::classical_memory_size / ::quantum_memory_size
      
      set ::test_results.memory_test = {
        quantum_memory_size: ::quantum_memory_size,
        classical_memory_size: ::classical_memory_size,
        memory_efficiency: ::memory_efficiency
      }
      emit test.memory.completed with ::test_results
    }
  }
}

# Main test runner
component ::test.real_problem_runner {
  behavior {
    on start {
      # Run all real problem tests
      emit test.database_search.start
      emit test.scalable_search.start
      emit test.memory_efficiency.start
    }
  }
} 