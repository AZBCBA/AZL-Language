component ::test.nested.objects {
  init {
    # Test simple nested object
    set ::simple_nested = {
      outer: {
        inner: "value"
      }
    }
    
    # Test complex nested object (like quantum gates)
    set ::complex_nested = {
      0: {
        0: {real: 0.707, imag: 0.0},
        1: {real: 0.707, imag: 0.0}
      },
      1: {
        0: {real: 0.707, imag: 0.0},
        1: {real: -0.707, imag: 0.0}
      }
    }
    
    # Test with variables
    set ::var1 = 0.707
    set ::var2 = 0.0
    set ::variable_nested = {
      key1: {
        nested: ::var1
      },
      key2: {
        nested: ::var2
      }
    }
  }

  behavior {
    on start {
      emit test.nested_object_test
    }

    on test.nested_object_test {
      emit test.simple_nested_test
      emit test.complex_nested_test
      emit test.variable_nested_test
    }

    on test.simple_nested_test {
      set ::test_result = ::simple_nested
      emit test.simple_nested.completed
    }

    on test.complex_nested_test {
      set ::test_result = ::complex_nested
      emit test.complex_nested.completed
    }

    on test.variable_nested_test {
      set ::test_result = ::variable_nested
      emit test.variable_nested.completed
    }
  }
} 