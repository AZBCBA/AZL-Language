# Test AZL v2 Language Features

# 1. Basic Variables and Types
let integer = 42;
let float = 3.14;
let string = "Hello AZL v2";
let boolean = true;
let null_val = null;

say "Testing basic types:";
say integer;
say float;
say string;
say boolean;
say null_val;

# 2. Arrays
let numbers = [1, 2, 3, 4, 5];
let mixed = [1, "string", true];
let empty = [];

say "Testing arrays:";
say stringify(numbers);
say stringify(mixed);
say stringify(empty);

# 3. Objects
let person = {
  name: "AZL v2",
  age: 3,
  skills: ["learning", "reasoning"]
};

say "Testing objects:";
say stringify(person);

# 4. Object access
let name = person.name;
say "Object property access:";
say name;

# 5. Array access
let first = numbers[0];
say "Array access:";
say first;

# 6. Function calls
let result = write_file("test.txt", "Hello");
say "Function call result:";
say result;

# 7. String concatenation
let greeting = "Hello" + " " + "AZL v2";
say "String concatenation:";
say greeting;

# 8. Math operations
let sum = 5 + 3;
let product = 4 * 2;
let quotient = 10 / 2;

say "Math operations:";
say sum;
say product;
say quotient;

# 9. Comparisons
let greater = 5 > 3;
let equal = 5 == 5;
let not_equal = 5 != 3;

say "Comparisons:";
say greater;
say equal;
say not_equal;

# 10. Logical operations
let and_result = true and false;
let or_result = true or false;
let not_result = not false;

say "Logical operations:";
say and_result;
say or_result;
say not_result;

# 11. Type checking
say "Type checking:";
say typeof(integer);
say typeof(string);
say typeof(boolean);
say typeof(person);
say typeof(numbers); 