// Basic Array Features Test - Working Features
say "=== AZL Basic Array Features Test ===";

// 1. Array Creation
let numbers = [1, 2, 3, 4, 5];
let strings = ["hello", "world", "azl"];
let mixed = [1, "two", 3.14, true];

say "1. Array Creation:";
say numbers;
say strings;
say mixed;

// 2. Array Access
let first = numbers[0];
let second = numbers[1];
let last = numbers[4];

say "2. Array Access:";
say "First element:";
say first;
say "Second element:";
say second;
say "Last element:";
say last;

// 3. Array Modification
numbers[0] = 10;
numbers[2] = 30;
strings[1] = "AZL";

say "3. Array Modification:";
say "Modified numbers:";
say numbers;
say "Modified strings:";
say strings;

// 4. Array Operations
let sum = numbers[0] + numbers[1] + numbers[2];
let product = numbers[3] * numbers[4];

say "4. Array Operations:";
say "Sum of first 3 elements:";
say sum;
say "Product of last 2 elements:";
say product;

// 5. Nested Arrays
let matrix = [[1, 2, 3], [4, 5, 6], [7, 8, 9]];
let nested = [["a", "b"], ["c", "d"]];

say "5. Nested Arrays:";
say "Matrix:";
say matrix;
say "Nested:";
say nested;

// 6. Array with Variables
let x = 100;
let y = 200;
let dynamic = [x, y, x + y];

say "6. Dynamic Arrays:";
say dynamic;

// 7. Array in Functions
fn get_array() {
    return [10, 20, 30];
}

let func_array = get_array();
say "7. Arrays in Functions:";
say "Function returned:";
say func_array;

// 8. Array Iteration (simulated with loop)
say "8. Array Iteration:";
let i = 0;
while (i < 5) {
    say "Element";
    say i;
    say "is";
    say numbers[i];
    i = i + 1;
}

say "=== Basic Array Features Test Complete ==="; 