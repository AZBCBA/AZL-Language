        "research_paper_quantum_computing.txt"
    ];
    
    let upload_result = batch_upload_documents(test_documents);
    print("✅ Document upload test completed");
    
    // Test 5: API handler test
    let handler = new AZMEHandler();
    print("✅ API handler initialized");
    
    return {
        "bridge_status": "initialized",
        "connectivity": connectivity,
        "capabilities": capabilities,
        "upload_result": upload_result,
        "api_handler": "ready"
    };
}

