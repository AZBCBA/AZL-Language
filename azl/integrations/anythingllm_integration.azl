// Run the AZME Bridge server
function run_server(port = 5000) {
    let handler = new AZMEHandler();
    print("🚀 AZME Bridge server running on port " + port);
    print("🔗 Health check: http://localhost:" + port + "/health");
    print("📊 Available models: " + handler.bridge.available_models);
    
    // Start HTTP server (simplified for AZL)
    start_http_server(port, handler);
}

// Main execution function
function main() {
    print("🚀 Starting AZME AnythingLLM Integration...");
    
    // Initialize bridge
    let bridge = new AZMEBridge();
    print("📊 Available models: " + bridge.available_models);
    print("🌐 API will be available at: http://localhost:5000");
    
    // Test integration
    let test_results = test_integration();
    print("✅ Integration testing completed");
    
    // Upload documents
    let documents = [
        "azme_quantum_systems_overview.md",
        "sample_python_code.py", 
        "research_paper_quantum_computing.txt"
    ];
    
    let upload_results = batch_upload_documents(documents);
    print("✅ Document upload completed");
    
    // Start server
    run_server(5000);
    
    return {
        "status": "success",
        "test_results": test_results,
        "upload_results": upload_results,
        "server_status": "running"
    };
}

