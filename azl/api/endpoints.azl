# azl/api/endpoints.azl
component ::api.training_endpoints {
  init {
    set ::port = parseInt((::internal.env("AZL_API_PORT") or "8080"))
    link ::core.command_processor
    link ::orchestrator.comprehensive_training_controller
    link ::system.http_server_compat
    link ::azme.speech_recognition
    link ::azme.speech_synthesis
    link ::azme.vision_processor
    link ::azme.visual_memory_linker
    say "🌐 Training API starting on port "
    say ::port
    emit start_http_server with ::port ::routes
  }

  behavior {
    # Start advanced training via HTTP
    listen for "api.train.start" {
      set p = $1 or {}
      link ::azme.security_policy_rules
      emit azme.check_permission to ::azme.security_policy_rules with { role: (::internal.env("AZL_API_ROLE") or "runtime"), event_type: "training.start" }
      listen for "azme.permission_result" then { if (!::event.data.has_permission) { emit api.response with { ok: false, error: "access_denied" }; return } }
      # Validate
      if (!p.dataset_path or p.dataset_path == "") {
        emit api.response with { ok: false, error: "missing_dataset_path" }
        return
      }
      if (p.device && !(p.device == "cpu" or p.device == "cuda")) {
        emit api.response with { ok: false, error: "invalid_device" }
        return
      }
      if (p.gpu_limit && (parseInt(p.gpu_limit) < 0 or parseInt(p.gpu_limit) > 100)) {
        emit api.response with { ok: false, error: "invalid_gpu_limit" }
        return
      }
      emit process_command to ::core.command_processor with "train.advanced" p
      emit api.response with { ok: true, started: true }
    }

    # Training status — surface last known state from orchestrator/metrics
    listen for "api.train.status" {
      set status = { epoch: 0, step: 0, dataset: "", metrics: {} }
      listen for "training.status" then { set status = ::event.data }
      emit "get_training_status" to ::orchestrator.comprehensive_training_controller
      emit api.response with { ok: true, status: status }
    }

    # Control: pause/resume/stop
    listen for "api.train.control" {
      set action = ($1 && $1.action) or ""
      link ::azme.security_policy_rules
      emit azme.check_permission to ::azme.security_policy_rules with { role: (::internal.env("AZL_API_ROLE") or "runtime"), event_type: ("training." + action) }
      listen for "azme.permission_result" then { if (!::event.data.has_permission) { emit api.response with { ok: false, error: "access_denied" }; return } }
      if action == "pause" { emit "pause_training" to ::orchestrator.comprehensive_training_controller; emit api.response with { ok: true, action: action } ; return }
      if action == "resume" { emit "resume_training" to ::orchestrator.comprehensive_training_controller; emit api.response with { ok: true, action: action } ; return }
      if action == "stop" { emit "stop_training" to ::orchestrator.comprehensive_training_controller; emit api.response with { ok: true, action: action } ; return }
      emit api.response with { ok: false, error: "invalid_action" }
    }

    # Configuration: set default training params
    listen for "api.train.configure" {
      set cfg = $1 or {}
      link ::azme.security_policy_rules
      emit azme.check_permission to ::azme.security_policy_rules with { role: (::internal.env("AZL_API_ROLE") or "runtime"), event_type: "training.config_update" }
      listen for "azme.permission_result" then { if (!::event.data.has_permission) { emit api.response with { ok: false, error: "access_denied" }; return } }
      set ::default_config = {
        device: (cfg.device or (::internal.env("AZL_DEVICE") or "auto")),
        gpu_limit: parseInt((cfg.gpu_limit or (::internal.env("AZL_GPU_LIMIT") or "0"))),
        epochs: parseInt((cfg.epochs or (::internal.env("AZL_EPOCHS") or "1"))),
        batch_size: parseInt((cfg.batch_size or (::internal.env("AZL_BATCH") or "1"))),
        mode: (cfg.mode or (::internal.env("AZL_TRAIN_MODE") or "supervised"))
      }
      emit "set_training_config" to ::orchestrator.comprehensive_training_controller with ::default_config
      emit api.response with { ok: true, config: ::default_config }
    }

    # Generic command endpoint → route through runtime integration
    listen for "api.command" {
      set payload = $1 or {}
      if (!payload.command) { emit api.response with { ok: false, error: "missing_command" }; return }
      link ::azme.security_policy_rules
      emit azme.check_permission to ::azme.security_policy_rules with { role: (::internal.env("AZL_API_ROLE") or "runtime"), event_type: ("command." + payload.command) }
      listen for "azme.permission_result" then { if (!::event.data.has_permission) { emit api.response with { ok: false, error: "access_denied" }; return } }
      link ::azl.runtime_integration
      emit runtime.command to ::azl.runtime_integration with { command: payload.command, params: (payload.params or {}) }
      emit api.response with { ok: true }
    }

    # Build endpoint: supports training commands or project builds
    listen for "api.build" {
      set req = $1 or {}
      link ::azl.runtime_integration
      link ::azme.security_policy_rules
      emit azme.check_permission to ::azme.security_policy_rules with { role: (::internal.env("AZL_API_ROLE") or "runtime"), event_type: "build.request" }
      listen for "azme.permission_result" then { if (!::event.data.has_permission) { emit api.response with { ok: false, error: "access_denied" }; return } }
      # Case A: build project manifest
      if (req.files && len(req.files) > 0) {
        emit build_project to ::azl.runtime_integration with (req.files or []) (req.options or { backend: "bytecode", workers: 4, incremental: true })
        emit api.response with { ok: true, kind: "build" }
        return
      }
      # Case B: training commands via /build
      if (req.train && req.train == "advanced") {
        set p = req.params or {}
        if (!p.dataset_path or p.dataset_path == "") { emit api.response with { ok: false, error: "missing_dataset_path" }; return }
        emit runtime.train.advanced to ::azl.runtime_integration with {
          dataset_path: p.dataset_path,
          mode: (p.mode or (::internal.env("AZL_TRAIN_MODE") or "supervised")),
          config: {
            device: (p.device or (::internal.env("AZL_DEVICE") or "auto")),
            gpu_limit: parseInt((p.gpu_limit or (::internal.env("AZL_GPU_LIMIT") or "0"))),
            epochs: parseInt((p.epochs or (::internal.env("AZL_EPOCHS") or "1"))),
            batch_size: parseInt((p.batch_size or (::internal.env("AZL_BATCH") or "1"))),
            strict: true
          }
        }
        emit api.response with { ok: true, kind: "train.advanced" }
        return
      }
      # Case C: generic command through /build (compat)
      if (req.command) {
        emit runtime.command to ::azl.runtime_integration with { command: req.command, params: (req.params or {}) }
        emit api.response with { ok: true, kind: "command" }
        return
      }
      emit api.response with { ok: false, error: "invalid_build_request" }
    }

    # HTTP server adapter
    listen for "start_http_server" {
      set port = $1
      set routes = $2
      emit http.server.start with { port: port, host: "0.0.0.0", handler: (req) => route_request(req, routes) }
    }

    # Simplified runner handlers for parallel training
    fn training_parallel_start_handler(req) {
      try {
        set body = (req && req.body ? json_parse(req.body) : {})
      } catch (e) { set body = {} }
      if (!body.dataset_path || body.dataset_path == "") { return { ok: false, error: "missing_dataset_path" } }
      set cfg = body.config || {}
      if (!(cfg.device == "cuda" && parseInt((cfg.num_gpus or 0)) > 1)) { return { ok: false, error: "parallel_requires_cuda_and_num_gpus>1" } }
      link ::ffi.fs
      set ds = body.dataset_path
    set req_id = ("req:" + (::azl.stdlib.time_now([]) % 1000000))
    emit read_file to ::ffi.fs with { path: ds, request_id: req_id }
    listen for "file_read" then {
      # Expect event as either (path, content) or { path, content, request_id }
      set ok = false
      if ($1 && $1.path) { if $1.path == ds && ($1.request_id == null || $1.request_id == req_id) { set ok = true; set raw = ($1.content or "") } }
      else { if $1 == ds { set ok = true; set raw = ($2 or "") } }
      if !ok { return }
      if raw == "" { return { ok: false, error: "dataset_empty" } }
        # split
        set lines = []
        set cur = ""; set i = 0; while i < raw.length { set ch = raw[i]; if ch == "\n" { if cur != "" { set lines.push(cur) } set cur = "" } else if ch != "\r" { set cur = cur + ch } set i = i + 1 }; if cur != "" { set lines.push(cur) }
        link ::orchestrator.parallel_training
        emit training.parallel.start to ::orchestrator.parallel_training with { data: lines, mode: (body.mode or "supervised"), config: (cfg or {}) }
      }
      return { ok: true, started: true }
    }
    fn training_parallel_status_handler(req) {
      link ::orchestrator.parallel_training
      set s = (::orchestrator.parallel_training.status or { state: "unknown" })
      return { ok: true, status: s }
    }
  }

  fn route_request(req, routes) {
    set method = (req && req.method ? req.method : "GET").toUpperCase()
    set path = (req && req.path ? req.path : "/")
    set body = {}
    if req && req.body { try { set body = json_parse(req.body) } catch (e) { set body = {} } }
    if routes[path] && routes[path][method] {
      set fn = routes[path][method]
      set result = (method == "POST" ? fn(body) : fn())
      return { status: 200, headers: { "Content-Type": "application/json" }, body: json_stringify(result) }
    }
    return { status: 404, headers: { "Content-Type": "application/json" }, body: json_stringify({ error: "not_found", path: path }) }
  }

  memory {
    routes = {
      "/health": { "GET": () => ({ ok: true }) },
      "/training/start": { "POST": (data) => { emit api.train.start with data; return { ok: true } } },
      "/training/status": { "GET": () => { emit api.train.status; return { ok: true } } },
      "/training/control": { "POST": (data) => { emit api.train.control with data; return { ok: true } } },
      "/training/config": { "POST": (data) => { emit api.train.configure with data; return { ok: true } } },
      "/command": { "POST": (data) => { emit api.command with data; return { ok: true } } },
      "/build": { "POST": (data) => { emit api.build with data; return { ok: true } } },
      "/metrics": { "GET": () => { return (::api.metrics_endpoint.get_metrics()) } },
      "/metrics/detailed": { "GET": () => { return (::api.metrics_endpoint.get_metrics_detailed()) } },
      "/training/profile": { "POST": (cfg) => { emit metrics.configure with cfg; return { ok: true } } },
      "/voice/command": { "POST": (body) => { return (::api.voice_bridge.handle_command(body)) } },
      "/voice/say": { "POST": (body) => { return (::api.voice_bridge.say(body)) } },
      "/vision/process": { "POST": (body) => { return (::api.vision_bridge.process(body)) } },
      "/evolution/suggestions": { "GET": () => { return (::api.evolution_endpoint.get_suggestions()) } },
      "/evolution/apply": { "POST": (body) => { return (::api.evolution_endpoint.apply_suggestion(body)) } },
      "/training/parallel/start": { "POST": (data) => { emit api.train.parallel.start with data; return { ok: true } } },
      "/training/parallel/status": { "GET": () => { emit api.train.parallel.status; return { ok: true } } },
      "/plugins/register": { "POST": (body) => { emit api.plugins.register with body; return { ok: true } } },
      "/plugins/unregister": { "POST": (body) => { emit api.plugins.unregister with body; return { ok: true } } },
      "/plugins/enable": { "POST": (body) => { emit api.plugins.enable with body; return { ok: true } } },
      "/plugins/disable": { "POST": (body) => { emit api.plugins.disable with body; return { ok: true } } },
        "/plugins/list": { "GET": () => { emit api.plugins.list; return { ok: true } } },
        
        # Runtime toggles (secured via policy): device and hybrid thresholds
        "/training/toggle/device": { "POST": (data) => { emit api.train.toggle.device with data; listen for "api.response" then { set r = ::event.data }; return (r or { ok: true }) } },
        "/training/toggle/hybrid": { "POST": (data) => { emit api.train.toggle.hybrid with data; listen for "api.response" then { set r = ::event.data }; return (r or { ok: true }) } }
    }
    default_config = {}
  }
}

# Training Plugin API endpoints
component ::api.training_plugins_endpoints {
  init {
    link ::extensions.training_plugin_manager
    link ::azme.security_policy_rules
  }

  # Runtime toggle endpoints (policy-gated)
  component ::api.training_runtime_toggles {
    init { link ::azme.security_policy_rules }
    behavior {
      listen for "api.train.toggle.device" {
        set p = $1 or {}
        emit azme.check_permission to ::azme.security_policy_rules with { role: (::internal.env("AZL_API_ROLE") or "runtime"), event_type: "training.config_update" }
        listen for "azme.permission_result" then { if (!::event.data.has_permission) { emit api.response with { ok: false, error: "access_denied" }; return } }
        set dev = (p.device or (::internal.env("AZL_DEVICE") or "cpu"))
        if !(dev == "cpu" or dev == "cuda") { emit api.response with { ok: false, error: "invalid_device" }; return }
        set gpu = parseInt((p.gpu_limit or (::internal.env("AZL_GPU_LIMIT") or "0")))
        if (gpu < 0 or gpu > 100) { emit api.response with { ok: false, error: "invalid_gpu_limit" }; return }
        emit "set_training_config" to ::orchestrator.comprehensive_training_controller with { device: dev, gpu_limit: gpu }
        emit api.response with { ok: true, device: dev, gpu_limit: gpu }
        
        # Metrics snapshots: consciousness state and LHA3 stats (best-effort)
        "/metrics/consciousness": { "GET": () => { emit api.metrics.consciousness; return { ok: true } } },
        "/metrics/lha3": { "GET": () => { emit api.metrics.lha3; return { ok: true } } }
      }
      listen for "api.train.toggle.hybrid" {
        set p = $1 or {}
        emit azme.check_permission to ::azme.security_policy_rules with { role: (::internal.env("AZL_API_ROLE") or "runtime"), event_type: "training.config_update" }
        listen for "azme.permission_result" then { if (!::event.data.has_permission) { emit api.response with { ok: false, error: "access_denied" }; return } }
        # Forward to advanced_training hybrid config event
        set enabled = (p.enabled != null ? (p.enabled == true) : null)
        set thresholds = (p.thresholds or null)
        emit azme.set_hybrid_config to ::nlp.advanced_training with { enabled: enabled, thresholds: thresholds }
        emit api.response with { ok: true }
      }
    }
  }
  behavior {
    listen for "api.plugins.register" { emit training.plugins.register to ::extensions.training_plugin_manager with $1 }
    listen for "api.plugins.unregister" { emit training.plugins.unregister to ::extensions.training_plugin_manager with $1 }
    listen for "api.plugins.enable" { emit training.plugins.enable to ::extensions.training_plugin_manager with $1 }
    listen for "api.plugins.disable" { emit training.plugins.disable to ::extensions.training_plugin_manager with $1 }
    listen for "api.plugins.list" { emit training.plugins.list to ::extensions.training_plugin_manager with $1 }
  }
}

# Metrics endpoint component (concise JSON)
component ::api.metrics_endpoint {
  init {}
  behavior {
    listen for "api.metrics.consciousness" {
      link ::consciousness.neural_quantum
      set s = (::consciousness.neural_quantum.get_state() or {})
      emit api.response with { ok: true, state: s }
    }
    listen for "api.metrics.lha3" {
      link ::memory.enhanced_lha3
      emit get_quantum_memory_stats to ::memory.enhanced_lha3
      listen for "memory.quantum_stats.retrieved" then { emit api.response with { ok: true, stats: ::event.data } }
    }
  }
  memory {}
  export fn get_metrics() {
    set m = ::metrics.training.metrics || {}
    return {
      total_steps: m.total_steps || 0,
      avg_loss: m.avg_loss || 0.0,
      avg_throughput: m.avg_throughput || 0.0,
      avg_latency_ms: m.avg_latency_ms || 0.0,
      peak_memory_gb: m.peak_memory || 0.0,
      total_time_ms: m.total_time_ms || 0.0,
      phases: m.phase_timings || {},
      per_device: m.per_device || {},
      adaptive: (m.adaptive || {}),
      pipeline: (m.pipeline || {}),
      hybrid: (m.hybrid || {}),
      health: (m.health || {})
    }
  }

  export fn get_metrics_detailed() {
    set m = ::metrics.training.metrics || {}
    return {
      core: {
        total_steps: m.total_steps || 0,
        avg_loss: m.avg_loss || 0.0,
        avg_throughput: m.avg_throughput || 0.0,
        avg_latency_ms: m.avg_latency_ms || 0.0,
        peak_memory_gb: m.peak_memory || 0.0,
        total_time_ms: m.total_time_ms || 0.0,
        phases: m.phase_timings || {}
      },
      recent: {
        losses: m.recent_losses || [],
        latencies_ms: m.recent_latencies || []
      },
      adaptive: {
        upshifts: (m.adaptive && m.adaptive.upshifts) || 0,
        downshifts: (m.adaptive && m.adaptive.downshifts) || 0,
        denied_updates: (m.adaptive && m.adaptive.denied_updates) || 0,
        loss_spike_events: (m.adaptive && m.adaptive.loss_spike_events) || 0,
        headroom_windows: (m.adaptive && m.adaptive.headroom_windows) || 0,
        last_action_reason: (m.adaptive && m.adaptive.last_action_reason) || ""
      },
      pipeline: {
        enriched: (m.pipeline && m.pipeline.enriched) || 0,
        deduped: (m.pipeline && m.pipeline.deduped) || 0,
        dedup_rate: (m.pipeline && m.pipeline.dedup_rate) || 0.0,
        avg_text_len: (m.pipeline && m.pipeline.avg_text_len) || 0.0,
        curriculum_mode: (m.pipeline && m.pipeline.curriculum_mode) || "auto"
      },
      hybrid: {
        quantum_share_percent: (m.hybrid && m.hybrid.quantum_share_percent) || 0.0,
        avg_loss: (m.hybrid && m.hybrid.avg_loss) || 0.0
      },
      health: {
        risk_score: (m.health && m.health.risk_score) || 0.0,
        reasons: (m.health && m.health.reasons) || [],
        suggestions: (m.health && m.health.suggestions) || [],
        p95_ms: (m.health && m.health.p95_ms) || null,
        device_cv: (m.health && m.health.device_cv) || null,
        peak_mem_gb: (m.health && m.health.peak_mem_gb) || null,
        ts: (m.health && m.health.ts) || null
      }
    }
  }
}

# Voice and Vision API bridges
component ::api.voice_bridge {
  init {}
  behavior {}
  memory {}
  export fn handle_command(body) {
    set text = (body && body.text) or ""
    if text == "" { return { ok: false, error: "missing_text" } }
    # Simple intent mapping
    set lower = text.toLowerCase()
    if lower.contains("start") && lower.contains("train") {
      emit process_command to ::core.command_processor with "train.advanced" { dataset_path: (body.dataset_path or ""), device: (body.device or "cpu"), gpu_limit: parseInt((body.gpu_limit or 0)) }
      return { ok: true, intent: "start_training" }
    }
    if lower.contains("pause") { emit "pause_training" to ::orchestrator.comprehensive_training_controller; return { ok: true, intent: "pause" } }
    if lower.contains("resume") { emit "resume_training" to ::orchestrator.comprehensive_training_controller; return { ok: true, intent: "resume" } }
    if lower.contains("stop") { emit "stop_training" to ::orchestrator.comprehensive_training_controller; return { ok: true, intent: "stop" } }
    if lower.contains("status") { emit "get_training_status" to ::orchestrator.comprehensive_training_controller; return { ok: true, intent: "status" } }
    return { ok: false, error: "unrecognized_command" }
  }
  export fn say(body) {
    set text = (body && body.text) or ""
    if text == "" { return { ok: false, error: "missing_text" } }
    emit azme.respond_with_voice to ::azme.speech_synthesis with { text: text }
    return { ok: true }
  }
}

component ::api.vision_bridge {
  init {}
  behavior {}
  memory {}
  export fn process(body) {
    set path = (body && body.path) or ""
    if path == "" { return { ok: false, error: "missing_path" } }
    emit process_image to ::azme.vision_processor with { path: path, source: "api" }
    return { ok: true }
  }
}

# Evolution suggestions endpoints (read-only by default)
component ::api.evolution_endpoint {
  init {}
  behavior {}
  memory {}
  export fn get_suggestions() {
    # Expose recent entries from self-execution engine suggestions buffer
    return { ok: true, suggestions: (::azl.self_execution_engine.suggestions or []) }
  }
  export fn apply_suggestion(body) {
    # Disabled by default for safety
    return { ok: false, error: "apply_disabled" }
  }
}

# AZL API Endpoints - HTTP endpoints for the enterprise daemon
# Provides health, readiness, build, and status endpoints

component ::api.endpoints {
  init {
    say "🌐 AZL API Endpoints initializing..."
    
    set ::ready = false
    set ::start_time = ::azl.stdlib.time_now([])
    set ::request_count = 0
    
    # Link to HTTP server and chat interface
    link ::net.http.server
    # Ensure training/runtime subsystems are online for command dispatch
    link ::core.command_processor
    link ::orchestrator.comprehensive_training_controller
    link ::error.system
    link ::azme.chat_interface
    
    say "✅ API Endpoints ready"
  }
  
  behavior {
    listen for "http.server.started" then {
      say "🌐 HTTP server started, setting up endpoints..."
      ::setup_endpoints()
    }
    
    listen for "daemon.enterprise.ready" then {
      say "✅ Daemon ready, enabling endpoints"
      set ::ready = true
    }
    
    # For testing in the simplified runner, set up endpoints immediately
    listen for "initialize_chat_interface" then {
      # Dev-gated inline endpoints for simplified runner only
      set ::dev_inline = ((::internal.env("AZL_DEV_INLINE_ENDPOINTS") or "0") == "1")
      if !::dev_inline { say "🔒 Inline endpoints disabled (set AZL_DEV_INLINE_ENDPOINTS=1 to enable)"; return }
      say "🔧 Setting up endpoints for testing (dev inline enabled)..."
      
      # Inline route setup for testing
      say "🔗 Adding route: GET /healthz"
      emit "http.server.add_route" to ::net.http.server with { path: "/healthz", method: "GET", handler: ::health_check }
      
      say "🔗 Adding route: GET /readyz"
      emit "http.server.add_route" to ::net.http.server with { path: "/readyz", method: "GET", handler: ::ready_check }
      
      say "🔗 Adding route: GET /status"
      emit "http.server.add_route" to ::net.http.server with { path: "/status", method: "GET", handler: ::status_check }
      
      say "🔗 Adding route: POST /build"
      emit "http.server.add_route" to ::net.http.server with { path: "/build", method: "POST", handler: ::handle_build }
      
      say "🔗 Adding route: GET /analytics"
      emit "http.server.add_route" to ::net.http.server with { path: "/analytics", method: "GET", handler: ::get_analytics }

      say "🔗 Adding route: POST /chat"
      emit "http.server.add_route" to ::net.http.server with { path: "/chat", method: "POST", handler: ::handle_chat }
      
      # Training endpoints for simplified runner
      say "🔗 Adding route: POST /training/start"
      emit "http.server.add_route" to ::net.http.server with { path: "/training/start", method: "POST", handler: ::training_start_handler }

      say "🔗 Adding route: GET /training/status"
      emit "http.server.add_route" to ::net.http.server with { path: "/training/status", method: "GET", handler: ::training_status_handler }

      say "🔗 Adding route: POST /training/control"
      emit "http.server.add_route" to ::net.http.server with { path: "/training/control", method: "POST", handler: ::training_control_handler }

      say "🔗 Adding route: POST /training/config"
      emit "http.server.add_route" to ::net.http.server with { path: "/training/config", method: "POST", handler: ::training_config_handler }

      # Parallel training endpoints for simplified runner
      say "🔗 Adding route: POST /training/parallel/start"
      emit "http.server.add_route" to ::net.http.server with { path: "/training/parallel/start", method: "POST", handler: ::training_parallel_start_handler }

      say "🔗 Adding route: GET /training/parallel/status"
