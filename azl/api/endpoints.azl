  # Health check handler
  ::health_check = (request) => {
    set ::request_count = ::request_count + 1
    
    return {
      status: 200,
      headers: { "Content-Type": "application/json" },
      body: '{"status":"healthy","timestamp":"' + ::azl.stdlib.time_now([]) + '","uptime":' + (::azl.stdlib.time_now([]) - ::start_time) + '}'
    }
  }
  
  # Readiness check handler
  ::ready_check = (request) => {
    set ::request_count = ::request_count + 1
    
    if ::ready {
      return {
        status: 200,
        headers: { "Content-Type": "application/json" },
        body: '{"status":"ready","daemon":"running"}'
      }
    } else {
      return {
        status: 503,
        headers: { "Content-Type": "application/json" },
        body: '{"status":"not_ready","daemon":"starting"}'
      }
    }
  }
  
  # Status check handler
  ::status_check = (request) => {
    set ::request_count = ::request_count + 1
    
    return {
      status: 200,
      headers: { "Content-Type": "application/json" },
      body: '{"status":"ok","daemon":"running","request_count":' + ::request_count + ',"uptime":' + (::azl.stdlib.time_now([]) - ::start_time) + '}'
    }
  }
  
  # Build handler
  ::handle_build = (request) => {
    set ::request_count = ::request_count + 1
    set payload = ::safe_parse_json(request.body)
    # Case A: training via /build
    if payload.train && payload.train == "advanced" {
      set p = payload.params or {}
      set dataset_path = p.dataset_path || p.data_path || ""
      if (dataset_path == null or dataset_path == "") {
        return { status: 400, headers: { "Content-Type": "application/json" }, body: '{"error":"missing_dataset_path"}' }
      }
      set mode = (p.mode or (::internal.env("AZL_TRAIN_MODE") or "supervised"))
      set device = (p.device or (::internal.env("AZL_DEVICE") or "auto"))
      set cfg = {
        device: device,
        gpu_limit: parseInt((p.gpu_limit or (::internal.env("AZL_GPU_LIMIT") or "0"))),
        num_gpus: parseInt((p.num_gpus or (::internal.env("AZL_NUM_GPUS") or "1"))),
        epochs: parseInt((p.epochs or (::internal.env("AZL_EPOCHS") or "1"))),
        batch_size: parseInt((p.batch_size or (::internal.env("AZL_BATCH") or "1"))),
        strict: true
      }
      emit runtime.train.advanced to ::azl.runtime_integration with { dataset_path: dataset_path, mode: mode, config: cfg }
      return { status: 202, headers: { "Content-Type": "application/json" }, body: '{"status":"accepted","kind":"train.advanced"}' }
    }
    # Case B: explicit command routing
    if payload.command {
      set cmd = payload.command
      set params = (payload.params or {})
      if cmd == "train.advanced" {
        # Validate
        set dataset_path = params.dataset_path || params.data_path || ""
        if (dataset_path == null or dataset_path == "") { return { status: 400, headers: { "Content-Type": "application/json" }, body: '{"error":"missing_dataset_path"}' } }
        set mode = (params.mode or (::internal.env("AZL_TRAIN_MODE") or "supervised"))
        set cfg = {
          device: (params.device or (::internal.env("AZL_DEVICE") or "auto")),
          gpu_limit: parseInt((params.gpu_limit or (::internal.env("AZL_GPU_LIMIT") or "0"))),
          num_gpus: parseInt((params.num_gpus or (::internal.env("AZL_NUM_GPUS") or "1"))),
          epochs: parseInt((params.epochs or (::internal.env("AZL_EPOCHS") or "1"))),
          batch_size: parseInt((params.batch_size or (::internal.env("AZL_BATCH") or "1"))),
          strict: true
        }
        emit runtime.train.advanced to ::azl.runtime_integration with { dataset_path: dataset_path, mode: mode, config: cfg }
        return { status: 202, headers: { "Content-Type": "application/json" }, body: '{"status":"accepted","kind":"train.advanced"}' }
      }
      # Strict: unknown command rejected
      emit log_error with { type: "invalid_request", message: "unknown_command", context: { path: "/build", command: cmd } }
      return { status: 400, headers: { "Content-Type": "application/json" }, body: '{"error":"unknown_command"}' }
    }
    # Case C: project build request
    set build_data = payload
    emit daemon.enterprise.build with { files: (build_data.files or []), options: (build_data.options or {}) }
    return { status: 202, headers: { "Content-Type": "application/json" }, body: '{"status":"accepted","message":"Build submitted"}' }
  }
  
  # Analytics handler
  ::get_analytics = (request) => {
    set ::request_count = ::request_count + 1
    link ::metrics.training
    link ::build.cache_manager
    set m = ::metrics.training.metrics || {}
    # Compute derived analytics: percentiles, trend, anomalies, gpu imbalance, ETA
    set recent_lat = (m.recent_latencies || [])
    set recent_loss = (m.recent_losses || [])
    set p50 = ::percentile(recent_lat, 0.50)
    set p95 = ::percentile(recent_lat, 0.95)
    set p99 = ::percentile(recent_lat, 0.99)
    set trend = ::linear_trend(recent_loss)
    set anomalies = ::detect_anomalies(recent_lat)
    set dev = (m.per_device || {})
    set imbalance = ::device_imbalance(dev)
    set total_items = (m.total_items || null)
    set done = (m.total_steps || 0)
    set eta_ms = (total_items && m.avg_throughput && m.avg_throughput > 0) ? ((total_items - done) * 1000.0 / m.avg_throughput) : null
    set out = {
      request_count: ::request_count,
      uptime_ms: (::azl.stdlib.time_now([]) - ::start_time),
      core: {
        total_steps: (m.total_steps || 0),
        avg_loss: (m.avg_loss || 0.0),
        avg_throughput: (m.avg_throughput || 0.0),
        avg_latency_ms: (m.avg_latency_ms || 0.0),
        total_time_ms: (m.total_time_ms || 0.0)
      },
      percentiles_ms: { p50: p50, p95: p95, p99: p99 },
      trends: { loss_slope: trend.slope, loss_intercept: trend.intercept },
      anomalies: anomalies,
      per_device: dev,
      gpu_imbalance: imbalance,
      forecasting: { total_items: total_items, done: done, eta_ms: eta_ms },
      errors: { recent: (m.errors || []), count: (m.error_count || 0) },
      cache: ::build.cache_manager.kv_stats()
    }
    return { status: 200, headers: { "Content-Type": "application/json" }, body: ::azl.stdlib.json_stringify(out) }
  }

  # Metrics SSE stream (snapshot)
  ::metrics_stream_handler = (request) => {
    link ::metrics.training
    set m = ::metrics.training.metrics || {}
    set payload = ::azl.stdlib.json_stringify({
      t: ::azl.stdlib.time_now([]),
      run_id: (m.run_id || ""),
      core: { total_steps: (m.total_steps || 0), avg_loss: (m.avg_loss || 0.0), avg_latency_ms: (m.avg_latency_ms || 0.0) },
      health: (m.health || {}),
      pipeline: (m.pipeline || {}),
      hybrid: (m.hybrid || {}),
      slo: (m.slo || {}),
      drift: (m.drift || {})
    })
    return { status: 200, headers: { "Content-Type": "text/event-stream" }, body: "data: " + payload + "\n\n" }
  }

