    # Training control endpoints (central runtime integration)
    say "🔗 Adding route: POST /training/start"
    emit "http.server.add_route" to ::net.http.server with { path: "/training/start", method: "POST", handler: ::training_start_handler }

    say "🔗 Adding route: GET /training/status"
    emit "http.server.add_route" to ::net.http.server with { path: "/training/status", method: "GET", handler: ::training_status_handler }

    say "🔗 Adding route: POST /training/control"
    emit "http.server.add_route" to ::net.http.server with { path: "/training/control", method: "POST", handler: ::training_control_handler }

    say "🔗 Adding route: POST /training/config"
    emit "http.server.add_route" to ::net.http.server with { path: "/training/config", method: "POST", handler: ::training_config_handler }

