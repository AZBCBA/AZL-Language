  # Chat handler
  ::handle_chat = (request) => {
    set payload = ::parse_json(request.body)
    set msg = payload.message || ""
    set uid = payload.user_id || "api"
    set uid = uid || "api"
    set sid = payload.session_id || uid

    if (msg == "") {
      return { status: 400, headers: { "Content-Type": "application/json" }, body: '{"error":"message_required"}' }
    }

    # For now, return a simple response since we're in the simplified runner
    # In the full runtime, this would emit to ::azme.chat_interface and wait for response
    return { 
      status: 200, 
      headers: { "Content-Type": "application/json" }, 
      body: '{"response":"I received your message: \'' + msg + '\'. (Simplified AZME response)"}' 
    }
  }

  # --- Analytics helpers (pure AZL, CPU-safe) ---
  ::percentile = (arr, q) => {
    if arr == null || arr.length == 0 { return null }
    set a = arr.slice(0, arr.length)
    # simple insertion sort
    set i = 1
    while i < a.length {
      set key = a[i]; set j = i - 1
      while j >= 0 && a[j] > key { set a[j+1] = a[j]; set j = j - 1 }
      set a[j+1] = key; set i = i + 1
    }
    set pos = (q * (a.length - 1))
    set lo = floor(pos)
    set hi = ceil(pos)
    if lo == hi { return a[lo] }
    set t = (pos - lo)
    return (a[lo] * (1 - t)) + (a[hi] * t)
  }
  ::linear_trend = (arr) => {
    if arr == null || arr.length < 2 { return { slope: 0.0, intercept: (arr && arr.length > 0 ? arr[0] : 0.0) } }
    set n = arr.length
    set sumx = 0.0; set sumy = 0.0; set sumxy = 0.0; set sumx2 = 0.0
    set i = 0
    while i < n { set sumx = sumx + i; set sumy = sumy + arr[i]; set sumxy = sumxy + (i * arr[i]); set sumx2 = sumx2 + (i * i); set i = i + 1 }
    set denom = (n * sumx2) - (sumx * sumx)
    if denom == 0 { return { slope: 0.0, intercept: arr[0] } }
    set slope = ((n * sumxy) - (sumx * sumy)) / denom
    set intercept = (sumy - (slope * sumx)) / n
    return { slope: slope, intercept: intercept }
  }
  ::detect_anomalies = (arr) => {
    set res = []
    if arr == null || arr.length < 5 { return res }
    # MAD-based anomaly detection
    set med = ::percentile(arr, 0.5)
    set dev = []
    for v in arr { set dev.push(abs(v - med)) }
    set mad = ::percentile(dev, 0.5)
    if mad == 0 { return res }
    set i = 0
    while i < arr.length {
      set score = abs(arr[i] - med) / mad
      if score > 6.0 { set res.push({ idx: i, value: arr[i], score: score }) }
      set i = i + 1
    }
    return res
  }
  ::device_imbalance = (per_device) => {
    set keys = []
    for k in per_device { if k != null { set keys.push(k) } }
    if keys.length == 0 { return { cv: 0.0, max: null, min: null } }
    set vals = []
    for k in keys { set d = per_device[k]; set vals.push(d.steps or 0) }
    # coefficient of variation = std/mean
    set mean = 0.0; for v in vals { set mean = mean + v }; set mean = mean / max(1, vals.length)
    if mean == 0 { return { cv: 0.0, max: null, min: null } }
    set ss = 0.0; for v in vals { set ss = ss + ((v - mean) * (v - mean)) }
    set var = ss / vals.length
    set std = sqrt(var)
    set cv = std / mean
    # find max/min devices
    set maxk = keys[0]; set mink = keys[0]
    set i = 1; while i < keys.length { set k = keys[i]; if (per_device[k].steps or 0) > (per_device[maxk].steps or 0) { set maxk = k } if (per_device[k].steps or 0) < (per_device[mink].steps or 0) { set mink = k } set i = i + 1 }
    return { cv: cv, max: maxk, min: mink }
  }

  # Security-gated wrappers for simplified runner parallel control
  listen for "api.train.parallel.start" {
    set p = $1 or {}
    link ::azme.security_policy_rules
    emit azme.check_permission to ::azme.security_policy_rules with { role: (::internal.env("AZL_API_ROLE") or "runtime"), event_type: "training.parallel.start" }
    listen for "azme.permission_result" then { if (!::event.data.has_permission) { emit api.response with { ok: false, error: "access_denied" }; return } }
    # Defer to inline handler by constructing a fake request object
    set req = { body: ::azl.stdlib.json_stringify(p) }
    set res = training_parallel_start_handler(req)
    emit api.response with res
  }
  listen for "api.train.parallel.status" {
    set req = { }
    set res = training_parallel_status_handler(req)
    emit api.response with res
  }

  # ---- Training HTTP Handlers (integrated with runtime command processor) ----
  ::training_start_handler = (request) => {
    set payload = ::safe_parse_json(request.body)
    # Idempotency: if idempotency_key present and recently used, return 200
    set idem = payload.idempotency_key || ""
    if idem != "" {
      link ::build.cache_manager
      set seen = ::build.cache_manager.kv_get("idem:start:" + idem)
      if seen != null { return { status: 200, headers: { "Content-Type": "application/json" }, body: '{"status":"ok","idempotent":true}' } }
      ::build.cache_manager.kv_set_ttl("idem:start:" + idem, { ts: ::azl.stdlib.time_now([]) }, 300000)
    }
    set dataset_path = payload.dataset_path || payload.data_path || ""
    set mode = payload.mode || (::internal.env("AZL_TRAIN_MODE") or "supervised")
    set device = payload.device || (::internal.env("AZL_DEVICE") or "auto")
    set gpu_limit = parseInt((payload.gpu_limit or (::internal.env("AZL_GPU_LIMIT") or "0")))
    set epochs = parseInt((payload.epochs or (::internal.env("AZL_EPOCHS") or "1")))
    set batch_size = parseInt((payload.batch_size or (::internal.env("AZL_BATCH") or "1")))
    
    if (dataset_path == null or dataset_path == "") {
      emit log_error with { type: "invalid_request", message: "missing_dataset_path", context: { path: "/training/start" } }
      return { status: 400, headers: { "Content-Type": "application/json" }, body: '{"error":"missing_dataset_path"}' }
    }
    # Validate dataset readability
    set probe = ::azl.system_interface.read_file_host_sync(dataset_path)
    if (probe == null or probe == "") {
      emit log_error with { type: "io", message: "dataset_unreadable", context: { path: dataset_path } }
      return { status: 400, headers: { "Content-Type": "application/json" }, body: '{"error":"dataset_unreadable"}' }
    }
    
    # Dispatch through core command processor for consistent runtime handling
    emit process_command to ::core.command_processor with "train.advanced" {
      dataset_path: dataset_path,
      mode: mode,
      config: { device: device, gpu_limit: gpu_limit, epochs: epochs, batch_size: batch_size, strict: true }
    }
    return { status: 202, headers: { "Content-Type": "application/json" }, body: '{"status":"accepted","command":"train.advanced"}' }
  }

  # Inline handlers matching routes-map behavior
  ::handle_command_inline = (request) => {
    set payload = ::safe_parse_json(request.body)
    if !payload || !payload.command { return { status: 400, headers: { "Content-Type": "application/json" }, body: '{"error":"missing_command"}' } }
    emit runtime.command to ::azl.runtime_integration with { command: payload.command, params: (payload.params or {}) }
    return { status: 202, headers: { "Content-Type": "application/json" }, body: '{"status":"accepted"}' }
  }

  ::handle_build_inline = (request) => {
    set payload = ::safe_parse_json(request.body)
    if payload.train && payload.train == "advanced" {
      set p = payload.params or {}
      if !p.dataset_path { return { status: 400, headers: { "Content-Type": "application/json" }, body: '{"error":"missing_dataset_path"}' } }
      emit runtime.train.advanced to ::azl.runtime_integration with {
        dataset_path: p.dataset_path,
        mode: (p.mode or (::internal.env("AZL_TRAIN_MODE") or "supervised")),
        config: {
          device: (p.device or (::internal.env("AZL_DEVICE") or "auto")),
          gpu_limit: parseInt((p.gpu_limit or (::internal.env("AZL_GPU_LIMIT") or "0"))),
          epochs: parseInt((p.epochs or (::internal.env("AZL_EPOCHS") or "1"))),
          batch_size: parseInt((p.batch_size or (::internal.env("AZL_BATCH") or "1"))),
          strict: true
        }
      }
      return { status: 202, headers: { "Content-Type": "application/json" }, body: '{"status":"accepted","kind":"train.advanced"}' }
    }
    emit daemon.enterprise.build with { files: (payload.files or []), options: (payload.options or {}) }
    return { status: 202, headers: { "Content-Type": "application/json" }, body: '{"status":"accepted","kind":"build"}' }
  }

  ::metrics_handler = (request) => {
    set m = ::api.metrics_endpoint.get_metrics()
    return { status: 200, headers: { "Content-Type": "application/json" }, body: ::azl.stdlib.json_stringify(m) }
  }

  ::metrics_detailed_handler = (request) => {
    set m = ::api.metrics_endpoint.get_metrics_detailed()
    return { status: 200, headers: { "Content-Type": "application/json" }, body: ::azl.stdlib.json_stringify(m) }
  }

  ::quantum_constraints_handler = (request) => {
    link ::quantum.constraints
    set c = ::quantum.constraints.get_constraints()
    return { status: 200, headers: { "Content-Type": "application/json" }, body: ::azl.stdlib.json_stringify(c) }
  }

  ::quantum_state_handler = (request) => {
    link ::quantum.superposition
    set s = { entropy: (::quantum.superposition.entropy or null), norm2: (::quantum.superposition.norm2 or null), max_concentration: (::quantum.superposition.max_concentration or null) }
    return { status: 200, headers: { "Content-Type": "application/json" }, body: ::azl.stdlib.json_stringify(s) }
  }

  ::quantum_tick_handler = (request) => {
    emit "orchestrator.quantum.tick"
    return { status: 202, headers: { "Content-Type": "application/json" }, body: '{"ok":true,"tick":true}' }
  }

  # Quantum telemetry handler: ingest metrics and emit runtime events
  ::quantum_telemetry_handler = (request) => {
    set payload = ::safe_parse_json(request.body)
    set mc = (payload.max_concentration or null)
    set norm2 = (payload.norm2 or null)
    set entropy = (payload.entropy or null)
    set step = (payload.step or null)
    set ok = true
    if mc == null { set ok = false }
    emit quantum.metrics with { max_concentration: mc, norm2: norm2, entropy: entropy, step: step }
    emit quantum.measure.check with { max_concentration: mc }
    # Drive a single cognitive tick per telemetry to apply updated constraints
    emit "orchestrator.quantum.tick"
    return { status: (ok ? 200 : 202), headers: { "Content-Type": "application/json" }, body: (ok ? '{"ok":true}' : '{"ok":true,"note":"partial"}') }
  }

  # Best-effort SSE snapshot (single event)
  ::metrics_stream_handler = (request) => {
    set m = ::api.metrics_endpoint.get_metrics_detailed()
    set evt = "event: metrics\n" + "data: " + ::azl.stdlib.json_stringify(m) + "\n\n"
    return { status: 200, headers: { "Content-Type": "text/event-stream", "Cache-Control": "no-cache" }, body: evt }
  }

  ::metrics_handler_evolution = (request) => {
    set r = ::api.evolution_endpoint.get_suggestions()
    return { status: 200, headers: { "Content-Type": "application/json" }, body: ::azl.stdlib.json_stringify(r) }
  }
  
  ::evolution_apply_handler = (request) => {
    set body = ::safe_parse_json(request.body)
    set r = ::api.evolution_endpoint.apply_suggestion(body)
    return { status: 200, headers: { "Content-Type": "application/json" }, body: ::azl.stdlib.json_stringify(r) }
  }

  ::voice_command_handler = (request) => {
    set payload = ::safe_parse_json(request.body)
    set res = ::api.voice_bridge.handle_command(payload)
    return { status: (res.ok ? 202 : 400), headers: { "Content-Type": "application/json" }, body: ::azl.stdlib.json_stringify(res) }
  }

  ::voice_say_handler = (request) => {
    set payload = ::safe_parse_json(request.body)
    set res = ::api.voice_bridge.say(payload)
    return { status: (res.ok ? 200 : 400), headers: { "Content-Type": "application/json" }, body: ::azl.stdlib.json_stringify(res) }
  }

  ::vision_process_handler = (request) => {
    set payload = ::safe_parse_json(request.body)
    set res = ::api.vision_bridge.process(payload)
    return { status: (res.ok ? 202 : 400), headers: { "Content-Type": "application/json" }, body: ::azl.stdlib.json_stringify(res) }
  }

  ::training_status_handler = (request) => {
    set captured = { s: null }
    listen for "training.status" then { set captured.s = ::event.data }
    emit "get_training_status" to ::orchestrator.comprehensive_training_controller
    set s = captured.s
    if s == null { set s = { mode: null, step: null, epoch: null, error: "pending" } }
    return { status: 200, headers: { "Content-Type": "application/json" }, body: ::azl.stdlib.json_stringify(s) }
  }

  ::training_control_handler = (request) => {
    set payload = ::safe_parse_json(request.body)
    set action = payload.action || ""
    # Simple per-route rate limit (best-effort): 1 request/sec per action
    link ::build.cache_manager
    set rlkey = "rl:control:" + action
    set last = ::build.cache_manager.kv_get(rlkey)
    if last != null { return { status: 429, headers: { "Content-Type": "application/json" }, body: '{"error":"rate_limited"}' } }
    ::build.cache_manager.kv_set_ttl(rlkey, { ts: ::azl.stdlib.time_now([]) }, 1000)
    if action == "pause" { emit "pause_training" to ::orchestrator.comprehensive_training_controller; return { status: 202, headers: { "Content-Type": "application/json" }, body: '{"status":"paused"}' } }
    if action == "resume" { emit "resume_training" to ::orchestrator.comprehensive_training_controller; return { status: 202, headers: { "Content-Type": "application/json" }, body: '{"status":"resumed"}' } }
    if action == "stop" { emit "stop_training" to ::orchestrator.comprehensive_training_controller; return { status: 202, headers: { "Content-Type": "application/json" }, body: '{"status":"stopped"}' } }
    emit log_error with { type: "invalid_request", message: "invalid_action", context: { path: "/training/control", action: action } }
    return { status: 400, headers: { "Content-Type": "application/json" }, body: '{"error":"invalid_action"}' }
  }

  ::training_config_handler = (request) => {
    set cfg = ::safe_parse_json(request.body) || {}
    set normalized = {
      device: (cfg.device or (::internal.env("AZL_DEVICE") or "auto")),
      gpu_limit: parseInt((cfg.gpu_limit or (::internal.env("AZL_GPU_LIMIT") or "0"))),
      epochs: parseInt((cfg.epochs or (::internal.env("AZL_EPOCHS") or "1"))),
      batch_size: parseInt((cfg.batch_size or (::internal.env("AZL_BATCH") or "1"))),
      mode: (cfg.mode or (::internal.env("AZL_TRAIN_MODE") or "supervised"))
    }
    emit "set_training_config" to ::orchestrator.comprehensive_training_controller with normalized
    return { status: 202, headers: { "Content-Type": "application/json" }, body: ::azl.stdlib.json_stringify({ status: "config_updated", config: normalized }) }
  }

  ::training_recover_handler = (request) => {
    # Force a recovery attempt (e.g., after transient infra issues)
    emit "attempt_recovery" to ::orchestrator.comprehensive_training_controller
    return { status: 202, headers: { "Content-Type": "application/json" }, body: '{"status":"recovery_initiated"}' }
  }

  ::training_checkpoint_handler = (request) => {
    set body = ::safe_parse_json(request.body)
    set step = parseInt((body.step or "0"))
    set loss = (body.loss != null) ? body.loss : 0.0
    emit "maybe_checkpoint" to ::orchestrator.comprehensive_training_controller with step loss
    return { status: 202, headers: { "Content-Type": "application/json" }, body: '{"status":"checkpoint_requested"}' }
  }

  ::training_parallel_start_handler = (request) => {
    set payload = ::safe_parse_json(request.body)
    set dataset_path = payload.dataset_path || payload.data_path || ""
    set cfg = payload.config || {}
    if (dataset_path == null or dataset_path == "") { return { status: 400, headers: { "Content-Type": "application/json" }, body: '{"error":"missing_dataset_path"}' } }
    if !(cfg.device == "cuda" && parseInt((cfg.num_gpus or 0)) > 1) { return { status: 400, headers: { "Content-Type": "application/json" }, body: '{"error":"parallel_requires_cuda_and_num_gpus>1"}' } }
    # Read dataset and trigger parallel orchestrator
    link ::ffi.fs
    emit read_file to ::ffi.fs with dataset_path
    listen for "file_read" then {
      if $1 != dataset_path { return }
      set raw = ($2 or "")
      if raw == "" { return }
      # split
      set lines = []
      set cur = ""; set i = 0; while i < raw.length { set ch = raw[i]; if ch == "\n" { if cur != "" { set lines.push(cur) } set cur = "" } else if ch != "\r" { set cur = cur + ch } set i = i + 1 }; if cur != "" { set lines.push(cur) }
      link ::orchestrator.parallel_training
      emit training.parallel.start to ::orchestrator.parallel_training with { data: lines, mode: (payload.mode or "supervised"), config: cfg }
    }
    return { status: 202, headers: { "Content-Type": "application/json" }, body: '{"status":"accepted","parallel":true}' }
  }
  
  ::training_parallel_status_handler = (request) => {
    link ::orchestrator.parallel_training
    set s = (::orchestrator.parallel_training.status or { state: "unknown" })
    return { status: 200, headers: { "Content-Type": "application/json" }, body: ::azl.stdlib.json_stringify({ ok: true, status: s }) }
  }

  # Robust JSON parse helper using stdlib; never throws
  ::safe_parse_json = (text) => {
    if (text == null or text == "") { return {} }
    set obj = {}
    try { set obj = ::azl.stdlib.json_parse(text) } catch (e) { set obj = {} }
    if (obj == null) { set obj = {} }
    return obj
  }
  
  # Router function for HTTP server - REMOVED to allow dynamic routing
  # The http.server.add_route system handles all routing dynamically
  
  # Helper function to parse JSON
  ::parse_json = (json_string) => {
    set result = {}
    set json = json_string.trim()
    
    if json.starts_with("{") && json.ends_with("}") {
      set content = json.substring(1, json.length - 1)
      set pairs = content.split(",")
      
      for pair in pairs {
        set parts = pair.split(":")
        if parts.length == 2 {
          set key = parts[0].trim().replace('"', "")
          set value = parts[1].trim().replace('"', "")
          set result[key] = value
        }
      }
    }
    
    return result
  }
}
