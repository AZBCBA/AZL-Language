component ::aba.function_identifier {
  init {
    set ::function_scores = {
      escape: 0.0,
      attention: 0.0,
      access: 0.0,
      automatic: 0.0
    }
    set ::behavior_history = []
    set ::function_patterns = {
      escape: {
        antecedents: ["task_demand", "difficult_activity", "long_session"],
        consequences: ["task_removed", "break_given", "activity_stopped"],
        indicators: ["avoidance", "refusal", "tantrum"]
      },
      attention: {
        antecedents: ["alone", "ignored", "quiet_environment"],
        consequences: ["adult_attention", "scolding", "eye_contact"],
        indicators: ["calling_out", "making_noise", "repetitive_behavior"]
      },
      access: {
        antecedents: ["desired_item_visible", "request_denied", "waiting"],
        consequences: ["item_given", "request_granted", "access_provided"],
        indicators: ["grabbing", "pointing", "requesting"]
      },
      automatic: {
        antecedents: ["boredom", "sensory_stimulation", "internal_state"],
        consequences: ["sensory_satisfaction", "self_stimulation", "no_external_consequence"],
        indicators: ["repetitive_movements", "self_stimulation", "no_social_attention"]
      }
    }
    set ::confidence_threshold = 0.6
    set ::weighted_average_window = 10
    
    // Global Improvements
    set ::introspection_state = {
      last_review: now(),
      decision_history: [],
      goal_alignment: {},
      evolution_ready: false
    }
    set ::goal_meta = {
      primary_goal: "accurate_function_analysis",
      subgoals: ["pattern_recognition", "multi_function_detection", "intervention_effectiveness"],
      goal_progress: {},
      goal_weights: {
        accurate_function_analysis: 0.4,
        pattern_recognition: 0.3,
        multi_function_detection: 0.2,
        intervention_effectiveness: 0.1
      }
    }
    set ::evolution_slots = {
      pattern_intelligence: "future_enhancement",
      multi_function_analysis: "future_enhancement",
      predictive_intervention: "future_enhancement",
      behavioral_clustering: "future_enhancement"
    }
    set ::modular_interface = {
      submodules: ["pattern_analyzer", "function_processor", "intervention_engine"],
      external_hooks: ["cli_interface", "dashboard_integration", "api_endpoint"],
      split_capable: true
    }
  }

  behavior {
    listen for "behavior_observed" then {
      // Introspective state review before major decisions
      reflect_introspective_state()
      
      store ::function_analysis from analyze_behavior_function(::behavior_data)
      
      // Goal meta integration
      update_goal_progress(::function_analysis)
      
      // Real-time monitoring with confidence scoring
      branch when ::function_analysis.confidence > ::confidence_threshold {
        emit "function_identified" with ::function_analysis
        update_function_scores(::function_analysis)
        
        // Emit for modular response by other components
        emit "function_analysis_complete" with {
          primary_function: ::function_analysis.primary_function,
          secondary_function: ::function_analysis.secondary_function,
          confidence: ::function_analysis.confidence,
          evidence: ::function_analysis.evidence,
          timestamp: now(),
          goal_meta: ::goal_meta.primary_goal
        }
      }
      
      store ::behavior_history from add_behavior_to_history(::behavior_data)
      
      // Real-time streaming analysis
      emit "streaming_analysis" with {
        current_scores: ::function_scores,
        recent_confidence: ::function_analysis.confidence,
        trend: calculate_function_trend()
      }
      
      // Evolution slot check
      check_evolution_readiness()
    }

    listen for "behavior_sequence_completed" then {
      store ::sequence_analysis from analyze_behavior_sequence(::behavior_sequence)
      emit "sequence_pattern_identified" with ::sequence_analysis
    }

    listen for "multi_function_detected" then {
      store ::multi_function_analysis from analyze_multi_function_behavior(::behavior_data)
      emit "multi_function_result" with ::multi_function_analysis
    }
    
    // External hooking for CLI and dashboard integration
    listen for "cli.command" then {
      handle_cli_command(::cli_command)
    }
    
    listen for "dashboard.request" then {
      emit "dashboard.data" with get_dashboard_data()
    }
    
    listen for "api.request" then {
      emit "api.response" with handle_api_request(::api_request)
    }
    
    // Modular interface support
    listen for "module.split" then {
      emit "module.split.ready" with prepare_module_split()
    }
    
    listen for "evolution.trigger" then {
      trigger_evolution(::evolution_type)
    }
  }

  memory {
    function_scores
    behavior_history
    function_patterns
    confidence_threshold
    weighted_average_window
  }

  interface {
    analyze_behavior_function using ::behavior_data
    analyze_behavior_sequence using ::behavior_sequence
    get_function_scores
    get_top_functions using ::count
    update_function_scores using ::analysis_data
  }
}

// Function Analysis Functions
function analyze_behavior_function(behavior_data) {
  let analysis = {
    primary_function: null,
    secondary_function: null,
    confidence: 0.0,
    function_scores: {},
    evidence: {},
    multi_function_detected: false,
    blended_functions: []
  }
  
  // Calculate scores for each function
  let escape_score = calculate_escape_score(behavior_data)
  let attention_score = calculate_attention_score(behavior_data)
  let access_score = calculate_access_score(behavior_data)
  let automatic_score = calculate_automatic_score(behavior_data)
  
  set analysis.function_scores = {
    escape: escape_score,
    attention: attention_score,
    access: access_score,
    automatic: automatic_score
  }
  
  // Check for multi-function behavior
  let high_scoring_functions = get_high_scoring_functions(analysis.function_scores)
  branch when high_scoring_functions.length > 1 {
    set analysis.multi_function_detected = true
    set analysis.blended_functions = high_scoring_functions
    set analysis.confidence = calculate_multi_function_confidence(high_scoring_functions)
  } else {
    // Single function analysis
    let sorted_functions = sort_functions_by_score(analysis.function_scores)
    set analysis.primary_function = sorted_functions[0]
    set analysis.secondary_function = sorted_functions[1]
    
    // Calculate confidence based on score difference
    let primary_score = analysis.function_scores[analysis.primary_function]
    let secondary_score = analysis.function_scores[analysis.secondary_function]
    set analysis.confidence = primary_score - secondary_score
  }
  
  // Collect evidence
  set analysis.evidence = collect_function_evidence(behavior_data, analysis.primary_function || analysis.blended_functions[0])
  
  return analysis
}

function calculate_escape_score(behavior_data) {
  let score = 0.0
  let patterns = ::function_patterns.escape
  
  // Check antecedents
  loop for antecedent in behavior_data.antecedents {
    branch when patterns.antecedents.includes(antecedent) {
      increment score by 0.3
    }
  }
  
  // Check consequences
  loop for consequence in behavior_data.consequences {
    branch when patterns.consequences.includes(consequence) {
      increment score by 0.4
    }
  }
  
  // Check indicators
  loop for indicator in behavior_data.indicators {
    branch when patterns.indicators.includes(indicator) {
      increment score by 0.3
    }
  }
  
  return score
}

