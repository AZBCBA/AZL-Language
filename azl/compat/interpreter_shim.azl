module ::azl.runtime.interpreter.azl_interpreter
// Prefer v2 if that's your real core, else the classic interpreter.
import ::azl.interpreter as core
// or: import ::core.interpreter.azl_v2_interpreter as core

pub fn run_combined_file(path: str, entry: str) -> i32 {
  return core.run_combined_file(path, entry)
}
pub fn call_entry(entry: str) -> i32 {
  return core.call_entry(entry)
}
