module ::azl.bootstrap.azl_pure_launcher
import ::azl.pure_launcher as impl

// Adapt whatever API your bridge calls. Examples:
pub fn execute_azl_file(path: str, entry: str) -> i32 {
  return impl.execute_azl_file(path, entry)
}
pub fn execute_entry(entry: str) -> bool {
  return impl.execute_entry(entry)
}
