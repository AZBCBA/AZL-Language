# Gate F104: `::execute_ast` — `memory|set|::global|value` runs a stub memory-section row (mirrors `execute_component` memory phase at one encoded statement). Then `say|…` in the same `.nodes` walk + outer markers. `AZL_USE_VM` unset.
component ::azl.security {
  init {
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit p104_memory_tree with { ast: "f104-root", scope: "f104-sc", nodes: "memory|set|::f104_slot|F104_CELL
say|F104_SAYLINE" }
  }
  behavior {
    listen for "execute_complete" {
      say "EC104_INNER"
      say ::event.data.result
      say "P0_SEM_F104_OK"
    }
    listen for "p104_memory_tree" {
      set ::ast = ::event.data.ast
      set ::scope = ::event.data.scope
      set ::ast.nodes = ::event.data.nodes
      set ::use_vm = ((::internal.env("AZL_USE_VM") or "") == "1")
      if (::use_vm) {
        say "F104_VM_ON_BAD"
        return
      }
      say "F104_TREE"
      set ::result = ::execute_ast(::ast, ::scope)
      say ::f104_slot
      say "EX104_POST"
      say ::result
      emit execute_complete with { result: ::result }
    }
  }
}
