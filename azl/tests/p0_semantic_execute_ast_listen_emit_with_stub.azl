# Gate F102: `::execute_ast` — `listen|ev|emit|inner|with|key|value` stub queues inner event with payload (mirrors direct `emit|…|with|…` from F96). `AZL_USE_VM` unset.
component ::azl.security {
  init {
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit p102_stub_emit_with_tree with { ast: "f102-root", scope: "f102-sc", nodes: "listen|f102_chain|emit|f102_inner|with|f102_slot|F102_STUB_PAYLOAD
emit|f102_chain
say|F102_TAIL" }
  }
  behavior {
    listen for "execute_complete" {
      say "EC102_INNER"
      say ::event.data.result
      say "P0_SEM_F102_OK"
    }
    listen for "f102_inner" {
      say ::event.data.f102_slot
    }
    listen for "p102_stub_emit_with_tree" {
      set ::ast = ::event.data.ast
      set ::scope = ::event.data.scope
      set ::ast.nodes = ::event.data.nodes
      set ::use_vm = ((::internal.env("AZL_USE_VM") or "") == "1")
      if (::use_vm) {
        say "F102_VM_ON_BAD"
        return
      }
      say "F102_TREE"
      set ::result = ::execute_ast(::ast, ::scope)
      say "EX102_POST"
      say ::result
      emit execute_complete with { result: ::result }
    }
  }
}
