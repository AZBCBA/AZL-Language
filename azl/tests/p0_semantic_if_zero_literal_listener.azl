# P0 semantic spine — if (0) does not run branch (F48).

component ::azl.security {
  init {
  }
}

component ::p0.if.zero.stub {
  init {
  }
  behavior {
    listen for "e" {
      if (0) {
        say "F48_BAD"
      }
      say "P0_SEMANTIC_IF_ZERO_LITERAL_OK"
    }
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    link ::p0.if.zero.stub
    emit e
  }
}
