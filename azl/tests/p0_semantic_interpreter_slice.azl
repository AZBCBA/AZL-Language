# P0 semantic spine — widened init mirror of ::azl.interpreter (minimal spine contract only).

component ::azl.security {
  init {
  }
}

component ::p0.interpreter.slice {
  init {
    set ::tokens = []
    set ::ast = {}
    set ::variables = {}
    set ::functions = {}
    set ::components = {}
    set ::current_scope = "global"
    set ::call_stack = []
    set ::memory = {}
    set ::listeners = {}
    set ::errors = []
    set ::error_count = 0
    set ::dispatch_stack = []
    set ::recursion_depth = 0
    set ::halted = false
    set ::cache_order = []
    set ::halt_on_error = ((::internal.env("AZL_STRICT") or "1") == "1")
    set ::perf = { tok_cache: {}, ast_cache: {}, cap: 512 }
    link ::azl.security
    if ::perf == null {
      set ::perf = {}
    }
    if ::error_count == 0 {
      set ::p0_init_branch_ok = 1
    }
    say "🧠 Pure AZL Interpreter Initialized"
    say "🚀 NO RUST DEPENDENCIES!"
    say "🚀 FULL AZL SELF-HOSTING!"
    say "P0_SEMANTIC_INTERPRETER_SLICE_OK"
  }
}

component ::boot.entry {
  init {
    link ::p0.interpreter.slice
  }
}
