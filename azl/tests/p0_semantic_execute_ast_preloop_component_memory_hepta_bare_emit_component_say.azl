# Gate F144: `::execute_ast` — preloop `import|` + `link|` then `component|`, then **seven** bare **`memory|emit|ev`** rows (no `|with|`, FIFO queue + drain), then `component|`, then `memory|say|…`. `AZL_USE_VM` unset. **`import|i`** + **`e1`…`e7`** keep **`::ast.nodes`** within minimal **255-byte** bound.
component ::azl.security {
  init {
  }
}

component ::p144.linked {
  init {
    say "P144_LINK_SID"
  }
}

component ::p144.a {
  init {
    say "P144_A"
  }
}

component ::p144.b {
  init {
    say "P144_B"
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit p144_comp_hepta_bare_emit_comp with { ast: "f144-root", scope: "f144-sc", nodes: "import|i
link|::p144.linked
component|p144.a
memory|emit|e1
memory|emit|e2
memory|emit|e3
memory|emit|e4
memory|emit|e5
memory|emit|e6
memory|emit|e7
component|p144.b
memory|say|F144_MEM" }
  }
  behavior {
    listen for "execute_complete" {
      say "EC144_INNER"
      say ::event.data.result
      say "P0_SEM_F144_OK"
    }
    listen for "e1" {
      say "F144_BARE_1"
    }
    listen for "e2" {
      say "F144_BARE_2"
    }
    listen for "e3" {
      say "F144_BARE_3"
    }
    listen for "e4" {
      say "F144_BARE_4"
    }
    listen for "e5" {
      say "F144_BARE_5"
    }
    listen for "e6" {
      say "F144_BARE_6"
    }
    listen for "e7" {
      say "F144_BARE_7"
    }
    listen for "p144_comp_hepta_bare_emit_comp" {
      set ::ast = ::event.data.ast
      set ::scope = ::event.data.scope
      set ::ast.nodes = ::event.data.nodes
      set ::p0_exec_import_last = ""
      set ::use_vm = ((::internal.env("AZL_USE_VM") or "") == "1")
      if (::use_vm) {
        say "F144_VM_ON_BAD"
        return
      }
      say "F144_TREE"
      set ::result = ::execute_ast(::ast, ::scope)
      say ::p0_exec_import_last
      say "EX144_POST"
      say ::result
      emit execute_complete with { result: ::result }
    }
  }
}
