# Gate F187: `::execute_ast` ‚Äî `listen|‚Ä¶|call|fn|arg` stub prints fn say body then arg. `AZL_USE_VM` unset.
component ::azl.security {
  init {
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit p187_exec_tree with { ast: "f187-root", scope: "f187-sc", nodes: "fn|f187_fn|say|F187_CB
listen|f187_ev|call|f187_fn|F187_ARG
emit|f187_ev
say|F187_TAIL" }
  }
  behavior {
    listen for "execute_complete" {
      say "EC187_INNER"
      say ::event.data.result
      say "P0_SEM_F187_OK"
    }
    listen for "p187_exec_tree" {
      set ::ast = ::event.data.ast
      set ::scope = ::event.data.scope
      set ::ast.nodes = ::event.data.nodes
      set ::use_vm = ((::internal.env("AZL_USE_VM") or "") == "1")
      if (::use_vm) {
        say "F187_VM_ON_BAD"
        return
      }
      say "F187_TREE"
      set ::result = ::execute_ast(::ast, ::scope)
      say "EX187_POST"
      say ::result
      emit execute_complete with { result: ::result }
    }
  }
}
