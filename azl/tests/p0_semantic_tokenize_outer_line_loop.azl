# Gate F77: `listen for "tokenize"` outer loop — `::code.split("\n")`, `for ::line_text`, `::tokens.concat(::chunk)`, eol `.push`, `::line + 1` (value/line/column from `::var` in object `.push`).
component ::azl.security {
  init {
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    say "P0_SEMANTIC_TOK_OUTER_INIT_OK"
    emit tok_outer with { }
  }
  behavior {
    listen for "tok_outer" {
      set ::code = "x
y"
      set ::lines = ::code.split("\n")
      set ::tokens = []
      set ::line = 1
      for ::line_text in ::lines {
        set ::chunk = []
        set ::chunk.push({ type: "id", value: ::line_text, line: ::line, column: 1 })
        set ::tokens = ::tokens.concat(::chunk)
        set ::tokens.push({ type: "eol", value: ";", line: ::line, column: 0 })
        set ::line = ::line + 1
      }
      for ::row in ::tokens {
        say ::row
      }
      say "P0_SEMANTIC_TOK_OUTER_OK"
    }
  }
}
