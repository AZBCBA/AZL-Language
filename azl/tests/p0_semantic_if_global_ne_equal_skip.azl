# P0 semantic spine — if (::a != ::b) skips when globals are equal (F63).

component ::azl.security {
  init {
  }
}

component ::p0.if.ne.eq.stub {
  init {
  }
  behavior {
    listen for "e" {
      set ::a = "same"
      set ::b = "same"
      if (::a != ::b) {
        say "F63_BAD"
      }
      say "P0_SEMANTIC_IF_GLOBAL_NE_EQUAL_OK"
    }
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    link ::p0.if.ne.eq.stub
    emit e
  }
}
