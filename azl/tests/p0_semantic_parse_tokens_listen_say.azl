# Gate F155: ::parse_tokens ‚Äî `listen for e155 { say PAY155 }` ‚Üí `listen|e155|say|PAY155`.
component ::azl.security {
  init {
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit f155_parse with { }
  }
  behavior {
    listen for "f155_parse" {
      set ::tokens = []
      set ::tx = "listen for e155 { say PAY155 }"
      set ::nx = "1"
      set ::tokens = ::tokens.concat(::tokenize_line(::tx, ::nx))
      set ::tokens.push({ type: "eol", value: ";", line: 1, column: 0 })
      set ::_p = ::parse_tokens(::tokens)
      say ::ast.nodes
      say "P0_SEM_F155_OK"
    }
  }
}
