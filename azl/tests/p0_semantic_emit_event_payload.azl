# P0 semantic spine — emit with { … } binds ::event.data.* for the listener body (::azl.interpreter-shaped).

component ::azl.security {
  init {
  }
}

component ::p0.emit.event.payload.stub {
  init {
  }
  behavior {
    listen for "interpret" {
      say "got-payload"
      say ::event.data.trace
      say "P0_SEMANTIC_EMIT_PAYLOAD_OK"
    }
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    link ::p0.emit.event.payload.stub
    emit interpret with { trace: "spine-f10" }
  }
}
