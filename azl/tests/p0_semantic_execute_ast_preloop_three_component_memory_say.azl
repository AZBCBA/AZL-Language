# Gate F125: `::execute_ast` — preloop `import|` + `link|` then **`component|`** ×3 with **`memory|say|…`** between each pair (source order). `AZL_USE_VM` unset.
component ::azl.security {
  init {
  }
}

component ::p125.linked {
  init {
    say "P125_LINK_SID"
  }
}

component ::p125.a {
  init {
    say "P125_A"
  }
}

component ::p125.b {
  init {
    say "P125_B"
  }
}

component ::p125.c {
  init {
    say "P125_C"
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit p125_three_comp with { ast: "f125-root", scope: "f125-sc", nodes: "import|f125_mod_tag
link|::p125.linked
component|p125.a
memory|say|F125_M1
component|p125.b
memory|say|F125_M2
component|p125.c
memory|say|F125_M3" }
  }
  behavior {
    listen for "execute_complete" {
      say "EC125_INNER"
      say ::event.data.result
      say "P0_SEM_F125_OK"
    }
    listen for "p125_three_comp" {
      set ::ast = ::event.data.ast
      set ::scope = ::event.data.scope
      set ::ast.nodes = ::event.data.nodes
      set ::p0_exec_import_last = ""
      set ::use_vm = ((::internal.env("AZL_USE_VM") or "") == "1")
      if (::use_vm) {
        say "F125_VM_ON_BAD"
        return
      }
      say "F125_TREE"
      set ::result = ::execute_ast(::ast, ::scope)
      say ::p0_exec_import_last
      say "EX125_POST"
      say ::result
      emit execute_complete with { result: ::result }
    }
  }
}
