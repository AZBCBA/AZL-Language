# P0 semantic spine — if (::t) skips when ::t holds string "0" (F56).

component ::azl.security {
  init {
  }
}

component ::p0.if.var.zero.stub {
  init {
  }
  behavior {
    listen for "e" {
      set ::t = "0"
      if (::t) {
        say "F56_BAD"
      }
      say "P0_SEMANTIC_IF_VAR_ZERO_STRING_OK"
    }
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    link ::p0.if.var.zero.stub
    emit e
  }
}
