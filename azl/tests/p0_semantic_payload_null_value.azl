# P0 semantic spine — payload bare null (token null → stored/said as literal "null") (F29).

component ::azl.security {
  init {
  }
}

component ::p0.payload.null.stub {
  init {
  }
  behavior {
    listen for "e" {
      say ::event.data.n
      say "P0_SEMANTIC_PAYLOAD_NULL_OK"
    }
