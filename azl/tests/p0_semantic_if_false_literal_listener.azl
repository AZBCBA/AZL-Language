# P0 semantic spine — if (false) does not run branch (F40).

component ::azl.security {
  init {
  }
}

component ::p0.if.false.stub {
  init {
  }
  behavior {
    listen for "e" {
      if (false) {
        say "F40_BAD"
      }
      say "P0_SEMANTIC_IF_FALSE_LITERAL_OK"
    }
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    link ::p0.if.false.stub
    emit e
  }
}
