# P0 semantic spine — if condition reads ::event.data.* while payload is active (F14).

component ::azl.security {
  init {
  }
}

component ::p0.payload.if.stub {
  init {
  }
  behavior {
    listen for "interpret" {
      if ::event.data.mode == "strict" {
        say "branch-strict"
      }
      say "P0_SEMANTIC_PAYLOAD_IF_OK"
    }
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    link ::p0.payload.if.stub
    emit interpret with { mode: "strict" }
  }
}
