    link ::azl.security
    emit p138_comp_quad_bare_with_bare_with_emit_comp with { ast: "f138-root", scope: "f138-sc", nodes: "import|f138_mod_tag
link|::p138.linked
component|p138.a
memory|emit|f138_e1
memory|emit|f138_e2|with|fk138a|F138_PAY_A
memory|emit|f138_e3
memory|emit|f138_e4|with|fk138b|F138_PAY_B
component|p138.b
memory|say|F138_MEM" }
