# Gate F157: ::parse_tokens — `listen for f157 { emit E157 }` → `listen|f157|emit|E157`.
component ::azl.security {
  init {
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit f157_parse with { }
  }
  behavior {
    listen for "f157_parse" {
      set ::tokens = []
      set ::tx = "listen for f157 { emit E157 }"
      set ::nx = "1"
      set ::tokens = ::tokens.concat(::tokenize_line(::tx, ::nx))
      set ::tokens.push({ type: "eol", value: ";", line: 1, column: 0 })
      set ::_p = ::parse_tokens(::tokens)
      say ::ast.nodes
      say "P0_SEM_F157_OK"
    }
  }
}
