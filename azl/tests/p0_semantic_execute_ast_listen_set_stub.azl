# Gate F101: `::execute_ast` — `listen|ev|set|::global|value` stub assigns when event is dispatched (no token listener). `AZL_USE_VM` unset.
component ::azl.security {
  init {
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit p101_set_listen_tree with { ast: "f101-root", scope: "f101-sc", nodes: "listen|f101_go|set|::p0_f101_cell|F101_CELL
emit|f101_go
say|F101_SAYLINE" }
  }
  behavior {
    listen for "execute_complete" {
      say "EC101_INNER"
      say ::event.data.result
      say "P0_SEM_F101_OK"
    }
    listen for "p101_set_listen_tree" {
      set ::ast = ::event.data.ast
      set ::scope = ::event.data.scope
      set ::ast.nodes = ::event.data.nodes
      set ::use_vm = ((::internal.env("AZL_USE_VM") or "") == "1")
      if (::use_vm) {
        say "F101_VM_ON_BAD"
        return
      }
      say "F101_TREE"
      set ::result = ::execute_ast(::ast, ::scope)
      say ::p0_f101_cell
      say "EX101_POST"
      say ::result
      emit execute_complete with { result: ::result }
    }
  }
}
