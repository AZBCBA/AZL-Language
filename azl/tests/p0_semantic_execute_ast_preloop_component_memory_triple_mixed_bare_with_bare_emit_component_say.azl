# Gate F135: `::execute_ast` — preloop `import|` + `link|` then `component|`, then **bare** **`memory|emit|ev1`** + **`memory|emit|ev2|with|k|v`** + **bare** **`memory|emit|ev3`** (FIFO queue + drain), then `component|`, then `memory|say|…`. `AZL_USE_VM` unset.
component ::azl.security {
  init {
  }
}

component ::p135.linked {
  init {
    say "P135_LINK_SID"
  }
}

component ::p135.a {
  init {
    say "P135_A"
  }
}

component ::p135.b {
  init {
    say "P135_B"
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit p135_comp_triple_bare_with_bare_emit_comp with { ast: "f135-root", scope: "f135-sc", nodes: "import|f135_mod_tag
link|::p135.linked
component|p135.a
memory|emit|f135_e1
memory|emit|f135_e2|with|fk135|F135_PAY_MID
memory|emit|f135_e3
component|p135.b
memory|say|F135_MEM" }
  }
  behavior {
    listen for "execute_complete" {
      say "EC135_INNER"
      say ::event.data.result
      say "P0_SEM_F135_OK"
    }
    listen for "f135_e1" {
      say "F135_BARE_1"
    }
    listen for "f135_e2" {
      say ::event.data.fk135
    }
    listen for "f135_e3" {
      say "F135_BARE_3"
    }
    listen for "p135_comp_triple_bare_with_bare_emit_comp" {
      set ::ast = ::event.data.ast
      set ::scope = ::event.data.scope
      set ::ast.nodes = ::event.data.nodes
      set ::p0_exec_import_last = ""
      set ::use_vm = ((::internal.env("AZL_USE_VM") or "") == "1")
      if (::use_vm) {
        say "F135_VM_ON_BAD"
        return
      }
      say "F135_TREE"
      set ::result = ::execute_ast(::ast, ::scope)
      say ::p0_exec_import_last
      say "EX135_POST"
      say ::result
      emit execute_complete with { result: ::result }
    }
  }
}
