# Tier B P0.1 — semantic spine behavior-entry harness (test-only).
# Concatenated after azl_security_for_interpreter_spine.azl and before
# azl/runtime/interpreter/azl_interpreter.azl. Entry component: ::azl.spine.behavior.entry
# links the real interpreter, then:
#   - two emit interpret (same code) — second pass exercises in-file tok_cache + ast_cache hits;
#   - third emit interpret (two-line user code) — split("\n"), parse loop, two say executes;
#   - fourth emit interpret (three-line user code) — deeper parse loop + three say executes;
#   - fifth emit interpret (four-line user code) — deeper parse loop + four say executes;
#     markers Q5a–Q5d are intentionally short: semantic spine Var.v / ::ast.nodes budget is 255 bytes (see minimal_runtime ::parse_tokens).
#   - sixth emit interpret (single-line literal say) — another full interpret→tokenize→parse→execute after smoke5; stdout marker AZL_S6_ONLY.
#   - seventh emit interpret (same code as sixth) — second tok_cache + ast_cache round-trip on AZL_S6_ONLY source (mirrors smoke/smoke2).
#   - eighth emit interpret (single-line literal say, new code) — distinct marker AZL_S8_MARK; cache miss on tok/ast for this snippet.
#   - ninth emit interpret (set global then say) — exercises ::execute_ast set|… row on real interpret→parse→execute chain (not covered by say-only smokes).
#   - tenth emit interpret (bare emit user statement) — exercises ::execute_emit → ::emit_event_resolved on the real file path (📡 line + Emitted: in ::result).
#   - eleventh emit interpret (emit … with { k: v }) — exercises payload path in ::emit_event_resolved (AZL_EMIT_WITH_PAYLOAD) on the real file path.
#   - twelfth emit interpret (on name { say … } then name()) — exercises top-level ::parse_tokens + ::execute_ast function registration + ::execute_call on the real file path.
#   - fourteenth emit interpret (if ( true ) { say … }) — ::parse_if_statement / ::execute_if_statement; spine ::parse_tokens emits if| row; host execute_ast branches.
#   - fifteenth emit interpret (if ( false ) { … } otherwise { say … }) — single-statement alternate branch; skipped then-body.
#   - sixteenth emit interpret (if ( false ) { … } otherwise { two says }) — ordered multi-statement otherwise body (AZL_SPINE_P16_A then AZL_SPINE_P16_B); skipped then-body AZL_SPINE_P16_BAD.
#   - seventeenth emit interpret — set ::azl_spine_p17 = true then if ( ::azl_spine_p17 ) { … } otherwise { … }: condition is evaluated (not a literal in the if parens); then-branch only; AZL_SPINE_P17_BAD must not run.
#   - eighteenth emit interpret — set ::azl_spine_p18 = false then if ( ::azl_spine_p18 ) { … } otherwise { … }: evaluated falsey global; otherwise only; AZL_SPINE_P18_BAD must not run.
#   - nineteenth emit interpret — evaluated truthy global; multi-statement then-branch (two say lines, same shape as P16); AZL_SPINE_P19_A before AZL_SPINE_P19_B; AZL_SPINE_P19_BAD must not run.
#   - twentieth emit interpret — evaluated falsey global; multi-statement otherwise-branch (two say lines); AZL_SPINE_P20_A before AZL_SPINE_P20_B; AZL_SPINE_P20_BAD must not run.
#   - twenty-first emit interpret — `if ( ::azl_spine_p21 == 1 )` expression condition (not lone `::var`); AZL_SPINE_P21_IF; AZL_SPINE_P21_BAD must not run.
#   - twenty-second emit interpret — `if ( ::azl_spine_p22 == 2 )` false expression path; AZL_SPINE_P22_ELSE; AZL_SPINE_P22_BAD must not run.

component ::azl.spine.behavior.entry {
  init {
    say "AZL_SPINE_BEHAVIOR_ENTRY_PRE"
    link ::azl.interpreter
    say "AZL_SPINE_BEHAVIOR_ENTRY_LINKED"
    emit interpret with { code: "say x", component_name: "smoke" }
    emit interpret with { code: "say x", component_name: "smoke2" }
    emit interpret with { code: "say AZL_SPINE_DEPTH_A
say AZL_SPINE_DEPTH_B", component_name: "smoke3" }
    emit interpret with { code: "say AZL_SPINE_TRIPLE_1
say AZL_SPINE_TRIPLE_2
say AZL_SPINE_TRIPLE_3", component_name: "smoke4" }
    emit interpret with { code: "say Q5a
say Q5b
say Q5c
say Q5d", component_name: "smoke5" }
    emit interpret with { code: "say 'AZL_S6_ONLY'", component_name: "smoke6" }
    emit interpret with { code: "say 'AZL_S6_ONLY'", component_name: "smoke7" }
    emit interpret with { code: "say 'AZL_S8_MARK'", component_name: "smoke8" }
    emit interpret with { code: "set ::azl_spine_p9 = 1
say AZL_SPINE_P9_SET_LINE", component_name: "smoke9" }
    emit interpret with { code: "emit AZL_SPINE_P10_USER_EMIT", component_name: "smoke10" }
    emit interpret with { code: "emit AZL_SPINE_P11 with { pk: 'AZL_SPINE_P11_MARK' }", component_name: "smoke11" }
    emit interpret with { code: "on a { say 'AZL_S12_FN' }
a()", component_name: "smoke12" }
    emit interpret with { code: "let ::azl_spine_p13 = 'AZL_S13_MARK'", component_name: "smoke13" }
    emit interpret with { code: "if ( true ) { say 'AZL_SPINE_P14_IF' }", component_name: "smoke14" }
    emit interpret with { code: "if ( false ) { say 'AZL_SPINE_P15_BAD' } otherwise { say 'AZL_SPINE_P15_ELSE' }", component_name: "smoke15" }
    emit interpret with { code: "if ( false ) { say 'AZL_SPINE_P16_BAD' } otherwise { say 'AZL_SPINE_P16_A'
say 'AZL_SPINE_P16_B' }", component_name: "smoke16" }
    emit interpret with { code: "set ::azl_spine_p17 = true
if ( ::azl_spine_p17 ) { say 'AZL_SPINE_P17_IF' } otherwise { say 'AZL_SPINE_P17_BAD' }", component_name: "smoke17" }
    emit interpret with { code: "set ::azl_spine_p18 = false
if ( ::azl_spine_p18 ) { say 'AZL_SPINE_P18_BAD' } otherwise { say 'AZL_SPINE_P18_ELSE' }", component_name: "smoke18" }
    emit interpret with { code: "set ::azl_spine_p19 = true
if ( ::azl_spine_p19 ) { say 'AZL_SPINE_P19_A'
say 'AZL_SPINE_P19_B' } otherwise { say 'AZL_SPINE_P19_BAD' }", component_name: "smoke19" }
    emit interpret with { code: "set ::azl_spine_p20 = false
if ( ::azl_spine_p20 ) { say 'AZL_SPINE_P20_BAD' } otherwise { say 'AZL_SPINE_P20_A'
say 'AZL_SPINE_P20_B' }", component_name: "smoke20" }
    emit interpret with { code: "set ::azl_spine_p21 = 1
if ( ::azl_spine_p21 == 1 ) { say 'AZL_SPINE_P21_IF' } otherwise { say 'AZL_SPINE_P21_BAD' }", component_name: "smoke21" }
    emit interpret with { code: "set ::azl_spine_p22 = 1
if ( ::azl_spine_p22 == 2 ) { say 'AZL_SPINE_P22_BAD' } otherwise { say 'AZL_SPINE_P22_ELSE' }", component_name: "smoke22" }
    say "AZL_SPINE_BEHAVIOR_ENTRY_POST_EMIT"
  }
}
