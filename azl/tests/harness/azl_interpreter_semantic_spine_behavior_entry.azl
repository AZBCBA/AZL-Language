# Tier B P0.1 ‚Äî semantic spine behavior-entry harness (test-only).
# Concatenated after azl_security_for_interpreter_spine.azl and before
# azl/runtime/interpreter/azl_interpreter.azl. Entry component: ::azl.spine.behavior.entry
# links the real interpreter, then:
#   - two emit interpret (same code) ‚Äî second pass exercises in-file tok_cache + ast_cache hits;
#   - third emit interpret (two-line user code) ‚Äî split("\n"), parse loop, two say executes;
#   - fourth emit interpret (three-line user code) ‚Äî deeper parse loop + three say executes;
#   - fifth emit interpret (four-line user code) ‚Äî deeper parse loop + four say executes;
#     markers Q5a‚ÄìQ5d are intentionally short: semantic spine Var.v / ::ast.nodes budget is 255 bytes (see minimal_runtime ::parse_tokens).
#   - sixth emit interpret (single-line literal say) ‚Äî another full interpret‚Üítokenize‚Üíparse‚Üíexecute after smoke5; stdout marker AZL_S6_ONLY.
#   - seventh emit interpret (same code as sixth) ‚Äî second tok_cache + ast_cache round-trip on AZL_S6_ONLY source (mirrors smoke/smoke2).
#   - eighth emit interpret (single-line literal say, new code) ‚Äî distinct marker AZL_S8_MARK; cache miss on tok/ast for this snippet.
#   - ninth emit interpret (set global then say) ‚Äî exercises ::execute_ast set|‚Ä¶ row on real interpret‚Üíparse‚Üíexecute chain (not covered by say-only smokes).
#   - tenth emit interpret (bare emit user statement) ‚Äî exercises ::execute_emit ‚Üí ::emit_event_resolved on the real file path (üì° line + Emitted: in ::result).
#   - eleventh emit interpret (emit ‚Ä¶ with { k: v }) ‚Äî exercises payload path in ::emit_event_resolved (AZL_EMIT_WITH_PAYLOAD) on the real file path.
#   - twelfth emit interpret (on name { say ‚Ä¶ } then name()) ‚Äî exercises top-level ::parse_tokens + ::execute_ast function registration + ::execute_call on the real file path.

component ::azl.spine.behavior.entry {
  init {
    say "AZL_SPINE_BEHAVIOR_ENTRY_PRE"
    link ::azl.interpreter
    say "AZL_SPINE_BEHAVIOR_ENTRY_LINKED"
    emit interpret with { code: "say x", component_name: "smoke" }
    emit interpret with { code: "say x", component_name: "smoke2" }
    emit interpret with { code: "say AZL_SPINE_DEPTH_A
say AZL_SPINE_DEPTH_B", component_name: "smoke3" }
    emit interpret with { code: "say AZL_SPINE_TRIPLE_1
say AZL_SPINE_TRIPLE_2
say AZL_SPINE_TRIPLE_3", component_name: "smoke4" }
    emit interpret with { code: "say Q5a
say Q5b
say Q5c
say Q5d", component_name: "smoke5" }
    emit interpret with { code: "say 'AZL_S6_ONLY'", component_name: "smoke6" }
    emit interpret with { code: "say 'AZL_S6_ONLY'", component_name: "smoke7" }
    emit interpret with { code: "say 'AZL_S8_MARK'", component_name: "smoke8" }
    emit interpret with { code: "set ::azl_spine_p9 = 1
say AZL_SPINE_P9_SET_LINE", component_name: "smoke9" }
    emit interpret with { code: "emit AZL_SPINE_P10_USER_EMIT", component_name: "smoke10" }
    emit interpret with { code: "emit AZL_SPINE_P11 with { pk: 'AZL_SPINE_P11_MARK' }", component_name: "smoke11" }
    emit interpret with { code: "on a { say 'AZL_S12_FN' }
a()", component_name: "smoke12" }
    say "AZL_SPINE_BEHAVIOR_ENTRY_POST_EMIT"
  }
}
