# P0 semantic spine — set ::out = "pre" + ::mid + "post" (F67).

component ::azl.security {
  init {
  }
}

component ::p0.set.triple.stub {
  init {
  }
  behavior {
    listen for "e" {
      set ::mid = "MID"
      set ::out = "pre" + ::mid + "post"
      say ::out
      say "P0_SEMANTIC_SET_TRIPLE_CONCAT_OK"
    }
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    link ::p0.set.triple.stub
    emit e
  }
}
