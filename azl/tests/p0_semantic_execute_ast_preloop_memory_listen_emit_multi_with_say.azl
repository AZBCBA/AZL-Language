# Gate F118: `::execute_ast` — preloop `import|` + `link|` (F112) then F117-shaped `memory|listen|…|emit|…|with` multi-pair + `memory|emit|…` + `memory|say|…`. `AZL_USE_VM` unset.
component ::azl.security {
  init {
  }
}

component ::p118.linked {
  init {
    say "P118_LINK_SID"
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit p118_preloop_memory_listen_multi with { ast: "f118-root", scope: "f118-sc", nodes: "import|f118_mod_tag
link|::p118.linked
say|F118_TOP
memory|listen|f118_mem|emit|f118_nested|with|f118_k1|F118_ONE|f118_k2|F118_TWO
memory|emit|f118_mem
memory|say|F118_MEM" }
  }
  behavior {
    listen for "execute_complete" {
      say "EC118_INNER"
      say ::event.data.result
      say "P0_SEM_F118_OK"
    }
    listen for "f118_nested" {
      say ::event.data.f118_k1
      say ::event.data.f118_k2
    }
    listen for "p118_preloop_memory_listen_multi" {
      set ::ast = ::event.data.ast
      set ::scope = ::event.data.scope
      set ::ast.nodes = ::event.data.nodes
      set ::p0_exec_import_last = ""
      set ::use_vm = ((::internal.env("AZL_USE_VM") or "") == "1")
      if (::use_vm) {
        say "F118_VM_ON_BAD"
        return
      }
      say "F118_TREE"
      set ::result = ::execute_ast(::ast, ::scope)
      say ::p0_exec_import_last
      say "EX118_POST"
      say ::result
      emit execute_complete with { result: ::result }
    }
  }
}
