# Gate F189: `::execute_ast` тАФ top-level `call|fn|arg` prints fn say body then arg (matches listen stub F187). `AZL_USE_VM` unset.
component ::azl.security {
  init {
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit p189_exec_tree with { ast: "f189-root", scope: "f189-sc", nodes: "fn|f189_fn|say|F189_CB
call|f189_fn|F189_ARG
emit|f189_ev
say|F189_TAIL" }
  }
  behavior {
    listen for "execute_complete" {
      say "EC189_INNER"
      say ::event.data.result
      say "P0_SEM_F189_OK"
    }
    listen for "p189_exec_tree" {
      set ::ast = ::event.data.ast
      set ::scope = ::event.data.scope
      set ::ast.nodes = ::event.data.nodes
      set ::use_vm = ((::internal.env("AZL_USE_VM") or "") == "1")
      if (::use_vm) {
        say "F189_VM_ON_BAD"
        return
      }
      say "F189_TREE"
      set ::result = ::execute_ast(::ast, ::scope)
      say "EX189_POST"
      say ::result
      emit execute_complete with { result: ::result }
    }
  }
}
