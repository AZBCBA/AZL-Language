# Gate F132: `::execute_ast` — preloop `import|` + `link|` then `component|`, then **bare** **`memory|emit|ev1`** then **`memory|emit|ev2|with|k|v`** (mixed FIFO queue + drain), then `component|`, then `memory|say|…`. `AZL_USE_VM` unset.
component ::azl.security {
  init {
  }
}

component ::p132.linked {
  init {
    say "P132_LINK_SID"
  }
}

component ::p132.a {
  init {
    say "P132_A"
  }
}

component ::p132.b {
  init {
    say "P132_B"
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit p132_comp_mixed_bare_with_emit_comp with { ast: "f132-root", scope: "f132-sc", nodes: "import|f132_mod_tag
link|::p132.linked
component|p132.a
memory|emit|f132_e1
memory|emit|f132_e2|with|fk132|F132_PAYLOAD
component|p132.b
memory|say|F132_MEM" }
  }
  behavior {
    listen for "execute_complete" {
      say "EC132_INNER"
      say ::event.data.result
      say "P0_SEM_F132_OK"
    }
    listen for "f132_e1" {
      say "F132_BARE_1"
    }
    listen for "f132_e2" {
      say ::event.data.fk132
    }
    listen for "p132_comp_mixed_bare_with_emit_comp" {
      set ::ast = ::event.data.ast
      set ::scope = ::event.data.scope
      set ::ast.nodes = ::event.data.nodes
      set ::p0_exec_import_last = ""
      set ::use_vm = ((::internal.env("AZL_USE_VM") or "") == "1")
      if (::use_vm) {
        say "F132_VM_ON_BAD"
        return
      }
      say "F132_TREE"
      set ::result = ::execute_ast(::ast, ::scope)
      say ::p0_exec_import_last
      say "EX132_POST"
      say ::result
      emit execute_complete with { result: ::result }
    }
  }
}
