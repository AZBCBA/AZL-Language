# Gate F188: ::parse_tokens тАФ top-level `name ( 'тАж' )` тЖТ `call|name|payload` (not inside listen)
component ::azl.security {
  init {
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit f188_parse with { }
  }
  behavior {
    listen for "f188_parse" {
      set ::tokens = []
      set ::tx = "f188_fn ( 'F188_MARK' )"
      set ::nx = "1"
      set ::tokens = ::tokens.concat(::tokenize_line(::tx, ::nx))
      set ::tokens.push({ type: "eol", value: ";", line: 1, column: 0 })
      set ::_p = ::parse_tokens(::tokens)
      say ::ast.nodes
      say "P0_SEM_F188_OK"
    }
  }
}
