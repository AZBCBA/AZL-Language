# Gate F137: `::execute_ast` — preloop `import|` + `link|` then `component|`, then **`memory|emit|…|with|…`** + **bare** + **bare** + **`memory|emit|…|with|…`** (four rows, FIFO queue + drain), then `component|`, then `memory|say|…`. `AZL_USE_VM` unset.
component ::azl.security {
  init {
  }
}

component ::p137.linked {
  init {
    say "P137_LINK_SID"
  }
}

component ::p137.a {
  init {
    say "P137_A"
  }
}

component ::p137.b {
  init {
    say "P137_B"
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit p137_comp_quad_with_bare_bare_with_emit_comp with { ast: "f137-root", scope: "f137-sc", nodes: "import|f137_mod_tag
link|::p137.linked
component|p137.a
memory|emit|f137_e1|with|fk137a|F137_PAY_A
memory|emit|f137_e2
memory|emit|f137_e3
memory|emit|f137_e4|with|fk137b|F137_PAY_B
component|p137.b
memory|say|F137_MEM" }
  }
  behavior {
    listen for "execute_complete" {
      say "EC137_INNER"
      say ::event.data.result
      say "P0_SEM_F137_OK"
    }
    listen for "f137_e1" {
      say ::event.data.fk137a
    }
    listen for "f137_e2" {
      say "F137_BARE_2"
    }
    listen for "f137_e3" {
      say "F137_BARE_3"
    }
    listen for "f137_e4" {
      say ::event.data.fk137b
    }
    listen for "p137_comp_quad_with_bare_bare_with_emit_comp" {
      set ::ast = ::event.data.ast
      set ::scope = ::event.data.scope
      set ::ast.nodes = ::event.data.nodes
      set ::p0_exec_import_last = ""
      set ::use_vm = ((::internal.env("AZL_USE_VM") or "") == "1")
      if (::use_vm) {
        say "F137_VM_ON_BAD"
        return
      }
      say "F137_TREE"
      set ::result = ::execute_ast(::ast, ::scope)
      say ::p0_exec_import_last
      say "EX137_POST"
      say ::result
      emit execute_complete with { result: ::result }
    }
  }
