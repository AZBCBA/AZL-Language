# Gate F186: ::parse_tokens — listen { name ( 'F186_MARK' ) } → listen|…|call|…|F186_MARK
component ::azl.security {
  init {
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit f186_parse with { }
  }
  behavior {
    listen for "f186_parse" {
      set ::tokens = []
      set ::l1 = "listen for f186 {"
      set ::l2 = "f186_fn ( 'F186_MARK' )"
      set ::l3 = "}"
      set ::nx = "1"
      set ::tokens = ::tokens.concat(::tokenize_line(::l1, ::nx))
