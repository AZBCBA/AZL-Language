# P0 semantic spine — if ("a" != "b") with two string literals (F66).

component ::azl.security {
  init {
  }
}

component ::p0.if.lit.ne.stub {
  init {
  }
  behavior {
    listen for "e" {
      if ("a" != "b") {
        say "F66_LITERAL_NE_BRANCH"
      }
      say "P0_SEMANTIC_IF_LITERAL_NE_STRINGS_OK"
    }
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    link ::p0.if.lit.ne.stub
    emit e
  }
}
