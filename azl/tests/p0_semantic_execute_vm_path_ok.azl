# Gate F90: `AZL_USE_VM=1` — `::vm_compile_ast(::ast)` sets `::vc.*`, non-empty bytecode, `::vm_run_bytecode_program(::vc.bytecode)`, `emit execute_complete` (mirrors `azl_interpreter.azl` ~141–156). Gate runner MUST set `AZL_USE_VM=1`. Magic ast `F90_VM_OK` selects success shape in minimal builtins.
component ::azl.security {
  init {
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit p90_vm_exec with { ast: "F90_VM_OK", scope: "sc90" }
  }
  behavior {
    listen for "execute_complete" {
      say "EC90_INNER"
      say ::event.data.result
      say "P0_SEM_F90_VM_OK"
    }
    listen for "p90_vm_exec" {
      set ::ast = ::event.data.ast
      set ::scope = ::event.data.scope
      set ::use_vm = ((::internal.env("AZL_USE_VM") or "") == "1")
      if (::use_vm) {
        say "VM_BRANCH"
        set ::_vmc = ::vm_compile_ast(::ast)
        if (::vc.ok != true) {
          say "VC_OK_BAD"
          return
        }
        if (::vc.bytecode.length == "0") {
          say "VC_EMPTY_BAD"
          return
        }
        set ::result = ::vm_run_bytecode_program(::vc.bytecode)
        say "VM_LINE"
        emit execute_complete with { result: ::result }
      } else {
        say "USE_VM_OFF_BAD"
      }
    }
  }
}
