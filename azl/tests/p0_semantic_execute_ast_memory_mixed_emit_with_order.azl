# Gate F110: `::execute_ast` — `memory|set|…` then `memory|emit|…|with|k|v` then `memory|say|…` in one walk (F109 + F106-shaped emit). `AZL_USE_VM` unset.
component ::azl.security {
  init {
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit p110_memory_mixed_emit_with with { ast: "f110-root", scope: "f110-sc", nodes: "memory|set|::f110_slot|F110_CELL
memory|emit|f110_inner|with|f110_pk|F110_PAYLOAD
memory|say|F110_AFTER" }
  }
  behavior {
    listen for "execute_complete" {
      say "EC110_INNER"
      say ::event.data.result
      say "P0_SEM_F110_OK"
    }
    listen for "f110_inner" {
      say ::event.data.f110_pk
    }
    listen for "p110_memory_mixed_emit_with" {
      set ::ast = ::event.data.ast
      set ::scope = ::event.data.scope
      set ::ast.nodes = ::event.data.nodes
      set ::use_vm = ((::internal.env("AZL_USE_VM") or "") == "1")
      if (::use_vm) {
        say "F110_VM_ON_BAD"
        return
      }
      say "F110_TREE"
      set ::result = ::execute_ast(::ast, ::scope)
      say ::f110_slot
      say "EX110_POST"
      say ::result
      emit execute_complete with { result: ::result }
    }
  }
}
