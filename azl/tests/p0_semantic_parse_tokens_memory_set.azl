# Gate F161: ::parse_tokens — `memory set ::f161_slot = F161_CELL` → `memory|set|::f161_slot|F161_CELL` (execute_ast memory row shape).
component ::azl.security {
  init {
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit f161_parse with { }
  }
  behavior {
    listen for "f161_parse" {
      set ::tokens = []
      set ::tx = "memory set ::f161_slot = F161_CELL"
      set ::nx = "1"
      set ::tokens = ::tokens.concat(::tokenize_line(::tx, ::nx))
      set ::tokens.push({ type: "eol", value: ";", line: 1, column: 0 })
      set ::_p = ::parse_tokens(::tokens)
      say ::ast.nodes
      say "P0_SEM_F161_OK"
    }
  }
}
