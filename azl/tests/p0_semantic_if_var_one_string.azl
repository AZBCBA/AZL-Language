# P0 semantic spine — if (::t) when ::t holds string "1" (F55).

component ::azl.security {
  init {
  }
}

component ::p0.if.var.one.stub {
  init {
  }
  behavior {
    listen for "e" {
      set ::t = "1"
      if (::t) {
        say "F55_ONE_STRING_VAR"
      }
      say "P0_SEMANTIC_IF_VAR_ONE_STRING_OK"
    }
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    link ::p0.if.var.one.stub
    emit e
  }
}
