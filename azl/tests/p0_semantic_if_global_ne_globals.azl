# P0 semantic spine — if (::a != ::b) when globals differ (F62).

component ::azl.security {
  init {
  }
}

component ::p0.if.ne.stub {
  init {
  }
  behavior {
    listen for "e" {
      set ::a = "x"
      set ::b = "y"
      if (::a != ::b) {
        say "F62_NEQ_BRANCH"
      }
      say "P0_SEMANTIC_IF_GLOBAL_NE_OK"
    }
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    link ::p0.if.ne.stub
    emit e
  }
}
