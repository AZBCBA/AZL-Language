# P0 semantic spine — if (::t) when ::t holds string "true" (F52).

component ::azl.security {
  init {
  }
}

component ::p0.if.var.true.stub {
  init {
  }
  behavior {
    listen for "e" {
      set ::t = "true"
      if (::t) {
        say "F52_TRUE_STRING_VAR"
      }
      say "P0_SEMANTIC_IF_VAR_TRUE_STRING_OK"
    }
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    link ::p0.if.var.true.stub
    emit e
  }
}
