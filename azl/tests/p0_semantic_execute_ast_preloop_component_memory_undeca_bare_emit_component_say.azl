# Gate F148: `::execute_ast` — preloop `import|` + `link|` then `component|`, then **eleven** bare **`memory|emit|ev`** rows (no `|with|`, FIFO queue + drain), then `component|`, then `memory|say|…`. `AZL_USE_VM` unset. **`import|i`** + **`e1`…`e11`** keep **`::ast.nodes`** within minimal **255-byte** bound.
component ::azl.security {
  init {
  }
}

component ::p148.linked {
  init {
    say "P148_LINK_SID"
  }
}

component ::p148.a {
  init {
    say "P148_A"
  }
}

component ::p148.b {
  init {
    say "P148_B"
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit p148_comp_undeca_bare_emit_comp with { ast: "f148-root", scope: "f148-sc", nodes: "import|i
link|::p148.linked
component|p148.a
memory|emit|e1
memory|emit|e2
memory|emit|e3
memory|emit|e4
memory|emit|e5
memory|emit|e6
memory|emit|e7
memory|emit|e8
memory|emit|e9
memory|emit|e10
memory|emit|e11
component|p148.b
memory|say|F148_MEM" }
  }
  behavior {
    listen for "execute_complete" {
      say "EC148_INNER"
      say ::event.data.result
      say "P0_SEM_F148_OK"
    }
    listen for "e1" {
      say "F148_BARE_1"
    }
    listen for "e2" {
      say "F148_BARE_2"
    }
    listen for "e3" {
      say "F148_BARE_3"
    }
    listen for "e4" {
      say "F148_BARE_4"
    }
    listen for "e5" {
      say "F148_BARE_5"
    }
    listen for "e6" {
      say "F148_BARE_6"
    }
    listen for "e7" {
      say "F148_BARE_7"
    }
    listen for "e8" {
      say "F148_BARE_8"
    }
    listen for "e9" {
      say "F148_BARE_9"
    }
    listen for "e10" {
      say "F148_BARE_10"
    }
    listen for "e11" {
      say "F148_BARE_11"
    }
    listen for "p148_comp_undeca_bare_emit_comp" {
      set ::ast = ::event.data.ast
      set ::scope = ::event.data.scope
      set ::ast.nodes = ::event.data.nodes
      set ::p0_exec_import_last = ""
      set ::use_vm = ((::internal.env("AZL_USE_VM") or "") == "1")
      if (::use_vm) {
        say "F148_VM_ON_BAD"
        return
      }
      say "F148_TREE"
      set ::result = ::execute_ast(::ast, ::scope)
      say ::p0_exec_import_last
      say "EX148_POST"
      say ::result
      emit execute_complete with { result: ::result }
    }
  }
}
