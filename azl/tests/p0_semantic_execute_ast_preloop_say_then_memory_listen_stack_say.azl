# Gate F121: `::execute_ast` — preloop `import|` + `link|` (F112) then top-level `say|` (F113-shaped) before stacked `memory|listen|…|say|…` + dual `memory|emit|…` + `memory|say|…` (F119). `AZL_USE_VM` unset.
component ::azl.security {
  init {
  }
}

component ::p121.linked {
  init {
    say "P121_LINK_SID"
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit p121_preloop_say_listen_stack with { ast: "f121-root", scope: "f121-sc", nodes: "import|f121_mod_tag
link|::p121.linked
say|F121_PRE_SLICE
memory|listen|f121_e1|say|F121_STUB_ONE
memory|listen|f121_e2|say|F121_STUB_TWO
memory|emit|f121_e1
memory|emit|f121_e2
memory|say|F121_MEM" }
  }
  behavior {
    listen for "execute_complete" {
      say "EC121_INNER"
      say ::event.data.result
      say "P0_SEM_F121_OK"
    }
    listen for "p121_preloop_say_listen_stack" {
      set ::ast = ::event.data.ast
      set ::scope = ::event.data.scope
      set ::ast.nodes = ::event.data.nodes
      set ::p0_exec_import_last = ""
      set ::use_vm = ((::internal.env("AZL_USE_VM") or "") == "1")
      if (::use_vm) {
        say "F121_VM_ON_BAD"
        return
      }
      say "F121_TREE"
      set ::result = ::execute_ast(::ast, ::scope)
      say ::p0_exec_import_last
      say "EX121_POST"
      say ::result
      emit execute_complete with { result: ::result }
    }
  }
}
