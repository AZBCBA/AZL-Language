# Gate F153: ::parse_tokens ‚Äî `emit w with { a: b, c: d }` ‚Üí `emit|w|with|a|b|c|d` (multi-pair; Var.v[255]-safe).
component ::azl.security {
  init {
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit f153_parse with { }
  }
  behavior {
    listen for "f153_parse" {
      set ::tokens = []
      set ::tx = "emit w with { a: b, c: d }"
      set ::nx = "1"
      set ::tokens = ::tokens.concat(::tokenize_line(::tx, ::nx))
      set ::tokens.push({ type: "eol", value: ";", line: 1, column: 0 })
      set ::_p = ::parse_tokens(::tokens)
      say ::ast.nodes
      say "P0_SEM_F153_OK"
    }
  }
}
