# P0 semantic spine — if (true) { … } inside listener (F39).

component ::azl.security {
  init {
  }
}

component ::p0.if.true.stub {
  init {
  }
  behavior {
    listen for "e" {
      if (true) {
        say "F39_TRUE_BRANCH"
      }
      say "P0_SEMANTIC_IF_TRUE_LITERAL_OK"
    }
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    link ::p0.if.true.stub
    emit e
  }
}
