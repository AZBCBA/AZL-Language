# Gate F95: `::execute_ast` — `set|::global|value` assigns a global (mirrors `execute_set` result string; no interpreter `say` side-effect). Then `say|…` + outer `say ::f95_slot` proves assignment. `AZL_USE_VM` unset.
component ::azl.security {
  init {
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit p95_set_tree with { ast: "f95-root", scope: "f95-sc", nodes: "set|::f95_slot|F95_CELL
say|F95_SAYLINE" }
  }
  behavior {
    listen for "execute_complete" {
      say "EC95_INNER"
      say ::event.data.result
      say "P0_SEM_F95_OK"
    }
    listen for "p95_set_tree" {
      set ::ast = ::event.data.ast
      set ::scope = ::event.data.scope
      set ::ast.nodes = ::event.data.nodes
      set ::use_vm = ((::internal.env("AZL_USE_VM") or "") == "1")
      if (::use_vm) {
        say "F95_VM_ON_BAD"
        return
      }
      say "F95_TREE"
      set ::result = ::execute_ast(::ast, ::scope)
      say ::f95_slot
      say "EX95_POST"
      say ::result
      emit execute_complete with { result: ::result }
    }
  }
}
