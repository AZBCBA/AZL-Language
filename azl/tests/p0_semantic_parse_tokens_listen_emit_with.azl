# Gate F158: ::parse_tokens — listen + emit … with { k: a } → listen|f158|emit|em158|with|k|a
component ::azl.security {
  init {
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit f158_parse with { }
  }
  behavior {
    listen for "f158_parse" {
      set ::tokens = []
      set ::tx = "listen for f158 { emit em158 with { k: a } }"
      set ::nx = "1"
      set ::tokens = ::tokens.concat(::tokenize_line(::tx, ::nx))
      set ::tokens.push({ type: "eol", value: ";", line: 1, column: 0 })
      set ::_p = ::parse_tokens(::tokens)
      say ::ast.nodes
      say "P0_SEM_F158_OK"
    }
  }
}
