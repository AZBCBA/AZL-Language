# Gate F92: `AZL_USE_VM=1` — `::vc.ok` true but `::vc.bytecode.length == "0"` → `vm_compile_error:vm_compile_empty` (~149–152). Runner MUST set `AZL_USE_VM=1`. Magic ast `F92_VM_EMPTY`.
component ::azl.security {
  init {
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit p92_vm_eb with { ast: "F92_VM_EMPTY" }
  }
  behavior {
    listen for "execute_complete" {
      say "EC92_INNER"
      say ::event.data.result
      say "P0_SEM_F92_VM_OK"
    }
    listen for "p92_vm_eb" {
      set ::ast = ::event.data.ast
      set ::use_vm = ((::internal.env("AZL_USE_VM") or "") == "1")
      if (::use_vm) {
        set ::_vmc = ::vm_compile_ast(::ast)
        if (::vc.ok != true) {
          say "F92_OK_BAD"
          return
        }
        if (::vc.bytecode.length == "0") {
          set ::out = "vm_compile_error:vm_compile_empty"
          say "F92_EMPTY_BRANCH"
          emit execute_complete with { result: ::out }
        } else {
          say "F92_SHOULD_EMPTY_BAD"
        }
      } else {
        say "USE_VM_OFF_BAD"
      }
    }
  }
}
