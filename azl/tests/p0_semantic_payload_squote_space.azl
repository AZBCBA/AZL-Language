# P0 semantic spine — single-quoted payload value with space (F42).

component ::azl.security {
  init {
  }
}

component ::p0.payload.squote.space.stub {
  init {
  }
  behavior {
    listen for "e" {
      say ::event.data.t
      say "P0_SEMANTIC_PAYLOAD_SQUOTE_SPACE_OK"
    }
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    link ::p0.payload.squote.space.stub
    emit e with { t: 'a b' }
  }
}
