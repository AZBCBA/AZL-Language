# Gate F112: `::execute_ast` — preloop `import|` + `link|` (F98) then main-loop `memory|say|…`; link side-effect and `::p0_exec_import_last` before memory stdout. `AZL_USE_VM` unset.
component ::azl.security {
  init {
  }
}

component ::p112.linked {
  init {
    say "P112_LINK_SID"
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit p112_preloop_memory with { ast: "f112-root", scope: "f112-sc", nodes: "import|f112_mod_tag
link|::p112.linked
memory|say|F112_MEM" }
  }
  behavior {
    listen for "execute_complete" {
      say "EC112_INNER"
      say ::event.data.result
      say "P0_SEM_F112_OK"
    }
    listen for "p112_preloop_memory" {
      set ::ast = ::event.data.ast
      set ::scope = ::event.data.scope
      set ::ast.nodes = ::event.data.nodes
      set ::p0_exec_import_last = ""
      set ::use_vm = ((::internal.env("AZL_USE_VM") or "") == "1")
      if (::use_vm) {
        say "F112_VM_ON_BAD"
        return
      }
      say "F112_TREE"
      set ::result = ::execute_ast(::ast, ::scope)
      say ::p0_exec_import_last
      say "EX112_POST"
      say ::result
      emit execute_complete with { result: ::result }
    }
  }
}
