# Gate F107: `::execute_ast` — `memory|emit|event|with|k1|v1|k2|v2` (F97-shaped multi-pair tail under `memory|`). `AZL_USE_VM` unset.
component ::azl.security {
  init {
  }
}

component ::boot.entry {
  init {
    link ::azl.security
    emit p107_memory_emit_multi_tree with { ast: "f107-root", scope: "f107-sc", nodes: "say|F107_A
memory|emit|f107_inner|with|f107_k1|F107_ONE|f107_k2|F107_TWO" }
  }
  behavior {
    listen for "execute_complete" {
      say "EC107_INNER"
      say ::event.data.result
      say "P0_SEM_F107_OK"
    }
    listen for "f107_inner" {
      say ::event.data.f107_k1
      say ::event.data.f107_k2
    }
    listen for "p107_memory_emit_multi_tree" {
      set ::ast = ::event.data.ast
      set ::scope = ::event.data.scope
      set ::ast.nodes = ::event.data.nodes
      set ::use_vm = ((::internal.env("AZL_USE_VM") or "") == "1")
      if (::use_vm) {
        say "F107_VM_ON_BAD"
        return
      }
      say "F107_TREE"
      set ::result = ::execute_ast(::ast, ::scope)
      say "EX107_POST"
      say ::result
      emit execute_complete with { result: ::result }
    }
  }
}
