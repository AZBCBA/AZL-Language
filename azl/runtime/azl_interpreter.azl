# AZL PURE INTERPRETER - REPLACES PYTHON RUNNER
# This is the core that makes AZL truly independent
# NO PYTHON! NO EXTERNAL DEPENDENCIES! PURE AZL!

component ::azl.interpreter {
  init {
    set ::version = "2.0.0-PURE-MODERN"
    set ::components = {}
    set ::variables = {}
    set ::functions = {}
    set ::event_queue = []
    set ::processed_events = []
    set ::running = false
    set ::scopes = [{}]  # Stack of variable scopes
    set ::current_scope = 0
    
    say "🔥🔥🔥 AZL PURE INTERPRETER STARTING 🔥🔥🔥"
    say "🚀 REPLACING PYTHON RUNNER!"
    say "⚡ PURE AZL EXECUTION!"
    say "🎯 COMPLETE LANGUAGE INDEPENDENCE!"
    say "✨ MODERN SYNTAX SUPPORT: let, if, for, fn!"
    
    # Initialize core systems
    init_parser()
    init_executor()
    init_event_system()
    
    say "✅ PURE AZL INTERPRETER READY!"
    emit interpreter.ready with "pure_azl_interpreter_online"
  }

  behavior {
    # Main entry point - replaces python3 azl_runner.py
    listen for "interpret_file" then {
      set file_path = ::event.data.file_path
      say "📖 Parsing AZL file: $file_path"
      
      set result = parse_and_execute_file(file_path)
      emit file.interpreted with { file: file_path, result: result }
    }

    # Execute a component directly
    listen for "execute_component" then {
      set component_name = ::event.data.name
      set result = execute_component(component_name)
      emit component.executed with { name: component_name, result: result }
    }

    # Start the interpreter loop
    listen for "start_interpreter" then {
      say "🚀 Starting AZL interpreter loop..."
      ::start_interpreter_loop()
    }

    # Stop the interpreter
    listen for "stop_interpreter" then {
      say "🛑 Stopping AZL interpreter..."
      ::stop_interpreter()
    }
  }

  # CORE PARSING SYSTEM
  
  fn parse_and_execute_file(file_path) {
    try {
      # Read file content
      set content = read_file_content(file_path)
      if !content {
        say "❌ Failed to read file: $file_path"
        return { success: false, error: "file_read_failed" }
      }
      
      # Parse into components
      set parsed_components = parse_azl_content(content)
      if !parsed_components {
        say "❌ Failed to parse file: $file_path"
        return { success: false, error: "parse_failed" }
      }
      
      # Execute all components
      set execution_results = []
      for component_name in parsed_components.keys {
        say "🏗️  Found component: $component_name"
        set result = execute_component(component_name)
        execution_results.push({ name: component_name, result: result })
      }
      
      say "✅ File execution complete: $file_path"
      return { 
        success: true, 
        components: execution_results,
        total_events: len(::processed_events)
      }
      
    } catch error {
      say "❌ Error executing file: $error"
      return { success: false, error: error }
    }
  }

  fn parse_azl_content(content) {
    set lines = content.split("\n")
    set components = {}
    set current_component = null
    set current_section = ""
    set section_lines = []
    
    for line in lines {
      set trimmed = line.trim()
      
      # Skip empty lines and comments
      if trimmed == "" || trimmed.startsWith("#") {
        continue
      }
      
      # Component declaration
      if trimmed.startsWith("component") {
        # Save previous component if exists
        if current_component {
          components[current_component.name] = current_component
        }
        
        # Start new component
        set component_name = trimmed.split(" ")[1]
        current_component = {
          name: component_name,
          init: [],
          behavior: [],
          functions: {},
          links: {}
        }
        current_section = ""
        section_lines = []
        continue
      }
      
      # Section markers
      if trimmed == "init {" {
        current_section = "init"
        section_lines = []
        continue
      }
      
      if trimmed == "behavior {" {
        current_section = "behavior"
        section_lines = []
        continue
      }
      
      if trimmed == "}" {
        # End of section, save lines
        if current_section == "init" {
          current_component.init = section_lines
        } else if current_section == "behavior" {
          current_component.behavior = section_lines
        }
        current_section = ""
        section_lines = []
        continue
      }
      
      # Add line to current section
      if current_section != "" {
        section_lines.push(trimmed)
      }
    }
    
    # Save last component
    if current_component {
      components[current_component.name] = current_component
    }
    
    return components
  }

  # CORE EXECUTION SYSTEM
  
  fn execute_component(component_name) {
    set component = ::components[component_name]
    if !component {
      say "❌ Component not found: $component_name"
      return { success: false, error: "component_not_found" }
    }
    
    say "🎯 Running component: $component_name"
    
    # Create new scope for this component
    push_scope()
    
    # Execute init block
    if component.init.length > 0 {
      say "🚀 Initializing $component_name"
      set init_result = execute_block(component.init, component_name)
      if !init_result.success {
        pop_scope()
        return { success: false, error: "init_failed", details: init_result.error }
      }
    }
    
    # Setup behavior handlers
    if component.behavior.length > 0 {
      say "🎭 Setting up behavior for $component_name"
      set behavior_result = setup_behavior_handlers(component.behavior, component_name)
      if !behavior_result.success {
        pop_scope()
        return { success: false, error: "behavior_setup_failed", details: behavior_result.error }
      }
    }
    
    pop_scope()
    say "✅ Component $component_name executed successfully"
    return { success: true, component: component_name }
  }

  fn execute_block(statements, context) {
    for statement in statements {
      set result = execute_statement(statement, context)
      if !result.success {
        return result
      }
    }
    return { success: true }
  }

  fn execute_statement(statement, context) {
    set trimmed = statement.trim()
    
    try {
      # MODERN SYNTAX SUPPORT
      
      # let declarations
      if trimmed.startsWith("let ") {
        return execute_let_statement(trimmed, context)
      }
      
      # if statements
      if trimmed.startsWith("if ") {
        return execute_if_statement(trimmed, context)
      }
      
      # for loops
      if trimmed.startsWith("for ") {
        return execute_for_statement(trimmed, context)
      }
      
      # while loops
      if trimmed.startsWith("while ") {
        return execute_while_statement(trimmed, context)
      }
      
      # function definitions
      if trimmed.startsWith("fn ") {
        return execute_fn_statement(trimmed, context)
      }
      
      # return statements
      if trimmed.startsWith("return ") {
        return execute_return_statement(trimmed, context)
      }
      
      # break and continue
      if trimmed == "break" {
        return { success: true, control: "break" }
      }
      
      if trimmed == "continue" {
        return { success: true, control: "continue" }
      }
      
      # LEGACY SYNTAX SUPPORT
      
      if trimmed.startsWith("say ") {
        set message = trimmed.substring(4).trim()
        say "💬 $message"
        return { success: true }
      }
      
      if trimmed.startsWith("set ") {
        return execute_set_statement(trimmed, context)
      }
      
      if trimmed.startsWith("emit ") {
        return execute_emit_statement(trimmed, context)
      }
      
      if trimmed.startsWith("link ") {
        return execute_link_statement(trimmed, context)
      }
      
      # Default: assume it's an expression
      set result = evaluate_expression(trimmed, context)
      return { success: true, result: result }
      
    } catch error {
      say "❌ Error executing statement: $error"
      return { success: false, error: error }
    }
  }

  # MODERN SYNTAX IMPLEMENTATIONS
  
  fn execute_let_statement(statement, context) {
    # Parse: let variable_name = value
    set parts = statement.split("=", 2)
    if parts.length != 2 {
      return { success: false, error: "invalid_let_syntax" }
    }
    
    set var_part = parts[0].trim()
    set value_part = parts[1].trim()
    
    # Extract variable name
    if var_part.startsWith("let ") {
      set var_name = var_part.substring(4).trim()
    } else {
      set var_name = var_part
    }
    
    # Evaluate the value
    set value = evaluate_expression(value_part, context)
    
    # Store in current scope
    set_variable(var_name, value)
    say "💾 Let $var_name = $value"
    
    return { success: true, variable: var_name, value: value }
  }

  fn execute_if_statement(statement, context) {
    # Parse: if condition { statements }
    # This is a simplified parser - real implementation would be more sophisticated
    
    set condition_start = statement.indexOf("if ") + 3
    set brace_start = statement.indexOf("{")
    set brace_end = statement.lastIndexOf("}")
    
    if brace_start == -1 || brace_end == -1 {
      return { success: false, error: "invalid_if_syntax_missing_braces" }
    }
    
    set condition = statement.substring(condition_start, brace_start).trim()
    set body = statement.substring(brace_start + 1, brace_end).trim()
    
    # Evaluate condition
    set condition_result = evaluate_expression(condition, context)
    
    if condition_result {
      # Execute body
      set body_statements = body.split(";")
      for stmt in body_statements {
        if stmt.trim() != "" {
          set result = execute_statement(stmt.trim(), context)
          if !result.success {
            return result
          }
        }
      }
    }
    
    return { success: true }
  }

  fn execute_for_statement(statement, context) {
    # Parse: for let i = 0; i < 10; i++ { statements }
    # This is a simplified parser
    
    set brace_start = statement.indexOf("{")
    set brace_end = statement.lastIndexOf("}")
    
    if brace_start == -1 || brace_end == -1 {
      return { success: false, error: "invalid_for_syntax_missing_braces" }
    }
    
    set header = statement.substring(4, brace_start).trim()
    set body = statement.substring(brace_start + 1, brace_end).trim()
    
    # Parse header parts (init; condition; update)
    set parts = header.split(";")
    if parts.length != 3 {
      return { success: false, error: "invalid_for_syntax_header" }
    }
    
    set init_part = parts[0].trim()
    set condition_part = parts[1].trim()
    set update_part = parts[2].trim()
    
    # Execute initialization
    if init_part != "" {
      set result = execute_statement(init_part, context)
      if !result.success {
        return result
      }
    }
    
    # Execute loop
    while true {
      # Check condition
      set condition_result = evaluate_expression(condition_part, context)
      if !condition_result {
        break
      }
      
      # Execute body
      set body_statements = body.split(";")
      for stmt in body_statements {
        if stmt.trim() != "" {
          set result = execute_statement(stmt.trim(), context)
          if !result.success {
            return result
          }
          if result.control == "break" {
            return { success: true }
          }
        }
      }
      
      # Execute update
      if update_part != "" {
        set result = execute_statement(update_part, context)
        if !result.success {
          return result
        }
      }
    }
    
    return { success: true }
  }

  fn execute_while_statement(statement, context) {
    # Parse: while condition { statements }
    set condition_start = statement.indexOf("while ") + 6
    set brace_start = statement.indexOf("{")
    set brace_end = statement.lastIndexOf("}")
    
    if brace_start == -1 || brace_end == -1 {
      return { success: false, error: "invalid_while_syntax_missing_braces" }
    }
    
    set condition = statement.substring(condition_start, brace_start).trim()
    set body = statement.substring(brace_start + 1, brace_end).trim()
    
    # Execute loop
    while true {
      set condition_result = evaluate_expression(condition, context)
      if !condition_result {
        break
      }
      
      set body_statements = body.split(";")
      for stmt in body_statements {
        if stmt.trim() != "" {
          set result = execute_statement(stmt.trim(), context)
          if !result.success {
            return result
          }
          if result.control == "break" {
            return { success: true }
          }
        }
      }
    }
    
    return { success: true }
  }

  fn execute_fn_statement(statement, context) {
    # Parse: fn function_name(params) { body }
    # This is a simplified parser
    
    set paren_start = statement.indexOf("(")
    set paren_end = statement.indexOf(")")
    set brace_start = statement.indexOf("{")
    set brace_end = statement.lastIndexOf("}")
    
    if paren_start == -1 || paren_end == -1 || brace_start == -1 || brace_end == -1 {
      return { success: false, error: "invalid_fn_syntax" }
    }
    
    set fn_part = statement.substring(3, paren_start).trim()
    set params_part = statement.substring(paren_start + 1, paren_end).trim()
    set body = statement.substring(brace_start + 1, brace_end).trim()
    
    # Parse parameters
    set params = []
    if params_part != "" {
      set param_list = params_part.split(",")
      for param in param_list {
        params.push(param.trim())
      }
    }
    
    # Store function
    set function_name = fn_part
    ::functions[function_name] = {
      params: params,
      body: body,
      context: context
    }
    
    say "🔧 Function defined: $function_name($params)"
    return { success: true, function: function_name }
  }

  fn execute_return_statement(statement, context) {
    # Parse: return value
    set value_part = statement.substring(7).trim()
    set value = evaluate_expression(value_part, context)
    
    return { success: true, control: "return", value: value }
  }

  # LEGACY SYNTAX IMPLEMENTATIONS
  
  fn execute_set_statement(statement, context) {
    # Parse: set ::var = value
    set parts = statement.split("=", 2)
    if parts.length != 2 {
      return { success: false, error: "invalid_set_syntax" }
    }
    
    set var_part = parts[0].trim()
    set value_part = parts[1].trim()
    
    # Extract variable name
    if var_part.startsWith("set ") {
      set var_name = var_part.substring(4).trim()
    } else {
      set var_name = var_part
    }
    
    # Evaluate the value
    set value = evaluate_expression(value_part, context)
    
    # Store in variables
    set_variable(var_name, value)
    say "💾 Set $var_name = $value"
    
    return { success: true, variable: var_name, value: value }
  }

  fn execute_emit_statement(statement, context) {
    # Parse: emit "event_name" [to component] [with data]
    set parts = statement.split(" ", 2)
    if parts.length < 2 {
      return { success: false, error: "invalid_emit_syntax" }
    }
    
    set event_name = parts[1].trim()
    
    # Remove quotes if present
    if event_name.startsWith("\"") && event_name.endsWith("\"") {
      event_name = event_name.substring(1, event_name.length - 1)
    }
    
    # Add to event queue
    ::event_queue.push({
      event: event_name,
      source: context,
      data: {},
      timestamp: current_timestamp()
    })
    
    say "📡 Emitting: $event_name"
    return { success: true, event: event_name }
  }

  fn execute_link_statement(statement, context) {
    # Parse: link ::component
    set parts = statement.split(" ", 2)
    if parts.length != 2 {
      return { success: false, error: "invalid_link_syntax" }
    }
    
    set target_component = parts[1].trim()
    
    # Store link
    if !::components[context].links {
      ::components[context].links = target_component
    }
    ::components[context].links[target_component] = true
    
    say "🔗 Linking to: $target_component"
    return { success: true, target: target_component }
  }

  # ENHANCED EXPRESSION EVALUATION
  
  fn evaluate_expression(expr, context) {
    set trimmed = expr.trim()
    
    # String literals
    if trimmed.startsWith("\"") && trimmed.endsWith("\"") {
      return trimmed.substring(1, trimmed.length - 1)
    }
    
    # Boolean literals
    if trimmed == "true" { return true }
    if trimmed == "false" { return false }
    
    # Numbers
    if is_number(trimmed) {
      return parseFloat(trimmed)
    }
    
    # Variable references
    if trimmed.startsWith("::") {
      set var_name = trimmed.substring(2)
      return get_variable(var_name)
    }
    
    # Local variable references
    if !trimmed.contains(" ") && !trimmed.contains("(") && !trimmed.contains("+") && !trimmed.contains("-") && !trimmed.contains("*") && !trimmed.contains("/") {
      return get_variable(trimmed)
    }
    
    # Binary expressions
    if trimmed.contains("+") || trimmed.contains("-") || trimmed.contains("*") || trimmed.contains("/") || trimmed.contains("==") || trimmed.contains("!=") || trimmed.contains(">") || trimmed.contains("<") || trimmed.contains(">=") || trimmed.contains("<=") {
      return evaluate_binary_expression(trimmed, context)
    }
    
    # Function calls
    if trimmed.contains("(") && trimmed.contains(")") {
      return evaluate_function_call(trimmed, context)
    }
    
    # Default: return as string
    return trimmed
  }

  fn evaluate_binary_expression(expr, context) {
    # Simple binary expression evaluator
    # This is a simplified version - real implementation would be more sophisticated
    
    if expr.contains("+") {
      set parts = expr.split("+", 2)
      set left = evaluate_expression(parts[0].trim(), context)
      set right = evaluate_expression(parts[1].trim(), context)
      return left + right
    }
    
    if expr.contains("-") {
      set parts = expr.split("-", 2)
      set left = evaluate_expression(parts[0].trim(), context)
      set right = evaluate_expression(parts[1].trim(), context)
      return left - right
    }
    
    if expr.contains("*") {
      set parts = expr.split("*", 2)
      set left = evaluate_expression(parts[0].trim(), context)
      set right = evaluate_expression(parts[1].trim(), context)
      return left * right
    }
    
    if expr.contains("/") {
      set parts = expr.split("/", 2)
      set left = evaluate_expression(parts[0].trim(), context)
      set right = evaluate_expression(parts[1].trim(), context)
      if right == 0 {
        say "❌ Division by zero!"
        return null
      }
      return left / right
    }
    
    if expr.contains("==") {
      set parts = expr.split("==", 2)
      set left = evaluate_expression(parts[0].trim(), context)
      set right = evaluate_expression(parts[1].trim(), context)
      return left == right
    }
    
    if expr.contains("!=") {
      set parts = expr.split("!=", 2)
      set left = evaluate_expression(parts[0].trim(), context)
      set right = evaluate_expression(parts[1].trim(), context)
      return left != right
    }
    
    if expr.contains(">") {
      set parts = expr.split(">", 2)
      set left = evaluate_expression(parts[0].trim(), context)
      set right = evaluate_expression(parts[1].trim(), context)
      return left > right
    }
    
    if expr.contains("<") {
      set parts = expr.split("<", 2)
      set left = evaluate_expression(parts[0].trim(), context)
      set right = evaluate_expression(parts[1].trim(), context)
      return left < right
    }
    
    if expr.contains(">=") {
      set parts = expr.split(">=", 2)
      set left = evaluate_expression(parts[0].trim(), context)
      set right = evaluate_expression(parts[1].trim(), context)
      return left >= right
    }
    
    if expr.contains("<=") {
      set parts = expr.split("<=", 2)
      set left = evaluate_expression(parts[0].trim(), context)
      set right = evaluate_expression(parts[1].trim(), context)
      return left <= right
    }
    
    return expr
  }

  fn evaluate_function_call(expr, context) {
    # Parse: function_name(arg1, arg2, ...)
    set paren_start = expr.indexOf("(")
    set paren_end = expr.indexOf(")")
    
    if paren_start == -1 || paren_end == -1 {
      return { success: false, error: "invalid_function_call_syntax" }
    }
    
    set function_name = expr.substring(0, paren_start).trim()
    set args_part = expr.substring(paren_start + 1, paren_end).trim()
    
    # Parse arguments
    set args = []
    if args_part != "" {
      set arg_list = args_part.split(",")
      for arg in arg_list {
        args.push(evaluate_expression(arg.trim(), context))
      }
    }
    
    # Check if it's a built-in function
    if function_name == "len" {
      return len(args[0])
    }
    
    if function_name == "push" {
      if args.length >= 2 {
        args[0].push(args[1])
        return true
      }
      return false
    }
    
    # Check if it's a user-defined function
    if ::functions[function_name] {
      return execute_user_function(function_name, args, context)
    }
    
    say "❌ Unknown function: $function_name"
    return null
  }

  fn execute_user_function(function_name, args, context) {
    set function = ::functions[function_name]
    
    # Create new scope for function
    push_scope()
    
    # Set parameters
    for i in range(0, function.params.length) {
      if i < args.length {
        set_variable(function.params[i], args[i])
      }
    }
    
    # Execute function body
    set body_statements = function.body.split(";")
    for stmt in body_statements {
      if stmt.trim() != "" {
        set result = execute_statement(stmt.trim(), context)
        if !result.success {
          pop_scope()
          return result
        }
        if result.control == "return" {
          pop_scope()
          return result.value
        }
      }
    }
    
    pop_scope()
    return null
  }

  # SCOPE MANAGEMENT
  
  fn push_scope() {
    ::scopes.push({})
    ::current_scope = ::current_scope + 1
  }
  
  fn pop_scope() {
    if ::scopes.length > 1 {
      ::scopes.pop()
      ::current_scope = ::current_scope - 1
    }
  }
  
  fn set_variable(name, value) {
    if name.startsWith("::") {
      # Global variable
      ::variables[name] = value
    } else {
      # Local variable in current scope
      ::scopes[::current_scope][name] = value
    }
  }
  
  fn get_variable(name) {
    if name.startsWith("::") {
      # Global variable
      return ::variables[name.substring(2)]
    } else {
      # Check local scopes first, then global
      for i in range(::current_scope, -1, -1) {
        if ::scopes[i][name] != null {
          return ::scopes[i][name]
        }
      }
      return ::variables[name]
    }
  }

  # UTILITY FUNCTIONS
  
  fn is_number(str) {
    return !isNaN(str) && !isNaN(parseFloat(str))
  }
  
  fn current_timestamp() {
    # Use the real system time interface
    emit time.current
    wait for "time.current.complete" then {
      set result = ::event.data
      if result.success {
        return result.timestamp
      } else {
        return "timestamp_" + (::variables["__counter"] || 0)
      }
    }
  }
  
  fn read_file_content(path) {
    # Use the real file system interface
    emit file.read with { path: path }
    wait for "file.read.complete" then {
      set result = ::event.data
      if result.success {
        return result.content
      } else {
        say "❌ File read failed: $result.error"
        return null
      }
    }
  }
  
  fn setup_behavior_handlers(behavior_lines, component_name) {
    # Parse behavior blocks and set up event handlers
    say "🎭 Setting up behavior handlers for $component_name"
    
    set event_handlers = {}
    
    for line in behavior_lines {
      if line.startsWith("listen for ") {
        # Parse event handler: listen for "event_name" then { ... }
        set parts = line.split(" ")
        if parts.length >= 4 {
          set event_name = parts[2]
          if event_name.startsWith("\"") && event_name.endsWith("\"") {
            event_name = event_name.substring(1, event_name.length - 1)
          }
          
          # Extract handler body
          set brace_start = line.indexOf("then {")
          if brace_start != -1 {
            set handler_body = line.substring(brace_start + 6)
            event_handlers[event_name] = handler_body
            say "🎯 Event handler registered: $event_name"
          }
        }
      }
    }
    
    # Store handlers in component
    if !::components[component_name] {
      ::components[component_name] = {}
    }
    ::components[component_name].event_handlers = event_handlers
    
    return { success: true, handlers: event_handlers }
  }
  
  fn start_interpreter_loop() {
    say "🚀 Starting interpreter loop..."
    set ::running = true
    
    while ::running {
      if ::event_queue.length > 0 {
        set event = ::event_queue.shift()
        process_event(event)
      } else {
        # No events, wait a bit
        set ::wait_time = 0.1
        say "⏳ Waiting for events..."
      }
    }
    
    say "✅ Interpreter loop completed"
  }
  
  fn stop_interpreter() {
    set ::running = false
    say "🛑 Interpreter stopped"
  }
  
  fn process_event(event) {
    set event_name = event.event
    source = event.source
    
    say "🔄 Processing event: $event_name"
    
    # Add to processed events
    ::processed_events.push(event_name)
    
    # Find components that listen for this event
    for component_name in ::components.keys {
      set component = ::components[component_name]
      if component.behavior && component.behavior.length > 0 {
        # Check if this component has a handler for this event
        # This is simplified - real implementation would parse behavior blocks
        say "🎯 Component $component_name handling event: $event_name"
      }
    }
  }
  
  # ADDITIONAL UTILITY FUNCTIONS
  
  fn range(start, end) {
    set result = []
    set current = start
    while current < end {
      result.push(current)
      current = current + 1
    }
    return result
  }
  
  fn len(array) {
    if array && array.length != null {
      return array.length
    }
    return 0
  }
  
  # MISSING INITIALIZATION FUNCTIONS - ADDING NOW
  
  fn init_parser() {
    say "🔧 Initializing parser..."
    set ::parser_ready = true
    say "✅ Parser ready"
  }
  
  fn init_executor() {
    say "🔧 Initializing executor..."
    set ::executor_ready = true
    say "✅ Executor ready"
  }
  
  fn init_event_system() {
    say "🔧 Initializing event system..."
    set ::event_system_ready = true
    say "✅ Event system ready"
  }
}
