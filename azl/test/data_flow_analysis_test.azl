component ::data_flow_analysis_test {
  init {
    link ::azl.data_flow_analyzer
    set ::test_results = {}
    set ::test_count = 0
    set ::passed_tests = 0
  }

  behavior {
    listen for "start_data_flow_tests" then {
      say "🧪 Starting Data Flow Analysis Tests..."
      
      # Test 1: Basic reaching definitions
      emit "test_reaching_definitions" with {}
      
      # Test 2: Available expressions
      emit "test_available_expressions" with {}
      
      # Test 3: Live variables
      emit "test_live_variables" with {}
      
      # Test 4: Comprehensive analysis
      emit "test_comprehensive_analysis" with {}
      
      # Test 5: Complex control flow
      emit "test_complex_control_flow" with {}
    }

    listen for "test_reaching_definitions" then {
      set ::test_count = ::test_count + 1
      say "🧪 Test ::test_count: Reaching Definitions Analysis"
      
      # Create test AST
      set ::test_ast = ::create_reaching_definitions_test_ast()
      
      # Perform analysis
      emit "analyze_data_flow" to ::azl.data_flow_analyzer with {
        ast: ::test_ast,
        analysis_type: "reaching_definitions",
        target_platform: "x86_64"
      }
      
      listen for "data_flow_analysis_complete" from ::azl.data_flow_analyzer then {
        set ::results = ::event.data
        set ::passed = ::validate_reaching_definitions(::results)
        
        if ::passed {
          set ::passed_tests = ::passed_tests + 1
          say "✅ Reaching Definitions Test PASSED"
        } else {
          say "❌ Reaching Definitions Test FAILED"
        }
        
        set ::test_results["reaching_definitions"] = {
          passed: ::passed,
          results: ::results
        }
        
        emit "test_available_expressions" with {}
      }
    }

    listen for "test_available_expressions" then {
      set ::test_count = ::test_count + 1
      say "🧪 Test ::test_count: Available Expressions Analysis"
      
      # Create test AST
      set ::test_ast = ::create_available_expressions_test_ast()
      
      # Perform analysis
      emit "analyze_data_flow" to ::azl.data_flow_analyzer with {
        ast: ::test_ast,
        analysis_type: "available_expressions",
        target_platform: "x86_64"
      }
      
      listen for "data_flow_analysis_complete" from ::azl.data_flow_analyzer then {
        set ::results = ::event.data
        set ::passed = ::validate_available_expressions(::results)
        
        if ::passed {
          set ::passed_tests = ::passed_tests + 1
          say "✅ Available Expressions Test PASSED"
        } else {
          say "❌ Available Expressions Test FAILED"
        }
        
        set ::test_results["available_expressions"] = {
          passed: ::passed,
          results: ::results
        }
        
        emit "test_live_variables" with {}
      }
    }

    listen for "test_live_variables" then {
      set ::test_count = ::test_count + 1
      say "🧪 Test ::test_count: Live Variables Analysis"
      
      # Create test AST
      set ::test_ast = ::create_live_variables_test_ast()
      
      # Perform analysis
      emit "analyze_data_flow" to ::azl.data_flow_analyzer with {
        ast: ::test_ast,
        analysis_type: "live_variables",
        target_platform: "x86_64"
      }
      
      listen for "data_flow_analysis_complete" from ::azl.data_flow_analyzer then {
        set ::results = ::event.data
        set ::passed = ::validate_live_variables(::results)
        
        if ::passed {
          set ::passed_tests = ::passed_tests + 1
          say "✅ Live Variables Test PASSED"
        } else {
          say "❌ Live Variables Test FAILED"
        }
        
        set ::test_results["live_variables"] = {
          passed: ::passed,
          results: ::results
        }
        
        emit "test_comprehensive_analysis" with {}
      }
    }

    listen for "test_comprehensive_analysis" then {
      set ::test_count = ::test_count + 1
      say "🧪 Test ::test_count: Comprehensive Data Flow Analysis"
      
      # Create test AST
      set ::test_ast = ::create_comprehensive_test_ast()
      
      # Perform comprehensive analysis
      emit "analyze_data_flow" to ::azl.data_flow_analyzer with {
        ast: ::test_ast,
        analysis_type: "all",
        target_platform: "x86_64"
      }
      
      listen for "data_flow_analysis_complete" from ::azl.data_flow_analyzer then {
        set ::results = ::event.data
        set ::passed = ::validate_comprehensive_analysis(::results)
        
        if ::passed {
          set ::passed_tests = ::passed_tests + 1
          say "✅ Comprehensive Analysis Test PASSED"
        } else {
          say "❌ Comprehensive Analysis Test FAILED"
        }
        
        set ::test_results["comprehensive"] = {
          passed: ::passed,
          results: ::results
        }
        
        emit "test_complex_control_flow" with {}
      }
    }

    listen for "test_complex_control_flow" then {
      set ::test_count = ::test_count + 1
      say "🧪 Test ::test_count: Complex Control Flow Analysis"
      
      # Create test AST with complex control flow
      set ::test_ast = ::create_complex_control_flow_test_ast()
      
      # Perform analysis
      emit "analyze_data_flow" to ::azl.data_flow_analyzer with {
        ast: ::test_ast,
        analysis_type: "all",
        target_platform: "x86_64"
      }
      
      listen for "data_flow_analysis_complete" from ::azl.data_flow_analyzer then {
        set ::results = ::event.data
        set ::passed = ::validate_complex_control_flow(::results)
        
        if ::passed {
          set ::passed_tests = ::passed_tests + 1
          say "✅ Complex Control Flow Test PASSED"
        } else {
          say "❌ Complex Control Flow Test FAILED"
        }
        
        set ::test_results["complex_control_flow"] = {
          passed: ::passed,
          results: ::results
        }
        
        # Print final results
        emit "print_test_results" with {}
      }
    }

    listen for "print_test_results" then {
      say "📊 Data Flow Analysis Test Results:"
      say "📊 Total Tests: ::test_count"
      say "📊 Passed: ::passed_tests"
      say "📊 Failed: ::test_count - ::passed_tests"
      say "📊 Success Rate: ::((::passed_tests / ::test_count) * 100).toFixed(1)%"
      
      say "📋 Detailed Results:"
      for ::test_name in ::test_results {
        set ::result = ::test_results[::test_name]
        set ::status = ::result.passed ? "✅ PASS" : "❌ FAIL"
        say "  ::status ::test_name"
        
        if ::result.results.analysis_metadata {
          say "    Iterations: ::result.results.analysis_metadata.iterations"
          say "    Converged: ::result.results.analysis_metadata.converged"
        }
      }
      
      say "🎉 Data Flow Analysis Testing Complete!"
    }
  }

  memory {
    ::create_reaching_definitions_test_ast = () => {
      return {
        body: [
          { type: "SET", variable: "x", value: "1" },
          { type: "SET", variable: "y", value: "x + 2" },
          { type: "SET", variable: "x", value: "3" },
          { type: "SET", variable: "z", value: "x + y" }
        ]
      }
    }

    ::create_available_expressions_test_ast = () => {
      return {
        body: [
          { type: "SET", variable: "a", value: "b + c" },
          { type: "SET", variable: "d", value: "b + c" },  # Should be available
          { type: "SET", variable: "b", value: "5" },      # Kills b + c
          { type: "SET", variable: "e", value: "b + c" }   # Should not be available
        ]
      }
    }

    ::create_live_variables_test_ast = () => {
      return {
        body: [
          { type: "SET", variable: "x", value: "1" },
          { type: "SET", variable: "y", value: "x + 2" },
          { type: "SET", variable: "z", value: "y * 3" },
          { type: "SET", variable: "result", value: "z" }
        ]
      }
    }

    ::create_comprehensive_test_ast = () => {
      return {
        body: [
          { type: "SET", variable: "sum", value: "0" },
          { type: "SET", variable: "i", value: "0" },
          { type: "WHILE", condition: "i < 10" },
          { type: "SET", variable: "sum", value: "sum + i" },
          { type: "SET", variable: "i", value: "i + 1" },
          { type: "SET", variable: "result", value: "sum" }
        ],
        functions: [
          {
            name: "calculate",
            body: [
              { type: "SET", variable: "temp", value: "a + b" },
              { type: "SET", variable: "result", value: "temp * 2" }
            ]
          }
        ]
      }
    }

    ::create_complex_control_flow_test_ast = () => {
      return {
        body: [
          { type: "SET", variable: "x", value: "1" },
          { type: "IF", condition: "x > 0" },
          { type: "SET", variable: "y", value: "x + 1" },
          { type: "SET", variable: "z", value: "y * 2" },
          { type: "ELSE" },
          { type: "SET", variable: "y", value: "x - 1" },
          { type: "SET", variable: "z", value: "y / 2" },
          { type: "SET", variable: "result", value: "z" }
        ]
      }
    }

    ::validate_reaching_definitions = (results) => {
      if !::results.reaching_definitions { return false }
      if !::results.reaching_definitions.definitions { return false }
      if !::results.reaching_definitions.out_sets { return false }
      
      # Check that we have definitions
      set ::def_count = ::Object.keys(::results.reaching_definitions.definitions).length
      if ::def_count < 2 { return false }
      
      # Check that analysis converged
      if !::results.reaching_definitions.analysis_metadata.converged { return false }
      
      return true
    }

    ::validate_available_expressions = (results) => {
      if !::results.available_expressions { return false }
      if !::results.available_expressions.expressions { return false }
      if !::results.available_expressions.out_sets { return false }
      
      # Check that we have expressions
      set ::expr_count = ::Object.keys(::results.available_expressions.expressions).length
      if ::expr_count < 1 { return false }
      
      # Check that analysis converged
      if !::results.available_expressions.analysis_metadata.converged { return false }
      
      return true
    }

    ::validate_live_variables = (results) => {
      if !::results.live_variables { return false }
      if !::results.live_variables.variables { return false }
      if !::results.live_variables.in_sets { return false }
      
      # Check that we have variables
      set ::var_count = ::Object.keys(::results.live_variables.variables).length
      if ::var_count < 2 { return false }
      
      # Check that analysis converged
      if !::results.live_variables.analysis_metadata.converged { return false }
      
      return true
    }

    ::validate_comprehensive_analysis = (results) => {
      # Check all three analyses are present
      if !::results.reaching_definitions { return false }
      if !::results.available_expressions { return false }
      if !::results.live_variables { return false }
      
      # Check metadata
      if !::results.analysis_metadata { return false }
      if !::results.analysis_metadata.target_platform { return false }
      if !::results.analysis_metadata.timestamp { return false }
      
      return true
    }

    ::validate_complex_control_flow = (results) => {
      # Check that control flow graph was built
      if !::results.reaching_definitions { return false }
      if !::results.reaching_definitions.definitions { return false }
      
      # Check that we have multiple definitions (due to control flow)
      set ::def_count = ::Object.keys(::results.reaching_definitions.definitions).length
      if ::def_count < 3 { return false }
      
      # Check that analysis converged
      if !::results.reaching_definitions.analysis_metadata.converged { return false }
      
      return true
    }
  }
}

# Test runner
component ::data_flow_test_runner {
  init {
    link ::data_flow_analysis_test
  }

  behavior {
    listen for "run_data_flow_tests" then {
      say "🚀 Starting Data Flow Analysis Test Suite..."
      emit "start_data_flow_tests" to ::data_flow_analysis_test with {}
    }
  }
}
