// Test AZME Integration
// This script tests the complete AZME + AnythingLLM integration

// Test direct AZME API
function test_azme_direct() {
    print("🧪 Testing direct AZME API...")
    try {
        let response = http_post(
            "http://localhost:8000/generate",
            json_stringify({"prompt": "Hello AZME, can you tell me about quantum computing?"}),
            {"Content-Type": "application/json"}
        )
        if (response.status == 200) {
            let result = json_parse(response.body)
            print("✅ AZME API working: " + (result.response || "No response").substring(0, 100) + "...")
            return true
        } else {
            print("❌ AZME API error: " + response.status)
            return false
        }
    } catch (error) {
        print("❌ AZME API error: " + error)
        return false
    }
}

// Test proxy server
function test_proxy() {
    print("🧪 Testing proxy server...")
    try {
        let response = http_post(
            "http://localhost:8080/chat",
            json_stringify({"message": "Hello AZME, can you tell me about quantum computing?", "workspace_id": 1}),
            {"Content-Type": "application/json"}
        )
        if (response.status == 200) {
            let result = json_parse(response.body)
            print("✅ Proxy working: " + (result.response || "No response").substring(0, 100) + "...")
            return true
        } else {
            print("❌ Proxy error: " + response.status)
            return false
        }
    } catch (error) {
        print("❌ Proxy error: " + error)
        return false
    }
}

// Test AnythingLLM API
function test_anythingllm() {
    print("🧪 Testing AnythingLLM API...")
    try {
        let response = http_get("http://localhost:3001/api/workspaces")
        if (response.status == 200) {
            let workspaces = json_parse(response.body)
            let count = workspaces.workspaces ? workspaces.workspaces.length : 0
            print("✅ AnythingLLM API working, found " + count + " workspaces")
            return true
        } else {
            print("❌ AnythingLLM API error: " + response.status)
            return false
        }
    } catch (error) {
        print("❌ AnythingLLM API error: " + error)
        return false
    }
}

// Main function
function main() {
    print("🚀 Testing AZME Integration...")
    print("=" * 50)
    
    // Test all components
    let azme_ok = test_azme_direct()
    let proxy_ok = test_proxy()
    let anythingllm_ok = test_anythingllm()
    
    print("\n" + "=" * 50)
    print("📊 Integration Test Results:")
    print("AZME API: " + (azme_ok ? "✅ Working" : "❌ Failed"))
    print("Proxy Server: " + (proxy_ok ? "✅ Working" : "❌ Failed"))
    print("AnythingLLM: " + (anythingllm_ok ? "✅ Working" : "❌ Failed"))
    
    if (azme_ok && proxy_ok && anythingllm_ok) {
        print("\n🎉 All systems are working!")
        print("🌐 You can now use AZME in AnythingLLM at: http://localhost:3001")
        print("💡 Try asking questions about quantum computing, AI, or any topic!")
    } else {
        print("\n⚠️ Some components are not working. Please check the errors above.")
    }
}

// Execute main function
main() 