component ::test.stdlib.json_minimal {
  init {
    say "🧪 JSON minimal parser test"
    emit run
  }
  behavior {
    listen for "run" then {
      set obj = ::azl.stdlib.json_parse('{"a":1,"b":"x","c":true,"d":null}')
      if (obj.a == 1 && obj.b == "x" && obj.c == true) { say "✅ json_parse basic ok" } else { say "TESTS_FAIL json_parse" }
      set s = ::azl.stdlib.json_stringify({ a:1, b:"x" })
      if (s.contains('"a":1') && s.contains('"b":"x"')) { say "✅ json_stringify basic ok" } else { say "TESTS_FAIL json_stringify" }
      emit done
    }
    listen for "done" then { say "✅ AZL Integration Test Complete!" }
  }
}

