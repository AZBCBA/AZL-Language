// ABA Components Validation Script
// Validates that our ABA components have correct AZL syntax

component ::validator.aba_components {
  init {
    set ::validation_status = "initializing"
    set ::validation_results = {}
    set ::components_to_validate = [
      "reinforcement_schedule",
      "discrete_trial_training", 
      "function_identifier",
      "language_shaper"
    ]
    set ::validation_errors = []
    set ::validation_successes = []
    
    emit "validator.aba_components.initialized" with ::validation_status
  }

  behavior {
    listen for "start_validation" then {
      set ::validation_status = "validating"
      emit "validation_started" with { components: ::components_to_validate }
      
      validate_reinforcement_schedule()
    }

    listen for "reinforcement_validated" then {
      validate_discrete_trial_training()
    }

    listen for "dtt_validated" then {
      validate_function_identifier()
    }

    listen for "function_validated" then {
      validate_language_shaper()
    }

    listen for "language_validated" then {
      generate_validation_report()
    }
  }

  memory {
    validation_status
    validation_results
    components_to_validate
    validation_errors
    validation_successes
  }

  interface {
    start_validation
    validate_reinforcement_schedule
    validate_discrete_trial_training
    validate_function_identifier
    validate_language_shaper
    generate_validation_report
  }
}

// Validate Reinforcement Schedule Component
function validate_reinforcement_schedule() {
  emit "console.log" with { message: "🔍 Validating Reinforcement Schedule Component...", timestamp: now() }
  
  // Check if component exists
  branch when ::aba.reinforcement_schedule {
    // Check required properties
    branch when ::aba.reinforcement_schedule.schedule_type {
      store ::validation_successes from ::validation_successes.push("reinforcement_schedule.schedule_type")
    } else {
      store ::validation_errors from ::validation_errors.push("reinforcement_schedule.schedule_type missing")
    }
    
    branch when ::aba.reinforcement_schedule.parameter {
      store ::validation_successes from ::validation_successes.push("reinforcement_schedule.parameter")
    } else {
      store ::validation_errors from ::validation_errors.push("reinforcement_schedule.parameter missing")
    }
    
    branch when ::aba.reinforcement_schedule.reinforcement_history {
      store ::validation_successes from ::validation_successes.push("reinforcement_schedule.reinforcement_history")
    } else {
      store ::validation_errors from ::validation_errors.push("reinforcement_schedule.reinforcement_history missing")
    }
    
    // Check global improvements
    branch when ::aba.reinforcement_schedule.introspection_state {
      store ::validation_successes from ::validation_successes.push("reinforcement_schedule.introspection_state")
    } else {
      store ::validation_errors from ::validation_errors.push("reinforcement_schedule.introspection_state missing")
    }
    
    branch when ::aba.reinforcement_schedule.goal_meta {
      store ::validation_successes from ::validation_successes.push("reinforcement_schedule.goal_meta")
    } else {
      store ::validation_errors from ::validation_errors.push("reinforcement_schedule.goal_meta missing")
    }
    
    branch when ::aba.reinforcement_schedule.evolution_slots {
      store ::validation_successes from ::validation_successes.push("reinforcement_schedule.evolution_slots")
    } else {
      store ::validation_errors from ::validation_errors.push("reinforcement_schedule.evolution_slots missing")
    }
    
    branch when ::aba.reinforcement_schedule.modular_interface {
      store ::validation_successes from ::validation_successes.push("reinforcement_schedule.modular_interface")
    } else {
      store ::validation_errors from ::validation_errors.push("reinforcement_schedule.modular_interface missing")
    }
    
    emit "console.log" with { message: "✅ Reinforcement Schedule Component Validated", timestamp: now() }
  } else {
    store ::validation_errors from ::validation_errors.push("reinforcement_schedule component not found")
    emit "console.log" with { message: "❌ Reinforcement Schedule Component Not Found", timestamp: now() }
  }
  
  emit "reinforcement_validated"
}

