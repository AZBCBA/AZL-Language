# AZL v2 Test - Modern Syntax Demonstration
# This file demonstrates the new AZL v2 syntax

# Variables with let
let name = "AZME"
let age = 3
let active = true
let scores = [85, 92, 78]
let config = { learning: true, rate: 0.05 }

# Functions with fn
fn greet(name) {
  return "Hello, " + name
}

fn add(a, b) {
  return a + b
}

fn calculate_average(scores) {
  let total = 0
  let count = 0
  
  loop for score in scores {
    set total = total + score
    set count = count + 1
  }
  
  return total / count
}

# Conditionals with if/else
if age > 2 {
  say "Mature agent"
} else {
  say "Still learning"
}

# Loops with for/in
loop for score in scores {
  if score > 90 {
    say "High score: " + score
  }
}

# Event handlers with on
on task_completed(task) {
  say "Task done: " + task.name
  say "Duration: " + task.duration
}

# Emit events
emit task_started with { name: "test_task", priority: "high" }

# Object access
let task_name = task.name
let learning_rate = config["rate"]

# System operations
say "AZME is running"
say "Current configuration: " + config

# Function calls
let greeting = greet(name)
let sum = add(10, 20)
let average = calculate_average(scores)

say "Greeting: " + greeting
say "Sum: " + sum
say "Average score: " + average

# Complex example
fn process_data(data) {
  let results = []
  
  loop for item in data {
    if item.value > 50 {
      let processed = item.value * 2
      set results = results + [processed]
    }
  }
  
  return results
}

let test_data = [
  { name: "item1", value: 30 },
  { name: "item2", value: 60 },
  { name: "item3", value: 45 }
]

let processed_results = process_data(test_data)
say "Processed results: " + processed_results

# Event emission with payload
emit data_processed with {
  input_count: test_data.length,
  output_count: processed_results.length,
  success: true
}

# Error handling example
fn safe_divide(a, b) {
  if b == 0 {
    say "Error: Division by zero"
    return null
  }
  return a / b
}

let result1 = safe_divide(10, 2)
let result2 = safe_divide(10, 0)

say "Result 1: " + result1
say "Result 2: " + result2

# Component-like structure (using functions)
fn create_component(name) {
  let component = {
    name: name,
    status: "active",
    data: [],
    
    add_data: fn(item) {
      set component.data = component.data + [item]
    },
    
    get_status: fn() {
      return component.status
    },
    
    process: fn() {
      say "Processing component: " + component.name
      loop for item in component.data {
        say "Processing: " + item
      }
    }
  }
  
  return component
}

let my_component = create_component("test_component")
my_component.add_data("item1")
my_component.add_data("item2")
my_component.process()

say "Component status: " + my_component.get_status()

# Array operations
let numbers = [1, 2, 3, 4, 5]
let doubled = []

loop for num in numbers {
  set doubled = doubled + [num * 2]
}

say "Original: " + numbers
say "Doubled: " + doubled

# Object operations
let person = {
  name: "AZME",
  age: 3,
  skills: ["learning", "reasoning", "adaptation"]
}

say "Person: " + person.name
say "Age: " + person.age
say "Skills: " + person.skills

# Nested functions
fn create_counter() {
  let count = 0
  
  return fn() {
    set count = count + 1
    return count
  }
}

let counter = create_counter()
say "Counter: " + counter()
say "Counter: " + counter()
say "Counter: " + counter()

# Complex conditional logic
fn evaluate_performance(scores) {
  let average = calculate_average(scores)
  
  if average >= 90 {
    return "Excellent"
  } else if average >= 80 {
    return "Good"
  } else if average >= 70 {
    return "Average"
  } else {
    return "Needs improvement"
  }
}

let performance = evaluate_performance(scores)
say "Performance: " + performance

# Event-driven programming
on data_received(data) {
  say "Received data: " + data
  
  if data.type == "user_input" {
    emit process_user_input with data
  } else if data.type == "system_event" {
    emit handle_system_event with data
  }
}

on process_user_input(data) {
  say "Processing user input: " + data.content
  let response = "Processed: " + data.content
  emit user_response with { response: response }
}

on handle_system_event(data) {
  say "Handling system event: " + data.event_type
  emit system_updated with { status: "processed" }
}

# Test the event system
emit data_received with {
  type: "user_input",
  content: "Hello AZME"
}

emit data_received with {
  type: "system_event",
  event_type: "status_check"
}

say "AZL v2 test completed successfully!" 