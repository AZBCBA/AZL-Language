# Simple Enhanced Syntax Test
# Verifies all enhanced features work correctly

component ::test.simple {
  init {
    set ::name = "Simple Test"
    say "🚀 ::name initialized"
    
    # Test if/else
    if 5 > 3 then {
      say "✅ 5 is greater than 3"
    } else {
      say "❌ 5 is not greater than 3"
    }
    
    # Test while
    set ::count = 0
    while ::count < 2 {
      set ::count = ::count + 1
      say "Counter: ::count"
    }
    
    say "🎯 Simple test completed!"
  }

  memory {
    status: "ready"
  }
} 