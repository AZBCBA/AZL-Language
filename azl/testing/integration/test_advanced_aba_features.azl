# Test Advanced ABA Features
# Tests the new advanced ABA functions: define_chain, shape_behavior, prompt_fade, task_analysis

say "🔧 Starting Advanced ABA Features Test..."

# Test 1: Define Behavior Chain
say "🔧 Step 1: Testing define_chain..."
define_chain "multi_step_learning: step1=read, step2=understand, step3=apply, step4=reflect"
define_chain "complex_task_execution: step1=plan, step2=execute, step3=monitor, step4=adjust"
define_chain "problem_solving: step1=analyze, step2=hypothesize, step3=test, step4=evaluate"

# Test 2: Shape Behavior
say "🔧 Step 2: Testing shape_behavior..."
shape_behavior "learning_skill: current=basic, target=advanced, steps=5"
shape_behavior "communication: current=simple, target=complex, steps=3"
shape_behavior "problem_solving: current=reactive, target=proactive, steps=4"

# Test 3: Prompt Fade
say "🔧 Step 3: Testing prompt_fade..."
prompt_fade "learning_prompt: initial=full, target=minimal, steps=10"
prompt_fade "guidance_prompt: initial=detailed, target=subtle, steps=8"
prompt_fade "instruction_prompt: initial=explicit, target=implicit, steps=6"

# Test 4: Task Analysis
say "🔧 Step 4: Testing task_analysis..."
task_analysis "complex_learning_task: subtasks=10, dependencies=5, complexity=high"
task_analysis "behavior_modification: subtasks=7, dependencies=3, complexity=medium"
task_analysis "skill_acquisition: subtasks=12, dependencies=8, complexity=very_high"

# Test 5: Combine with Basic ABA Functions
say "🔧 Step 5: Testing Integration with Basic ABA Functions..."
addgoal "Master advanced ABA techniques" 10
addgoal "Learn behavior chaining" 9
addgoal "Practice prompt fading" 8

# Execute goals
say "🔧 Step 6: Executing Goals with Advanced ABA..."
run

# Test ABA trial logging for advanced features
say "🔧 Step 7: Testing ABA Trial Logging for Advanced Features..."
apply_trial "antecedent: advanced_aba_testing; behavior: define_chain; consequence: success"
apply_trial "antecedent: advanced_aba_testing; behavior: shape_behavior; consequence: success"
apply_trial "antecedent: advanced_aba_testing; behavior: prompt_fade; consequence: success"
apply_trial "antecedent: advanced_aba_testing; behavior: task_analysis; consequence: success"

# Test reinforcement for advanced behaviors
say "🔧 Step 8: Testing Reinforcement for Advanced Behaviors..."
reinforce_behavior advanced_chain_definition
reinforce_behavior successful_behavior_shaping
reinforce_behavior effective_prompt_fading
reinforce_behavior thorough_task_analysis

# Test consequence analysis
say "🔧 Step 9: Testing Consequence Analysis..."
analyze_consequence

# Check final state and advanced ABA data
say "🔧 Step 10: Checking Final State and Advanced ABA Data..."
reflect

say "✅ Advanced ABA Features Test Complete!"
say "🔧 All advanced ABA functions are working!"
say "🎯 AZL now has powerful behavior learning capabilities!"
say "🧠 Advanced ABA features integrated successfully!" 