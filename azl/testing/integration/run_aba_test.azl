// ABA System Test Runner - Pure AZL
// Tests our enhanced ABA components

component ::aba.test_runner {
  init {
    set ::test_status = "initializing"
    set ::test_results = {}
    set ::current_test = "none"
    set ::test_phase = 0
    
    // Initialize ABA components
    set ::reinforcement_schedule = ::aba.reinforcement_schedule
    set ::discrete_trial_training = ::aba.discrete_trial_training
    set ::function_identifier = ::aba.function_identifier
    set ::language_shaper = ::aba.language_shaper
    
    emit "aba.test_runner.initialized" with ::test_status
  }

  behavior {
    listen for "start_aba_test" then {
      set ::test_status = "running"
      set ::test_phase = 1
      emit "test_phase_started" with { phase: "reinforcement_schedule", phase_number: 1 }
      test_reinforcement_schedule()
    }

    listen for "reinforcement_test_complete" then {
      set ::test_phase = 2
      emit "test_phase_started" with { phase: "discrete_trial_training", phase_number: 2 }
      test_discrete_trial_training()
    }

    listen for "dtt_test_complete" then {
      set ::test_phase = 3
      emit "test_phase_started" with { phase: "function_identifier", phase_number: 3 }
      test_function_identifier()
    }

    listen for "function_test_complete" then {
      set ::test_phase = 4
      emit "test_phase_started" with { phase: "language_shaper", phase_number: 4 }
      test_language_shaper()
    }

    listen for "language_test_complete" then {
      set ::test_status = "completed"
      generate_final_report()
    }

    // Monitor test events
    listen for "console.log" then {
      emit "test.output" with ::console_log_data
    }
  }

  memory {
    test_status
    test_results
    current_test
    test_phase
    reinforcement_schedule
    discrete_trial_training
    function_identifier
    language_shaper
  }

  interface {
    start_aba_test
    test_reinforcement_schedule
    test_discrete_trial_training
    test_function_identifier
    test_language_shaper
    generate_final_report
  }
}

// Test Reinforcement Schedule
function test_reinforcement_schedule() {
  emit "console.log" with { message: "🧠 Testing Reinforcement Schedule...", timestamp: now() }
  
  // Test 1: Continuous Reinforcement
  emit "console.log" with { message: "Testing Continuous Reinforcement", timestamp: now() }
  emit "response_occurred" with {
    behavior: "greeting",
    context: "test",
    learner_id: "test_learner_1",
    response_time: 1500
  }
  
  // Test 2: Fixed Ratio
  emit "console.log" with { message: "Testing Fixed Ratio Schedule", timestamp: now() }
  set ::reinforcement_schedule.schedule_type = "fixed_ratio"
  set ::reinforcement_schedule.parameter = 3
  
  loop from 1 to 6 {
    emit "response_occurred" with {
      behavior: "greeting",
      context: "test",
      learner_id: "test_learner_1",
      response_time: 2000
    }
  }
  
  // Test 3: Variable Ratio
  emit "console.log" with { message: "Testing Variable Ratio Schedule", timestamp: now() }
  set ::reinforcement_schedule.schedule_type = "variable_ratio"
  set ::reinforcement_schedule.parameter = 3
  
  loop from 1 to 10 {
    emit "response_occurred" with {
      behavior: "greeting",
      context: "test",
      learner_id: "test_learner_1",
      response_time: 1800
    }
  }
  
  // Test 4: CLI Integration
  emit "console.log" with { message: "Testing CLI Integration", timestamp: now() }
  emit "cli.command" with "status"
  
  store ::test_results.reinforcement_schedule from {
    schedule_types_tested: ["continuous", "fixed_ratio", "variable_ratio"],
    reinforcement_count: ::reinforcement_schedule.reinforcement_history.length,
    session_duration: now() - ::reinforcement_schedule.session_start,
    goal_progress: ::reinforcement_schedule.goal_meta.goal_progress
  }
  
  emit "console.log" with { message: "✅ Reinforcement Schedule Test Complete", timestamp: now() }
  emit "reinforcement_test_complete"
}

// Test Discrete Trial Training
function test_discrete_trial_training() {
  emit "console.log" with { message: "🧠 Testing Discrete Trial Training...", timestamp: now() }
  
  // Test 1: Start Session
  emit "console.log" with { message: "Starting DTT Session", timestamp: now() }
  emit "start_session"
  
  // Test 2: Run Trials
  emit "console.log" with { message: "Running Trials", timestamp: now() }
  loop from 1 to 5 {
    emit "agent_responded" with {
      behavior: "touch_nose",
      response: "touch_nose",
      context: "test",
      response_time: 2500,
      correct: true
    }
  }
  
  // Test 3: Test Error Correction
  emit "console.log" with { message: "Testing Error Correction", timestamp: now() }
  emit "agent_responded" with {
    behavior: "touch_nose",
    response: "touch_ear",
    context: "test",
    response_time: 3000,
    correct: false
  }
  
  // Test 4: Check Progress
  let progress = ::discrete_trial_training.session_data
  store ::test_results.discrete_trial_training from {
    total_trials: progress.total_trials,
    correct_responses: progress.correct_responses,
    accuracy_rate: progress.correct_responses / (progress.total_trials + 1),
    current_trial: ::discrete_trial_training.current_trial,
    goal_progress: ::discrete_trial_training.goal_meta.goal_progress
  }
  
  emit "console.log" with { message: "✅ Discrete Trial Training Test Complete", timestamp: now() }
  emit "dtt_test_complete"
}

// Test Function Identifier
function test_function_identifier() {
  emit "console.log" with { message: "🧠 Testing Function Identifier...", timestamp: now() }
  
  // Test 1: Escape Function
  emit "console.log" with { message: "Testing Escape Function Analysis", timestamp: now() }
  emit "behavior_observed" with {
    behavior: "tantrum",
    antecedent: "task_demand",
    consequence: "task_removed",
    context: "difficult_activity",
    timestamp: now()
  }
  
  // Test 2: Attention Function
  emit "console.log" with { message: "Testing Attention Function Analysis", timestamp: now() }
  emit "behavior_observed" with {
    behavior: "calling_out",
    antecedent: "alone",
    consequence: "adult_attention",
    context: "quiet_environment",
    timestamp: now()
  }
  
  // Test 3: Access Function
  emit "console.log" with { message: "Testing Access Function Analysis", timestamp: now() }
  emit "behavior_observed" with {
    behavior: "grabbing",
    antecedent: "desired_item_visible",
    consequence: "item_given",
    context: "waiting",
    timestamp: now()
  }
  
  // Test 4: Multi-Function Detection
  emit "console.log" with { message: "Testing Multi-Function Detection", timestamp: now() }
  emit "multi_function_detected" with {
    behavior: "screaming",
    antecedents: ["task_demand", "alone"],
    consequences: ["task_removed", "adult_attention"],
    context: "mixed",
    timestamp: now()
  }
  
  store ::test_results.function_identifier from {
    function_scores: ::function_identifier.function_scores,
    behavior_history_length: ::function_identifier.behavior_history.length,
    confidence_threshold: ::function_identifier.confidence_threshold,
    goal_progress: ::function_identifier.goal_meta.goal_progress
  }
  
  emit "console.log" with { message: "✅ Function Identifier Test Complete", timestamp: now() }
  emit "function_test_complete"
}

// Test Language Shaper
function test_language_shaper() {
  emit "console.log" with { message: "🧠 Testing Language Shaper...", timestamp: now() }
  
  // Test 1: Basic Language Response
  emit "console.log" with { message: "Testing Basic Language Response", timestamp: now() }
  emit "agent_responded" with {
    behavior: "greeting",
    utterance: "Hello!",
    context: "social",
    response_time: 1500,
    success: true,
    expected_intent: "greeting"
  }
  
  // Test 2: Language Error Detection
  emit "console.log" with { message: "Testing Language Error Detection", timestamp: now() }
  emit "agent_responded" with {
    behavior: "greeting",
    utterance: "Me want cookie",
    context: "social",
    response_time: 2000,
    success: false,
    expected_intent: "polite_request"
  }
  
  // Test 3: Expressive Type Analysis
  emit "console.log" with { message: "Testing Expressive Type Analysis", timestamp: now() }
  emit "expressive_type_analysis" with {
    behavior: "greeting",
    utterance: "Can I have a cookie, please?",
    context: "social",
    response_time: 1800,
    success: true
  }
  
  // Test 4: Goal-Based Shaping
  emit "console.log" with { message: "Testing Goal-Based Shaping", timestamp: now() }
  emit "goal_activated" with {
    goal_id: "goal_ask_question",
    target_behavior: "question_asking"
  }
  
  store ::test_results.language_shaper from {
    current_target_behavior: ::language_shaper.current_target_behavior,
    shaping_progress: ::language_shaper.shaping_progress,
    expressive_types: ::language_shaper.expressive_types,
    goal_progress: ::language_shaper.goal_meta.goal_progress
  }
  
  emit "console.log" with { message: "✅ Language Shaper Test Complete", timestamp: now() }
  emit "language_test_complete"
}

// Generate Final Test Report
function generate_final_report() {
  emit "console.log" with { message: "📊 Generating Final Test Report...", timestamp: now() }
  
  set ::test_results.overall = {
    reinforcement_schedule: ::test_results.reinforcement_schedule,
    discrete_trial_training: ::test_results.discrete_trial_training,
    function_identifier: ::test_results.function_identifier,
    language_shaper: ::test_results.language_shaper,
    test_timestamp: now(),
    overall_status: "completed"
  }
  
  emit "console.log" with { message: "🎉 ABA System Test Complete!", timestamp: now() }
  emit "console.log" with { message: "Reinforcement Schedule Tests: " + ::test_results.reinforcement_schedule, timestamp: now() }
  emit "console.log" with { message: "DTT Tests: " + ::test_results.discrete_trial_training, timestamp: now() }
  emit "console.log" with { message: "Function Analysis Tests: " + ::test_results.function_identifier, timestamp: now() }
  emit "console.log" with { message: "Language Shaping Tests: " + ::test_results.language_shaper, timestamp: now() }
  
  emit "test_complete" with ::test_results.overall
}

// Start the test
emit "start_aba_test" 