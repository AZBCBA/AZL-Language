# Comprehensive AZL Error Handling Test
# Tests all error scenarios and diagnostics

say "🧪 Starting Comprehensive Error Handling Test..."

# Test 1: Valid operations (should work)
set ::valid_number = 42
set ::valid_string = "Hello Error Handling!"
set ::valid_float = 3.14159

say "✅ Valid operations completed"

# Test 2: Typeof with valid variables
typeof ::valid_number
typeof ::valid_string
typeof ::valid_float

say "✅ Typeof with valid variables completed"

# Test 3: Mathematical operations
set ::sum = ::valid_number + 8
say "📊 Sum: ::sum = ::sum"

# Test 4: Error cases - VariableNotFound
say "🔍 Testing VariableNotFound error..."
set ::error_var = ::undefined_var

# Test 5: Error cases - InvalidOperation
say "🔍 Testing InvalidOperation error..."
invalid_command_that_does_not_exist

# Test 6: Error cases - TypeMismatch (simulated)
say "🔍 Testing TypeMismatch error..."
set ::string_var = "Hello"
set ::number_var = 42
# Note: TypeMismatch would be caught in a more sophisticated type system

# Test 7: Error cases - Runtime error (simulated)
say "🔍 Testing Runtime error..."
