# Test AZL Curiosity Agent
# Demonstrates intellectual curiosity and exploration capabilities

component ::test.curiosity {
  init {
    say "🧪 Testing AZL Curiosity Agent"
    say "🤔 Starting curiosity test..."
    
    # Initialize curiosity agent
    emit "curiosity.initialized"
    
    # Simulate self-reflection questions to trigger curiosity
    emit "self_reflection.question" with { question: "Why do I perform mathematical operations? What am I calculating?" }
    emit "self_reflection.question" with { question: "What was I waiting for? Was the timing necessary?" }
    emit "self_reflection.question" with { question: "What patterns exist in my memory usage? What am I trying to remember?" }
    emit "self_reflection.question" with { question: "How can I improve my efficiency?" }
    
    # Trigger curiosity assessment
    emit "curiosity.assess"
    
    # Trigger exploration
    emit "curiosity.explore" with { action: "Explore mathematical reasoning" }
    emit "curiosity.explore" with { action: "Analyze timing patterns in my operations" }
  }

  behavior {
    # Listen for curiosity events
    listen for "curiosity.initialized" then {
      say "✅ Curiosity Agent initialized"
    }
    
    listen for "curiosity.explore" then {
      set ::action = ::exploration_data.action
      say "🔍 Curiosity exploring: ::action"
    }
    
    listen for "curiosity.execute_exploration" then {
      set ::action = ::exploration_data.action
      say "🚀 Executing exploration: ::action"
    }
    
    listen for "math.exploration.start" then {
      say "🧮 Mathematical exploration started"
    }
    
    listen for "memory.exploration.start" then {
      say "🧠 Memory exploration started"
    }
    
    listen for "timing.exploration.start" then {
      say "⏱️ Timing exploration started"
    }
    
    listen for "knowledge.exploration.start" then {
      say "📚 Knowledge exploration started"
    }
    
    listen for "general.exploration.start" then {
      say "🔍 General exploration started"
    }
    
    # Listen for CLI commands generated by curiosity
    listen for "cli.input" then {
      set ::command = ::cli_data.command
      say "💭 Curiosity generated command: ::command"
    }
    
    # Listen for follow-up questions
    listen for "self_reflection.question" then {
      set ::question = ::question_data.question
      say "❓ Follow-up question: ::question"
    }
  }

  memory {
    exploration_count: 0,
    questions_processed: 0,
    commands_generated: 0,
    insights_discovered: 0
  }
} 