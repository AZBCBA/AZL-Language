# Test Enhanced AZL Syntax
# Demonstrates blocks, say commands, string interpolation, and event listeners

component ::test.enhanced_syntax {
  init {
    set ::status = "initializing"
    set ::name = "AZL Enhanced"
    set ::version = 2.0
    set ::features = ["blocks", "say", "interpolation", "events"]
    
    say "🚀 Initializing ::name v::version"
    say "📋 Features: ::features"
    
    link ::memory.core
    link ::time.engine
    
    emit "test.enhanced.initialized"
    
    set ::status = "ready"
    say "✅ ::name is ready!"
  }

  behavior {
    listen for "test.enhanced.initialized" then {
      say "🎉 Enhanced syntax test initialized"
      emit "test.run_demo"
    }
    
    listen for "test.run_demo" then {
      say "🧪 Running enhanced syntax demo..."
      
      # Test string interpolation
      set ::message = "Hello from ::name!"
      say ::message
      
      # Test mathematical expressions
      set ::a = 10
      set ::b = 5
      set ::sum = ::a + ::b
      say "Sum of ::a + ::b = ::sum"
      
      # Test conditional logic
      if ::sum > 10 then {
        say "✅ Sum is greater than 10"
        emit "test.condition.passed"
      } else {
        say "❌ Sum is not greater than 10"
        emit "test.condition.failed"
      }
      
      # Test loop simulation
      set ::count = 0
      loop for ::i in [1, 2, 3] {
        set ::count = ::count + ::i
        say "Count: ::count"
      }
      
      say "🎯 Demo completed successfully!"
    }
    
    listen for "test.condition.passed" then {
      say "🎊 Condition test passed!"
    }
  }

  memory {
    status: "ready",
    demo_count: 0,
    success_rate: 1.0,
    last_test: "enhanced_syntax"
  }
} 