component ::tests.aggregate {
  init {
    set ::pass = 0
    set ::fail = 0
    say "🧪 Aggregated tests starting"
    # Trigger real error_system flow (requires error_system to be present in combined file)
    emit log_error with { type: "aggregate_smoke", message: "trigger", context: {} }
    emit finalize
  }

  behavior {
    listen for "error.logged" then {
      set ::pass = ::pass + 1
    }
    listen for "finalize" then {
      if ::pass > 0 {
        say "TESTS_PASS ::pass"
      } else {
        say "TESTS_FAIL ::pass"
      }
    }
  }
}


