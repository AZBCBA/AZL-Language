# Simple AZL Test - Core Features Only
set ::a = 10
set ::b = 5
set ::c = 2

# Basic arithmetic
set ::sum = ::a + ::b
set ::product = ::a * ::b
set ::complex = ::a + ::b * ::c

# Testing
assert ::sum == 15
assert ::product == 50
assert ::complex == 20

# Time functions
internal.now()
internal.wait(1000)

# Events
emit "test.complete" 