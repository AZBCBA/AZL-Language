# Comprehensive Goal System Test
# Tests all aspects of the goal scheduling and execution system

say "🧠 Starting Comprehensive Goal System Test..."

# Test 1: Multiple goals with different priorities
say "🔍 Test 1: Adding multiple goals with priorities..."
addgoal "Clear memory" 6
addgoal "Increase consciousness level" 10
addgoal "Learn new behavior" 4
addgoal "Optimize performance" 8
addgoal "Register new component" 7

# Test 2: Check goals are stored correctly
say "🔍 Test 2: Checking goal storage..."
reflect

# Test 3: Run autonomous execution multiple times
say "🔍 Test 3: Running autonomous execution..."
run
reflect
run
reflect
run
reflect

# Test 4: Test all known goal behaviors
say "🔍 Test 4: Testing all known behaviors..."
addgoal "Clear memory" 9
addgoal "Register new component" 8
addgoal "Optimize performance" 7
addgoal "Learn new behavior" 6

run
reflect
run
reflect
run
reflect
run
reflect

# Test 5: Test error handling
say "🔍 Test 5: Testing error handling..."
addgoal "Unknown goal type" 5
run
reflect

# Test 6: Test empty goals
say "🔍 Test 6: Testing empty goals..."
set ::goals = "No goals set"
run
reflect

# Test 7: Test goal prioritization
say "🔍 Test 7: Testing goal prioritization..."
addgoal "Low priority goal" 1
addgoal "High priority goal" 10
addgoal "Medium priority goal" 5
run
reflect

say "✅ Comprehensive Goal System Test Complete!"
say "🎯 Goal scheduling system is fully functional"
say "🚀 Autonomous execution is working correctly"
say "📊 Goal prioritization is operational"
say "🔧 Error handling is robust" 