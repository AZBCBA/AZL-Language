# Simple Memory Engine Test
# Tests basic memory operations

# Test memory store and retrieve
set ::test_number = 42
set ::test_string = "Hello Memory Engine!"
set ::test_float = 3.14159

# Display stored values
say "📊 Stored values:"
say "📊 ::test_number = ::test_number"
say "📊 ::test_string = ::test_string"
say "📊 ::test_float = ::test_float"

# Test typeof functionality
typeof ::test_number
typeof ::test_string
typeof ::test_float

# Test mathematical operations
set ::sum = ::test_number + 8
say "📊 Sum: ::sum = ::sum"

# Test string operations
set ::greeting = "Hello from AZL Memory Engine!"
say "📊 Greeting: ::greeting"

say "✅ Memory Engine Test Complete!" 