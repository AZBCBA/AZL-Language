# Test AZME→AZL ABA Integration
# Tests the bridge between AZME's high-level cognition and AZL's low-level ABA functions

say "🔌 Starting AZME→AZL ABA Integration Test..."

# Initialize AZME ABA Bridge
say "🔌 Step 1: Initializing AZME ABA Bridge..."
emit "azme.aba_bridge.initialized" with {
  status: "ready",
  version: "1.0",
  linked_components: 7
}

# Test AZME Goal Planning → AZL Goals
say "🔌 Step 2: Testing AZME Goal Planning → AZL Goals..."
emit "azme.goal_planning.goal_created" with {
  goal: "Learn quantum computing principles",
  priority: 9,
  category: "learning",
  azl_command: "addgoal \"Learn quantum computing principles\" 9"
}

# Test AZME Cognitive Reasoning → AZL Reinforcement
say "🔌 Step 3: Testing AZME Cognitive Reasoning → AZL Reinforcement..."
emit "azme.cognitive_reasoning.insight_generated" with {
  insight: "Quantum entanglement can be used for parallel processing",
  confidence: 0.85
}

# Test AZME Learning → AZL Trial Analysis
say "🔌 Step 4: Testing AZME Learning → AZL Trial Analysis..."
emit "azme.learning.learning_complete" with {
  topic: "neural_network_optimization",
  success_rate: 0.92
}

# Test AZME Semantic Understanding → AZL Behavior Shaping
say "🔌 Step 5: Testing AZME Semantic Understanding → AZL Behavior Shaping..."
emit "azme.semantic_understanding.pattern_recognized" with {
  pattern: "recursive_learning_improves_performance",
  recognition_strength: 0.95
}

# Test direct AZL command execution
say "🔌 Step 6: Testing Direct AZL Command Execution..."
emit "azl.execute_command" with { command: "addgoal \"Test AZL integration\" 7" }
emit "azl.execute_command" with { command: "apply_trial \"antecedent: integration_test; behavior: command_execution; consequence: success\"" }
emit "azl.execute_command" with { command: "reinforce_behavior integration_success" }
emit "azl.execute_command" with { command: "analyze_consequence" }

# Check bridge status
say "🔌 Step 7: Checking Bridge Status..."
emit "azme.aba_bridge.status_request"

# Run AZL goal execution to see if goals were created
say "🔌 Step 8: Testing AZL Goal Execution..."
run

say "✅ AZME→AZL ABA Integration Test Complete!"
say "🎯 AZME can now use AZL's ABA functions for intelligent learning!"
say "🧠 The bridge is working - high-level cognition meets low-level behavior!" 

# Extended: integrate AGI core registration and task processing
say "🔌 Step 9: Registering AGI components..."
emit "agi.register_component" with { name: "planner", version: "1.0", capability: "symbolic" }
emit "agi.register_component" with { name: "neural-exec", version: "1.2", capability: "neural" }

say "🔌 Step 10: Enqueue tasks and process..."
emit "agi.enqueue_task" with { task_id: "task-001", task_type: "plan", input: "optimize_goal_flow" }
emit "agi.enqueue_task" with { task_id: "task-002", task_type: "execute", input: "apply_strategy" }
emit "agi.process_queue"
emit "agi.process_queue"
emit "agi.metrics.tick"

say "🔌 Step 11: Query components and capabilities"
emit "agi.component.list"
emit "agi.component.get" with { name: "planner", version: "1.0" }
emit "agi.capability.query" with { capability: "symbolic" }

say "🔌 Step 12: Process all and flush"
emit "agi.process_all"
emit "agi.queue.flush"

say "🔌 Step 13: Status and health"
emit "agi.status"
emit "agi.health.check"

say "🔌 Step 14: Hardware and capabilities APIs"
emit "agi.hardware.get"
emit "agi.hardware.set" with { available_ram: 20000 }
emit "agi.hardware.get"
emit "agi.capability.list"
emit "agi.capability.set" with { name: "QUANTUM", enabled: true }
emit "agi.capability.list"

say "🔌 Step 15: Task result retrieval"
emit "agi.task.result.get" with { task_id: "task-001" }
emit "agi.system.metrics.get"

say "🔌 Step 16: Component lifecycle"
emit "agi.component.initialize" with { name: "planner", version: "1.0" }
emit "agi.component.optimize" with { name: "planner", version: "1.0" }
emit "agi.component.reload" with { name: "planner", version: "1.0" }
emit "agi.component.shutdown" with { name: "planner", version: "1.0" }
emit "agi.component.list"
emit "agi.unregister_component" with { name: "planner", version: "1.0" }
emit "agi.component.list"

say "🔌 Step 17: Automation Wave 1"
emit "automation.scan.inventory" with { path: "migration/INVENTORY.csv" }
emit "automation.plan.wave1"
emit "automation.execute.wave1"
emit "automation.emit.tasks"
emit "automation.report"