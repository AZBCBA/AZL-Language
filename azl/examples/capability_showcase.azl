print("Consciousness stored: " + consciousness_store_result);

let consciousness_retrieve = consciousness_retrieve("demo_consciousness");
print("Consciousness retrieved: " + consciousness_retrieve);

// REAL CAPABILITY 4: Mathematical Operations
print("\n🔢 REAL CAPABILITY 4: MATHEMATICAL OPERATIONS");
let a = 10;
let b = 5;
let addition = a + b;
let multiplication = a * b;
let division = a / b;
print("Addition: " + a + " + " + b + " = " + addition);
print("Multiplication: " + a + " * " + b + " = " + multiplication);
print("Division: " + a + " / " + b + " = " + division);

// REAL CAPABILITY 5: Control Flow
print("\n🔄 REAL CAPABILITY 5: CONTROL FLOW");
let test_value = 7;
if (test_value > 5) {
    print("Value is greater than 5");
} else {
    print("Value is 5 or less");
}

// REAL CAPABILITY 6: Function Calls
print("\n⚙️ REAL CAPABILITY 6: FUNCTION CALLS");
let result = add_numbers(5, 10);
print("Function result: " + result);

function add_numbers(x, y) {
    return x + y;
}

