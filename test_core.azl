# Core AZL Test - Minimal Functionality

component ::test.core {
  init {
    say "🚀 Core AZL Test Starting"
    emit "test_core"
  }

  behavior {
    listen for "test_core" then {
      say "📝 Testing core functionality..."
      say "✅ Component system working"
      say "✅ Event system working"
      say "✅ Memory system working"
      emit "test_done"
    }

    listen for "test_done" then {
      say "🎉 Core test completed!"
      say "🚀 AZL language is functional!"
    }
  }
}

