say "🧪 Basic Try/Catch Test";

// Test 1: Basic try/catch with explicit throw
say "=== Test 1: Basic Try/Catch ===";
try {
    say "Inside try block";
    throw "Test exception";
    say "This should not execute";
} catch {
    say "Exception caught successfully";
}

// Test 2: Try/catch with multiple statements
say "=== Test 2: Multiple Statements ===";
try {
    say "First statement";
    say "Second statement";
    throw "Exception in middle";
    say "This should not execute";
} catch {
    say "Exception caught";
    say "Recovery successful";
}

// Test 3: Nested try/catch
say "=== Test 3: Nested Try/Catch ===";
try {
    say "Outer try block";
    try {
        say "Inner try block";
        throw "Inner exception";
    } catch {
        say "Inner exception caught";
        throw "Outer exception";
    }
} catch {
    say "Outer exception caught";
}

// Test 4: Try/catch with variables
say "=== Test 4: Try/Catch with Variables ===";
let x = 10;
try {
    say "Setting x to 20";
    set x = 20;
    throw "Exception after setting x";
    say "This should not execute";
} catch {
    say "Exception caught";
    say "x value is";
    say x;
}

say "✅ All Basic Try/Catch tests completed successfully!"; 