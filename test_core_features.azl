say "🧠 AZL v2 Core Features Test";

// ========================================
// 1. BASIC LANGUAGE FEATURES
// ========================================

say "=== 1. Basic Language Features ===";

// Variables and literals
let string_var = "Hello AZL";
let number_var = 42;
let boolean_var = true;
let null_var = null;

say "Variables working:";
say string_var;
say number_var;
say boolean_var;
say null_var;

// Arrays and objects
let test_array = [1, 2, 3, 4, 5];
let test_object = {name: "AZL", version: 2.0};

say "Data structures working:";
say test_array;
say test_object;

// ========================================
// 2. STANDARD LIBRARY
// ========================================

say "=== 2. Standard Library ===";

// Math functions
let sin_result = math.sin(3.14159);
let cos_result = math.cos(0);
let sqrt_result = math.sqrt(16);
let pow_result = math.pow(2, 8);

say "Math functions working:";
say sin_result;
say cos_result;
say sqrt_result;
say pow_result;

// String functions
let string_test = "Hello World";
let length_result = string.length(string_test);
let substring_result = string.substring(string_test, 0, 5);

say "String functions working:";
say length_result;
say substring_result;

// Array functions
let array_test = [1, 2, 3];
let push_result = array.push(array_test, 4);

say "Array functions working:";
say push_result;

// Object functions
let object_test = {a: 1, b: 2};
let keys_result = object.keys(object_test);

say "Object functions working:";
say keys_result;

// Time functions
let time_result = time.now();
say "Time functions working:";
say time_result;

// Crypto functions
let crypto_result = crypto.sha256("test");
say "Crypto functions working:";
say crypto_result;

// System functions
let system_result = system.uuid();
say "System functions working:";
say system_result;

// ========================================
// 3. AI PRIMITIVES
// ========================================

say "=== 3. AI Primitives ===";

// Memory system
let memory_result = memory.lha3.store("test_key", "test_value");
say "Memory system working:";
say memory_result;

// Quantum system
let quantum_result = quantum.superposition(0.5, 0.5);
say "Quantum system working:";
say quantum_result;

// Neural system
let neural_result = neural.forward_pass([0.1, 0.2, 0.3]);
say "Neural system working:";
say neural_result;

// ========================================
// 4. EVENT SYSTEM
// ========================================

say "=== 4. Event System ===";

emit "test_event" with "test_data";
say "Event system working";

// ========================================
// 5. COMPONENT SYSTEM
// ========================================

say "=== 5. Component System ===";

component TestComponent {
    method test_method() {
        say "Component method called";
    }
}
say "Component system working";

// ========================================
// 6. CONTROL FLOW
// ========================================

say "=== 6. Control Flow ===";

let test_condition = 5;
if test_condition > 3 {
    say "If statement working";
} else {
    say "If statement failed";
}

let loop_counter = 0;
loop {
    if loop_counter >= 3 {
        break;
    }
    say "Loop working";
    let loop_counter = loop_counter + 1;
}

say "Control flow working";

// ========================================
// 7. FUNCTION CALLS
// ========================================

say "=== 7. Function Calls ===";

let function_result = math.abs(-42);
say "Function calls working:";
say function_result;

// ========================================
// 8. DOT NOTATION
// ========================================

say "=== 8. Dot Notation ===";

let dot_result = string.length("test");
say "Dot notation working:";
say dot_result;

// ========================================
// SUMMARY
// ========================================

say "🎉 AZL v2 Core Features Test Complete!";
say "✅ Basic language features working";
say "✅ Standard library implemented";
say "✅ AI primitives working";
say "✅ Event system working";
say "✅ Component system working";
say "✅ Control flow working";
say "✅ Function calls working";
say "✅ Dot notation working";

say "🚀 AZL v2 is ready for advanced development!"; 