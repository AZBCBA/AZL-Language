say "🧪 Testing New Error System";

// Test 1: Division by zero should be caught
say "=== Test 1: Division by Zero ===";
try {
    say "Attempting division by zero...";
    let result = 10 / 0;
    say "This should not execute";
} catch {
    say "Division by zero caught successfully!";
}

// Test 2: Multiple operations with error recovery
say "=== Test 2: Error Recovery ===";
let x = 5;
let y = 0;
let z = 10;

try {
    say "Performing calculations...";
    let result1 = x * z;  // Should work
    say "First calculation successful";
    
    let result2 = x / y;  // Should cause error
    say "This should not execute";
    
    let result3 = z + x;  // Should not execute
    say "This should not execute either";
} catch {
    say "Error caught during calculations";
    say "Recovery successful";
}

// Test 3: Nested try/catch with different error types
say "=== Test 3: Nested Error Handling ===";
try {
    say "Outer try block";
    try {
        say "Inner try block";
        let division = 100 / 0;
        say "This should not execute";
    } catch {
        say "Inner division error caught";
        throw "Outer exception";
    }
} catch {
    say "Outer exception caught";
}

say "✅ Error system test completed!"; 