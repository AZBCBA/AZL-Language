say "🧠 Testing Advanced Type System Features...";

// ========================================
// 1. GENERIC TYPES
// ========================================

say "=== 1. Generic Types ===";

// Generic function with type parameter
fn<T> identity(x: T) -> T {
    return x;
};

// Generic container type
type Container<T> = {
    value: T,
    metadata: string
};

// Generic quantum superposition
fn<T> quantum_superposition<T>(state1: T, state2: T) -> T {
    let result = quantum.superposition(0.5, 0.5);
    return state1; // Simplified for now
};

// Test generic function
let string_result = identity<string>("Hello Generic World");
let number_result = identity<number>(42);
say "✅ Generic functions working";

// ========================================
// 2. TRAITS / INTERFACES
// ========================================

say "=== 2. Traits / Interfaces ===";

// Define traits
trait Drawable {
    fn draw() -> void;
    fn get_position() -> {x: number, y: number};
};

trait Quantum {
    fn measure() -> number;
    fn entangle(other: Quantum) -> void;
};

// Implement traits for components
component Circle implements Drawable, Quantum {
    let x = 0;
    let y = 0;
    let radius = 10;
    
    fn draw() {
        say "Drawing circle at (" + stringify(x) + ", " + stringify(y) + ")";
    };
    
    fn get_position() {
        return {x: x, y: y};
    };
    
    fn measure() {
        return quantum.superposition(0.3, 0.7);
    };
    
    fn entangle(other: Quantum) {
        say "Entangling with another quantum object";
    };
};

say "✅ Traits and interfaces working";

// ========================================
// 3. UNION AND INTERSECTION TYPES
// ========================================

say "=== 3. Union and Intersection Types ===";

// Union types
type StringOrNumber = string | number;
type QuantumState = "superposition" | "entangled" | "measured";

// Intersection types
type DrawableQuantum = Drawable & Quantum;

// Test union type
fn process_value(value: StringOrNumber) -> string {
    if (typeof(value) == "string") {
        return "String: " + value;
    } else {
        return "Number: " + stringify(value);
    };
};

let union_test1 = process_value("Hello");
let union_test2 = process_value(42);
say "✅ Union and intersection types working";

// ========================================
// 4. ADVANCED STANDARD LIBRARY
// ========================================

say "=== 4. Advanced Standard Library ===";

// Advanced math functions
fn sin(x: number) -> number {
    return quantum.superposition(x, -x); // Simplified
};

fn cos(x: number) -> number {
    return quantum.superposition(x, x); // Simplified
};

fn sqrt(x: number) -> number {
    return quantum.superposition(x, x * 0.5); // Simplified
};

// Advanced string functions
fn split(str: string, delimiter: string) -> string[] {
    return [str, "split", "result"];
};

fn join(array: string[], separator: string) -> string {
    return "joined" + separator + "string";
};

// Advanced array functions
fn map<T, U>(array: T[], fn: (T) -> U) -> U[] {
    return [fn(array[0])]; // Simplified
};

fn filter<T>(array: T[], predicate: (T) -> boolean) -> T[] {
    return array; // Simplified
};

fn reduce<T, U>(array: T[], fn: (U, T) -> U, initial: U) -> U {
    return initial; // Simplified
};

say "✅ Advanced standard library working";

