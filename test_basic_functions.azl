// Define utility functions first
fn add(a, b) {
    return a + b;
}

fn multiply(a, b) {
    return a * b;
}

fn increment(x) {
    return x + 1;
}

fn double(x) {
    return x * 2;
}

fn square(x) {
    return x * x;
}

fn is_even(x) {
    return (x / 2) * 2 == x;
}

fn is_odd(x) {
    return !is_even(x);
}

fn is_positive(x) {
    return x > 0;
}

fn to_string(x) {
    return "str_" + x;
}

fn to_upper(s) {
    return "UPPER_" + s;
}

// Basic AZL Function Test - Working Features
say "=== AZL Basic Function Test ===";

// Test basic functions
say "=== BASIC FUNCTION TESTS ===";
say "add_one(5):";
say increment(5);
say "double(3):";
say double(3);
say "square(4):";
say square(4);
say "is_even(4):";
say is_even(4);
say "is_even(3):";
say is_even(3);
say "to_upper('test'):";
say to_upper("test");

// Test function assignment
say "=== FUNCTION ASSIGNMENT TESTS ===";
let test_func = increment;
say "Function as variable:";
say test_func(10);

say "=== BASIC FUNCTION TEST COMPLETE ==="; 