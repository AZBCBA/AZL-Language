// Simple test of functional programming features

// Define the higher-order functions
fn map(array, transform) {
    let result = [];
    let length = array.length(array);
    let i = 0;
    
    while (i < length) {
        let element = array[i];
        let transformed = transform(element);
        result = array.push(result, transformed);
        i = i + 1;
    }
    
    return result;
}

fn filter(array, predicate) {
    let result = [];
    let length = array.length(array);
    let i = 0;
    
    while (i < length) {
        let element = array[i];
        if (predicate(element)) {
            result = array.push(result, element);
        }
        i = i + 1;
    }
    
    return result;
}

fn reduce(array, initial, reducer) {
    let result = initial;
    let length = array.length(array);
    let i = 0;
    
    while (i < length) {
        let element = array[i];
        result = reducer(result, element);
        i = i + 1;
    }
    
    return result;
}

// Define utility functions
fn double(n) {
    return n * 2;
}

fn add(a, b) {
    return a + b;
}

fn is_even(n) {
    return (n / 2) * 2 == n;
}

// Test data
let numbers = [1, 2, 3, 4, 5];

say "Original array:";
say numbers;

// Test map with a simple transformation
say "Testing map with double function:";
let doubled = map(numbers, double);
say doubled;

// Test filter with a simple predicate
say "Testing filter with is_even function:";
let evens = filter(numbers, is_even);
say evens;

// Test reduce with a simple reducer
say "Testing reduce with add function:";
let sum = reduce(numbers, 0, add);
say sum;

say "All tests completed!"; 