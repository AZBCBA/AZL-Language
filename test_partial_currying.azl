// Test Partial Application and Currying Implementation

// Basic functions for testing
let add = |x, y| x + y;
let multiply = |x, y| x * y;
let greet = |greeting, name| greeting + ", " + name + "!";

say "=== Partial Application Tests ===";

// Test partial application with built-in partial function
let add_five = partial(add, 5);
say "add_five(3) = " + add_five(3); // Should be 8

let multiply_by_ten = partial(multiply, 10);
say "multiply_by_ten(7) = " + multiply_by_ten(7); // Should be 70

let greet_hello = partial(greet, "Hello");
say "greet_hello('AZL') = " + greet_hello("AZL"); // Should be "Hello, AZL!"

say "=== Currying Tests ===";

// Test auto-currying
let curried_add = curry(add);
let add_five_curried = curried_add(5);
say "curried_add(5)(3) = " + add_five_curried(3); // Should be 8

let curried_multiply = curry(multiply);
let multiply_by_ten_curried = curried_multiply(10);
say "curried_multiply(10)(7) = " + multiply_by_ten_curried(7); // Should be 70

say "=== Higher-Order Function Tests ===";

// Test with higher-order functions
let numbers = [1, 2, 3, 4, 5];
let add_one = partial(add, 1);
let doubled = map(numbers, |x| multiply(x, 2));
say "doubled = " + doubled;

let add_five_to_all = map(numbers, add_five);
say "add_five_to_all = " + add_five_to_all;

say "=== Complex Currying Tests ===";

// Test multi-parameter currying
let complex_func = |a, b, c| a * b + c;
let curried_complex = curry(complex_func);
let partial_complex = curried_complex(2);
let partial_complex_2 = partial_complex(3);
say "complex_func(2, 3, 4) = " + partial_complex_2(4); // Should be 10

say "All partial application and currying tests completed!"; 