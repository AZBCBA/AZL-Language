[Unit]
Description=AZL Production Runtime (containerized)
After=network-online.target docker.service
Wants=network-online.target docker.service

[Service]
Type=simple
Environment=AZL_LOG_LEVEL=quiet
Environment=AZL_ENABLE_QUANTUM=1
ExecStart=/usr/bin/docker run \
  --rm \
  --name azl-prod \
  --env AZL_LOG_LEVEL=${AZL_LOG_LEVEL} \
  --env AZL_ENABLE_QUANTUM=${AZL_ENABLE_QUANTUM} \
  --log-driver json-file \
  --log-opt max-size=10m \
  --log-opt max-file=5 \
  azl:prod
ExecStop=/usr/bin/docker stop azl-prod
Restart=on-failure
RestartSec=2s
TimeoutStopSec=20

[Install]
WantedBy=multi-user.target


