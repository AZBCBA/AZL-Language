component ::test.multi.line.objects {
  init {
    # Test multi-line object literal
    set ::multi_line_object = {
      outer: {
        inner: "value"
      },
      nested: {
        deep: {
          level: "test"
        }
      }
    }
    
    # Test multi-line emit parameters
    set ::test_data = {
      success: 1,
      bits: [1, 0, 1, 0],
      bases: ["X", "Z", "X", "Z"]
    }
  }

  behavior {
    on start {
      emit test.multi_line_object_test
    }

    on test.multi_line_object_test {
      # Test multi-line emit with complex object
      emit test.multi_line_emit with {
        success: 1,
        bits: ::test_data.bits,
        bases: ::test_data.bases,
        nested: {
          deep: {
            level: "test"
          }
        }
      }
    }

    on test.multi_line_emit {
      set ::result = "Multi-line emit successful"
      emit test.multi_line_emit.completed
    }
  }
} 