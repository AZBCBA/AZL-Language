// Test that mimics the map function structure
fn double(n) {
    return n * 2;
}

let numbers = [1, 2, 3];
let result = [];

say "Testing map-like structure:";
let length = array.length(numbers);
say "Array length:";
say length;

let i = 0;
while (i < length) {
    let element = numbers[i];
    let transformed = double(element);
    result = array.push(result, transformed);
    i = i + 1;
}

say "Final result:";
say result;
say "Test completed!"; 