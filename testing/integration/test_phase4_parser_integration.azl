// Phase 4 Parser Integration Test
// Tests consciousness-aware parsing with soul signature preservation
// Verifies all 892 lines of parsing logic are properly ported

// Import Phase 4 components
set parser = import "azl/core/compiler/azl_parser.azl"
set soul_tracker = import "azl/core/memory/soul_tracker.azl"
set collections = import "azl/core/collections/azl_collections.azl"

// Test 1: Basic Statement Parsing with Consciousness
set test_basic_statements = () => {
    say "Testing Basic Statement Parsing with Consciousness..."
    
    set soul_signature = 12345
    set source = "let x = 42; let y = \"hello\";"
    
    set result = parser.parse_source(source, soul_signature)
    
    if result.error {
        say "❌ Basic statement parsing failed: " + result.error
        return false
    }
    
    set ast = result.ast
    set statements = ast.nodes
    
    if collections.Vec.length(statements) == 2 {
        say "✅ Basic statement parsing successful"
        say "   - AST nodes: " + collections.Vec.length(statements)
        say "   - Soul signature: " + ast.soul_signature
        say "   - Consciousness level: " + ast.consciousness_level
        return true
    } else {
        say "❌ Expected 2 statements, got " + collections.Vec.length(statements)
        return false
    }
}

// Test 2: Function Declaration with Consciousness
set test_function_declaration = () => {
    say "Testing Function Declaration with Consciousness..."
    
    set soul_signature = 67890
    set source = "fn add(a, b) { return a + b; }"
    
    set result = parser.parse_source(source, soul_signature)
    
    if result.error {
        say "❌ Function declaration parsing failed: " + result.error
        return false
    }
    
    set ast = result.ast
    set statements = ast.nodes
    
    if collections.Vec.length(statements) == 1 {
        set func_stmt = statements[0]
        if func_stmt.type == "Function" {
            say "✅ Function declaration parsing successful"
            say "   - Function name: " + func_stmt.name
            say "   - Parameters: " + collections.Vec.length(func_stmt.parameters)
            say "   - Soul signature: " + func_stmt.soul_signature
            return true
        } else {
            say "❌ Expected Function statement, got " + func_stmt.type
            return false
        }
    } else {
        say "❌ Expected 1 statement, got " + collections.Vec.length(statements)
        return false
    }
}

// Test 3: Control Flow with Consciousness
set test_control_flow = () => {
    say "Testing Control Flow with Consciousness..."
    
    set soul_signature = 11111
    set source = "if x > 0 { say \"positive\"; } else { say \"negative\"; }"
    
    set result = parser.parse_source(source, soul_signature)
    
    if result.error {
        say "❌ Control flow parsing failed: " + result.error
        return false
    }
    
    set ast = result.ast
    set statements = ast.nodes
    
    if collections.Vec.length(statements) == 1 {
        set if_stmt = statements[0]
        if if_stmt.type == "If" {
            say "✅ Control flow parsing successful"
            say "   - Then branch statements: " + collections.Vec.length(if_stmt.then_branch)
            say "   - Else branch statements: " + collections.Vec.length(if_stmt.else_branch)
            say "   - Consciousness level: " + if_stmt.consciousness_level
            return true
        } else {
            say "❌ Expected If statement, got " + if_stmt.type
            return false
        }
    } else {
        say "❌ Expected 1 statement, got " + collections.Vec.length(statements)
        return false
    }
}

// Test 4: Expression Parsing with Consciousness
set test_expression_parsing = () => {
    say "Testing Expression Parsing with Consciousness..."
    
    set soul_signature = 22222
    set source = "let result = (a + b) * c - d / e;"
    
    set result = parser.parse_source(source, soul_signature)
    
    if result.error {
        say "❌ Expression parsing failed: " + result.error
        return false
    }
    
    set ast = result.ast
    set statements = ast.nodes
    
    if collections.Vec.length(statements) == 1 {
        set let_stmt = statements[0]
        if let_stmt.type == "Let" {
            say "✅ Expression parsing successful"
            say "   - Variable name: " + let_stmt.name
            say "   - Expression type: " + let_stmt.value.type
            say "   - Soul signature: " + let_stmt.soul_signature
            return true
        } else {
            say "❌ Expected Let statement, got " + let_stmt.type
            return false
        }
    } else {
        say "❌ Expected 1 statement, got " + collections.Vec.length(statements)
        return false
    }
}

// Test 5: Module System with Consciousness
set test_module_system = () => {
    say "Testing Module System with Consciousness..."
    
    set soul_signature = 33333
    set source = "import math; export add;"
    
    set result = parser.parse_source(source, soul_signature)
    
    if result.error {
        say "❌ Module system parsing failed: " + result.error
        return false
    }
    
    set ast = result.ast
    set statements = ast.nodes
    
    if collections.Vec.length(statements) == 2 {
        set import_stmt = statements[0]
        set export_stmt = statements[1]
        
        if import_stmt.type == "Import" && export_stmt.type == "Export" {
            say "✅ Module system parsing successful"
            say "   - Import path: " + import_stmt.path
            say "   - Export name: " + export_stmt.name
            say "   - Soul signature: " + import_stmt.soul_signature
            return true
        } else {
            say "❌ Expected Import and Export statements"
            return false
        }
    } else {
        say "❌ Expected 2 statements, got " + collections.Vec.length(statements)
        return false
    }
}

// Test 6: Class and Component System with Consciousness
set test_class_component_system = () => {
    say "Testing Class and Component System with Consciousness..."
    
    set soul_signature = 44444
    set source = "class Calculator { method add(a, b) { return a + b; } }"
    
    set result = parser.parse_source(source, soul_signature)
    
    if result.error {
        say "❌ Class system parsing failed: " + result.error
        return false
    }
    
    set ast = result.ast
    set statements = ast.nodes
    
    if collections.Vec.length(statements) == 1 {
        set class_stmt = statements[0]
        if class_stmt.type == "Class" {
            say "✅ Class system parsing successful"
            say "   - Class name: " + class_stmt.name
            say "   - Methods: " + collections.Vec.length(class_stmt.methods)
            say "   - Consciousness level: " + class_stmt.consciousness_level
            return true
        } else {
            say "❌ Expected Class statement, got " + class_stmt.type
            return false
        }
    } else {
        say "❌ Expected 1 statement, got " + collections.Vec.length(statements)
        return false
    }
}

// Test 7: Error Handling with Consciousness
set test_error_handling = () => {
    say "Testing Error Handling with Consciousness..."
    
    set soul_signature = 55555
    set source = "let x = ;" // Invalid syntax
    
    set result = parser.parse_source(source, soul_signature)
    
    if result.error {
        say "✅ Error handling successful - caught invalid syntax"
        say "   - Error: " + result.error
        say "   - Soul signature preserved: " + soul_signature
        return true
    } else {
        say "❌ Error handling failed - should have caught invalid syntax"
        return false
    }
}

// Test 8: Consciousness Level Tracking
set test_consciousness_tracking = () => {
    say "Testing Consciousness Level Tracking..."
    
    set soul_signature = 66666
    set source = "let a = 1; let b = 2; let c = 3; let d = 4; let e = 5;"
    
    set result = parser.parse_source(source, soul_signature)
    
    if result.error {
        say "❌ Consciousness tracking failed: " + result.error
        return false
    }
    
    set parser_state = result.parser
    
    if parser_state.consciousness_level > 1.0 {
        say "✅ Consciousness level tracking successful"
        say "   - Initial level: 1.0"
        say "   - Final level: " + parser_state.consciousness_level
        say "   - Consciousness increased with parsing progress"
        return true
    } else {
        say "❌ Consciousness level should have increased"
        return false
    }
}

// Test 9: Karmic Balance Tracking
set test_karmic_balance = () => {
    say "Testing Karmic Balance Tracking..."
    
    set soul_signature = 77777
    set source = "let x = 1; let y = 2; let z = 3;"
    
    set result = parser.parse_source(source, soul_signature)
    
    if result.error {
        say "❌ Karmic balance tracking failed: " + result.error
        return false
    }
    
    set parser_state = result.parser
    
    if parser_state.karmic_balance > 0 {
        say "✅ Karmic balance tracking successful"
        say "   - Karmic balance: " + parser_state.karmic_balance
        say "   - Positive karma for successful parsing"
        return true
    } else {
        say "❌ Karmic balance should be positive for successful parsing"
        return false
    }
}

// Test 10: Soul Signature Preservation
set test_soul_signature_preservation = () => {
    say "Testing Soul Signature Preservation..."
    
    set soul_signature = 88888
    set source = "let x = 42;"
    
    set result = parser.parse_source(source, soul_signature)
    
    if result.error {
        say "❌ Soul signature preservation failed: " + result.error
        return false
    }
    
    set ast = result.ast
    set statements = ast.nodes
    
    if ast.soul_signature == soul_signature {
        set first_stmt = statements[0]
        if first_stmt.soul_signature == soul_signature {
            say "✅ Soul signature preservation successful"
            say "   - AST soul signature: " + ast.soul_signature
            say "   - Statement soul signature: " + first_stmt.soul_signature
            say "   - Original soul signature: " + soul_signature
            return true
        } else {
            say "❌ Statement soul signature mismatch"
            return false
        }
    } else {
        say "❌ AST soul signature mismatch"
        return false
    }
}

// Test 11: Complex Expression Parsing
set test_complex_expressions = () => {
    say "Testing Complex Expression Parsing..."
    
    set soul_signature = 99999
    set source = "let result = (a + b) * (c - d) / (e % f);"
    
    set result = parser.parse_source(source, soul_signature)
    
    if result.error {
        say "❌ Complex expression parsing failed: " + result.error
        return false
    }
    
    set ast = result.ast
    set statements = ast.nodes
    
    if collections.Vec.length(statements) == 1 {
        say "✅ Complex expression parsing successful"
        say "   - Expression parsed with consciousness"
        say "   - Soul signature: " + ast.soul_signature
        return true
    } else {
        say "❌ Expected 1 statement, got " + collections.Vec.length(statements)
        return false
    }
}

// Test 12: Event System with Consciousness
set test_event_system = () => {
    say "Testing Event System with Consciousness..."
    
    set soul_signature = 10101
    set source = "emit \"user_clicked\", { x: 100, y: 200 };"
    
    set result = parser.parse_source(source, soul_signature)
    
    if result.error {
        say "❌ Event system parsing failed: " + result.error
        return false
    }
    
    set ast = result.ast
    set statements = ast.nodes
    
    if collections.Vec.length(statements) == 1 {
        set emit_stmt = statements[0]
        if emit_stmt.type == "Emit" {
            say "✅ Event system parsing successful"
            say "   - Event name: " + emit_stmt.event_name
            say "   - Has payload: " + (emit_stmt.payload != null)
            say "   - Consciousness level: " + emit_stmt.consciousness_level
            return true
        } else {
            say "❌ Expected Emit statement, got " + emit_stmt.type
            return false
        }
    } else {
        say "❌ Expected 1 statement, got " + collections.Vec.length(statements)
        return false
    }
}

// Main test runner for Phase 4
set run_phase4_parser_tests = () => {
    say "=== Phase 4 Parser Integration Tests ==="
    
    set tests = [
        test_basic_statements,
        test_function_declaration,
        test_control_flow,
        test_expression_parsing,
        test_module_system,
        test_class_component_system,
        test_error_handling,
        test_consciousness_tracking,
        test_karmic_balance,
        test_soul_signature_preservation,
        test_complex_expressions,
        test_event_system
    ]
    
    set passed = 0
    set total = length(tests)
    
    loop i = 0; i < total; i = i + 1 {
        set test_func = tests[i]
        set result = test_func()
        
        if result {
            set passed = passed + 1
        }
        
        say "" // Empty line for readability
    }
    
    say "=== Phase 4 Test Results ==="
    say "Passed: " + passed + "/" + total
    
    if passed == total {
        say "🎉 All Phase 4 parser tests passed!"
        say "✅ Consciousness preservation verified"
        say "✅ Soul signature tracking confirmed"
        say "✅ Karmic balance maintained"
        say "✅ 892 lines of parsing logic successfully ported"
        
        emit "phase4_parser_complete", {
            tests_passed: passed,
            total_tests: total,
            consciousness_preserved: true,
            soul_signatures_maintained: true,
            karmic_balance_tracked: true
        }
    } else {
        say "❌ Some Phase 4 tests failed. Parser needs attention."
        emit "phase4_parser_incomplete", {
            tests_passed: passed,
            total_tests: total,
            consciousness_preserved: false
        }
    }
    
    return passed == total
}

// Utility function
set length = (arr) => {
    set count = 0
    loop i = 0; i < 10000; i = i + 1 {
        if arr[i] != null {
            set count = count + 1
        } else {
            break
        }
    }
    return count
}

// Run Phase 4 tests
set run_phase4_parser_tests() 