say "🧪 Testing Simple Module Functionality...";

module math {
    fn add(a, b) {
        return a + b;
    }
    
    fn multiply(a, b) {
        return a * b;
    }
}

say "✅ Module defined successfully";

let x = 5;
let y = 3;

let sum = math::add(x, y);
say sum;

let product = math::multiply(x, y);
say product;

say "✅ Module functions called successfully!"; 