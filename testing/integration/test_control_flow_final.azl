say "🎉 CONTROL FLOW TEST STARTING 🎉";

let x = 10;
let y = 5;

say "Testing if x > y:";
if x > y {
    say "✅ x is greater than y";
} else {
    say "❌ x is not greater than y";
}

say "Testing if x < y:";
if x < y {
    say "✅ x is less than y";
} else {
    say "❌ x is not less than y";
}

say "Testing if x == y:";
if x == y {
    say "✅ x equals y";
} else {
    say "❌ x does not equal y";
}

say "🎉 CONTROL FLOW TEST COMPLETE 🎉"; 