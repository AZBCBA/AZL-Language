// Simple function test to verify our unified bytecode implementation works

// Define a simple function
let add = (x, y) => x + y

// Test basic function call
say "Testing basic function call..."
say add(5, 3)

// Test with variables
let a = 10
let b = 20
say add(a, b)

// Test nested function calls
say add(add(1, 2), add(3, 4))

say "Function composition test completed successfully!" 