// Test Break/Continue functionality
// This test verifies that break and continue work correctly in loops

say "Testing Break/Continue functionality:";

// Test 1: Basic break in while loop
say "Test 1: Basic break in while loop";
let i = 0;
while (i < 10) {
    if (i == 5) {
        break;
    }
    say "i = " + i;
    set i = i + 1;
}
say "After break loop";

// Test 2: Basic continue in while loop
say "Test 2: Basic continue in while loop";
let j = 0;
while (j < 5) {
    set j = j + 1;
    if (j == 3) {
        continue;
    }
    say "j = " + j;
}
say "After continue loop";

// Test 3: Break in for loop
say "Test 3: Break in for loop";
for (let k = 0; k < 10; set k = k + 1) {
    if (k == 7) {
        break;
    }
    say "k = " + k;
}
say "After for loop break";

// Test 4: Continue in for loop
say "Test 4: Continue in for loop";
for (let m = 0; m < 6; set m = m + 1) {
    if (m == 2 || m == 4) {
        continue;
    }
    say "m = " + m;
}
say "After for loop continue";

// Test 5: Nested loops with break
say "Test 5: Nested loops with break";
for (let outer = 0; outer < 3; set outer = outer + 1) {
    say "Outer: " + outer;
    for (let inner = 0; inner < 5; set inner = inner + 1) {
        if (inner == 3) {
            break;
        }
        say "  Inner: " + inner;
    }
}
say "After nested break";

// Test 6: Nested loops with continue
say "Test 6: Nested loops with continue";
for (let outer = 0; outer < 3; set outer = outer + 1) {
    say "Outer: " + outer;
    for (let inner = 0; inner < 4; set inner = inner + 1) {
        if (inner == 1) {
            continue;
        }
        say "  Inner: " + inner;
    }
}
say "After nested continue";

// Test 7: Break/Continue in function
say "Test 7: Break/Continue in function";
fn test_break_continue() {
    let count = 0;
    while (count < 5) {
        set count = count + 1;
        if (count == 2) {
            continue;
        }
        if (count == 4) {
            break;
        }
        say "Function count: " + count;
    }
    return "Function completed";
}

let result = test_break_continue();
say "Function result: " + result;

// Test 8: Error cases - break/continue outside loops
say "Test 8: Error cases - break/continue outside loops";

// These should cause errors:
// break;  // Should error: break outside loop
// continue;  // Should error: continue outside loop

say "All break/continue tests completed!"; 