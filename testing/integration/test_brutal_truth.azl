say "🔍 BRUTAL TRUTH CHECK - AZL LANGUAGE CAPABILITIES";
say "";

say "=== 1. BASIC SYNTAX ===";
say "✅ say statements work";
say "✅ string literals work";
say "✅ number literals work";
say "✅ boolean literals work";
say "✅ null literals work";

say "";
say "=== 2. VARIABLES ===";
let x = 42;
let y = "hello";
let z = true;
let w = null;
say "✅ Variable declarations work";
say "x = ";
say x;
say "y = ";
say y;
say "z = ";
say z;
say "w = ";
say w;

say "";
say "=== 3. ARITHMETIC ===";
let a = 10;
let b = 5;
let sum = a + b;
let product = a * b;
let difference = a - b;
let quotient = a / b;
say "✅ Arithmetic operations work";
say "sum = ";
say sum;
say "product = ";
say product;
say "difference = ";
say difference;
say "quotient = ";
say quotient;

say "";
say "=== 4. STRING CONCATENATION ===";
let greeting = "Hello";
let world = "World";
let message = greeting + " " + world;
say "✅ String concatenation works";
say "message = ";
say message;

say "";
say "=== 5. CONTROL FLOW - IF STATEMENTS ===";
let test = 10;
if test > 5 {
    say "✅ if statements work";
} else {
    say "❌ if statements don't work";
}

say "";
say "=== 6. CONTROL FLOW - LOOPS ===";
let counter = 0;
loop counter < 3 {
    say "✅ loop statements work";
    let counter = counter + 1;
}

say "";
say "=== 7. FUNCTIONS ===";
fn add(a, b) {
    return a + b;
}
let result = add(5, 3);
say "✅ Function definitions work";
say "result = ";
say result;

say "";
say "=== 8. MODULES ===";
module math {
    fn multiply(x, y) {
        return x * y;
    }
}
let module_result = math::multiply(4, 5);
say "✅ Module system works";
say "module_result = ";
say module_result;

say "";
say "=== 9. STRUCTS ===";
struct Point {
    x: number,
    y: number
}
let point = Point { x: 10, y: 20 };
say "✅ Struct definitions work";
say "point.x = ";
say point.x;

say "";
