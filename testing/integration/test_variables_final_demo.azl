say "🎉 AZL Variables are FULLY WORKING! 🎉";
say "";

say "=== BASIC VARIABLES ===";
let name = "AZL";
let version = 2.0;
let is_awesome = true;
let nothing = null;

say "name = ";
say name;
say "version = ";
say version;
say "is_awesome = ";
say is_awesome;
say "nothing = ";
say nothing;

say "";
say "=== ARITHMETIC WITH VARIABLES ===";
let a = 10;
let b = 5;
let sum = a + b;
let product = a * b;
let difference = a - b;
let quotient = a / b;

say "a = ";
say a;
say "b = ";
say b;
say "sum = a + b = ";
say sum;
say "product = a * b = ";
say product;
say "difference = a - b = ";
say difference;
say "quotient = a / b = ";
say quotient;

say "";
say "=== STRING CONCATENATION ===";
let greeting = "Hello";
let world = "World";
let message = greeting + " " + world + " from " + name + " v" + version;

say "greeting = ";
say greeting;
say "world = ";
say world;
say "message = ";
say message;

say "";
say "=== VARIABLE REASSIGNMENT ===";
let counter = 0;
say "counter = ";
say counter;
let counter = counter + 1;
say "counter = counter + 1 = ";
say counter;
let counter = counter + 5;
say "counter = counter + 5 = ";
say counter;

say "";
say "=== COMPLEX EXPRESSIONS ===";
let x = 100;
let y = 50;
let result = x + y * 2;
say "x = ";
say x;
say "y = ";
say y;
say "result = x + y * 2 = ";
say result;

say "";
say "=== STRING + NUMBER CONCATENATION ===";
let score = 95;
let grade = "A";
let report = "Your grade is " + grade + " with a score of " + score;
say "score = ";
say score;
say "grade = ";
say grade;
say "report = ";
say report;

say "";
say "🎯 AZL Variables are PRODUCTION READY! 🎯"; 