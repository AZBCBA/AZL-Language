// Test for unified addition operations
// This test verifies that ALL addition operations use the unified add_values helper
// and produce consistent error messages with debug prints

// Test 1: Basic number + number
let result1 = 5 + 3;
say "Number + Number: " + result1;

// Test 2: String + string
let result2 = "Hello" + " World";
say "String + String: " + result2;

// Test 3: String + number
let result3 = "Value: " + 42;
say "String + Number: " + result3;

// Test 4: Number + string
let result4 = 100 + " dollars";
say "Number + String: " + result4;

// Test 5: String + boolean
let result5 = "Status: " + true;
say "String + Boolean: " + result5;

// Test 6: Boolean + string
let result6 = false + " is the answer";
say "Boolean + String: " + result6;

// Test 7: String + null
let result7 = "Value: " + null;
say "String + Null: " + result7;

// Test 8: Null + string
let result8 = null + " is null";
say "Null + String: " + result8;

// Test 9: String + array
let result9 = "Array: " + [1, 2, 3];
say "String + Array: " + result9;

// Test 10: Array + string
let result10 = ["a", "b"] + " end";
say "Array + String: " + result10;

// Test 11: String + object
let result11 = "Object: " + {name: "test", value: 123};
say "String + Object: " + result11;

// Test 12: Object + string
let result12 = {x: 1, y: 2} + " coordinates";
say "Object + String: " + result12;

// Test 13: String + function
fn test_function() {
    return "test";
}
let result13 = "Function: " + test_function;
say "String + Function: " + result13;

// Test 14: Function + string
let result14 = test_function + " result";
say "Function + String: " + result14;

// Test 15: Error cases - should all use the same error message
// These should all fail with "Can only add numbers, strings, or convert other types to strings"

// Test 15a: Number + boolean (should error)
try {
    let error1 = 5 + true;
    say "ERROR: Should have failed";
} catch {
    say "Expected error: " + error;
}

// Test 15b: Boolean + number (should error)
try {
    let error2 = true + 5;
    say "ERROR: Should have failed";
} catch {
    say "Expected error: " + error;
}

// Test 15c: Number + null (should error)
try {
    let error3 = 10 + null;
    say "ERROR: Should have failed";
} catch {
    say "Expected error: " + error;
}

// Test 15d: Null + number (should error)
try {
    let error4 = null + 10;
    say "ERROR: Should have failed";
} catch {
    say "Expected error: " + error;
}

// Test 15e: Boolean + boolean (should error)
try {
    let error5 = true + false;
    say "ERROR: Should have failed";
} catch {
    say "Expected error: " + error;
}

// Test 15f: Array + array (should error)
try {
    let error6 = [1, 2] + [3, 4];
    say "ERROR: Should have failed";
} catch {
    say "Expected error: " + error6;
}

// Test 15g: Object + object (should error)
try {
    let error7 = {a: 1} + {b: 2};
    say "ERROR: Should have failed";
} catch {
    say "Expected error: " + error7;
}

// Test 15h: Function + function (should error)
try {
    let error8 = test_function + test_function;
    say "ERROR: Should have failed";
} catch {
    say "Expected error: " + error8;
}

// Test 16: Addition inside function calls
fn add_test(a, b) {
    return a + b;
}

let result16a = add_test("Hello", " World");
say "Function call addition: " + result16a;

let result16b = add_test(10, 20);
say "Function call number addition: " + result16b;

// Test 17: Addition with variables
let x = 10;
let y = " apples";
let result18 = x + y;
say "Variable addition: " + result18;

say "All addition tests completed successfully!";
say "All error messages should be consistent: 'Can only add numbers, strings, or convert other types to strings'";
say "Debug prints should show the exact values that caused errors"; 