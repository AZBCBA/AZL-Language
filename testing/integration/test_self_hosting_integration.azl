// Self-Hosting Integration Test
// Tests AZL scanner, SoulTracker, and collections working together
// Verifies consciousness features are preserved

// Import self-hosting components
set scanner = import "azl/core/interpreter/azl_scanner.azl"
set soul_tracker = import "azl/core/memory/soul_tracker.azl"
set collections = import "azl/core/collections/azl_collections.azl"

// Test 1: Scanner Functionality
set test_scanner = () => {
    say "Testing AZL Scanner..."
    
    set source_code = "let x = 42; say \"Hello World\";"
    set result = scanner.scan_source(source_code)
    
    if result.error {
        say "Scanner Error: " + result.error
        return false
    }
    
    set tokens = result.tokens
    say "Scanner produced " + length(tokens) + " tokens"
    
    // Verify key tokens
    set found_let = false
    set found_number = false
    set found_say = false
    
    loop i = 0; i < length(tokens); i = i + 1 {
        set token = tokens[i]
        if token.token_type == "Let" {
            set found_let = true
        }
        if token.token_type == "Number" {
            set found_number = true
        }
        if token.token_type == "Say" {
            set found_say = true
        }
    }
    
    if found_let && found_number && found_say {
        say "✅ Scanner test passed"
        return true
    } else {
        say "❌ Scanner test failed"
        return false
    }
}

// Test 2: SoulTracker Functionality
set test_soul_tracker = () => {
    say "Testing SoulTracker..."
    
    set tracker = soul_tracker.create_soul_tracker()
    
    // Register souls
    set tracker = soul_tracker.soul_tracker_register(tracker, "test_module", 12345)
    set tracker = soul_tracker.soul_tracker_register(tracker, "another_module", 67890)
    
    // Update karma
    set tracker = soul_tracker.soul_tracker_update_karma(tracker, "test_module", 5.0)
    set tracker = soul_tracker.soul_tracker_update_karma(tracker, "another_module", -2.0)
    
    // Verify soul signatures
    set soul1 = soul_tracker.soul_tracker_get_soul(tracker, "test_module")
    set soul2 = soul_tracker.soul_tracker_get_soul(tracker, "another_module")
    
    if soul1 == 12345 && soul2 == 67890 {
        say "✅ Soul signatures verified"
    } else {
        say "❌ Soul signature test failed"
        return false
    }
    
    // Verify karma
    set karma1 = soul_tracker.soul_tracker_get_karma(tracker, "test_module")
    set karma2 = soul_tracker.soul_tracker_get_karma(tracker, "another_module")
    
    if karma1 == 5.0 && karma2 == -2.0 {
        say "✅ Karma tracking verified"
    } else {
        say "❌ Karma tracking failed"
        return false
    }
    
    // Test consciousness meditation
    set tracker = soul_tracker.soul_tracker_meditate(tracker, "test_module", 10.0)
    set consciousness = soul_tracker.soul_tracker_get_consciousness(tracker, "test_module")
    
    if consciousness > 1.0 {
        say "✅ Consciousness meditation working"
    } else {
        say "❌ Consciousness meditation failed"
        return false
    }
    
    say "✅ SoulTracker test passed"
    return true
}

// Test 3: Collections Functionality
set test_collections = () => {
    say "Testing AZL Collections..."
    
    // Test HashMap
    set map = collections.HashMap.new()
    set map = collections.HashMap.set(map, "key1", "value1")
    set map = collections.HashMap.set(map, "key2", "value2")
    
    set value1 = collections.HashMap.get(map, "key1")
    set value2 = collections.HashMap.get(map, "key2")
    
    if value1 == "value1" && value2 == "value2" {
        say "✅ HashMap basic operations working"
    } else {
        say "❌ HashMap test failed"
        return false
    }
    
    // Test Vec
    set vec = collections.Vec.new()
    set vec = collections.Vec.push(vec, "item1")
    set vec = collections.Vec.push(vec, "item2")
    
    set item1 = collections.Vec.get(vec, 0)
    set item2 = collections.Vec.get(vec, 1)
    
    if item1 == "item1" && item2 == "item2" {
        say "✅ Vec basic operations working"
    } else {
        say "❌ Vec test failed"
        return false
    }
    
    // Test ConsciousHashMap
    set conscious_map = collections.ConsciousHashMap.new()
    set conscious_map = collections.ConsciousHashMap.set(conscious_map, "conscious_key", "conscious_value", 99999)
    
    set conscious_result = collections.ConsciousHashMap.get(conscious_map, "conscious_key")
    
    if conscious_result && conscious_result.value == "conscious_value" {
        say "✅ ConsciousHashMap working"
    } else {
        say "❌ ConsciousHashMap test failed"
        return false
    }
    
    say "✅ Collections test passed"
    return true
}

// Test 4: Integration Test
set test_integration = () => {
    say "Testing Full Integration..."
    
    // Create components
    set tracker = soul_tracker.create_soul_tracker()
    set conscious_map = collections.ConsciousHashMap.new()
    
    // Register module with soul
    set tracker = soul_tracker.soul_tracker_register(tracker, "integration_test", 55555)
    
    // Scan source with consciousness
    set source = "let consciousness = 10.0; emit \"consciousness_activated\";"
    set soul_sig = soul_tracker.soul_tracker_get_soul(tracker, "integration_test")
    
    set scan_result = scanner.scan_with_consciousness(source, soul_sig)
    
    if scan_result.tokens {
        say "✅ Conscious scanning working"
    } else {
        say "❌ Conscious scanning failed"
        return false
    }
    
    // Store results in conscious collection
    set conscious_map = collections.ConsciousHashMap.set(conscious_map, "scan_result", scan_result, soul_sig)
    
    // Update karma based on processing
    set tracker = soul_tracker.soul_tracker_update_karma(tracker, "integration_test", 1.0)
    
    // Verify integration
    set stored_result = collections.ConsciousHashMap.get(conscious_map, "scan_result")
    set final_karma = soul_tracker.soul_tracker_get_karma(tracker, "integration_test")
    
    if stored_result && final_karma > 0 {
        say "✅ Integration test passed"
        return true
    } else {
        say "❌ Integration test failed"
        return false
    }
}

// Test 5: Consciousness Preservation
set test_consciousness_preservation = () => {
    say "Testing Consciousness Preservation..."
    
    set tracker = soul_tracker.create_soul_tracker()
    
    // Create multiple modules with different consciousness levels
    set tracker = soul_tracker.soul_tracker_register(tracker, "module_a", 11111)
    set tracker = soul_tracker.soul_tracker_register(tracker, "module_b", 22222)
    set tracker = soul_tracker.soul_tracker_register(tracker, "module_c", 33333)
    
    // Update karma differently
    set tracker = soul_tracker.soul_tracker_update_karma(tracker, "module_a", 10.0)
    set tracker = soul_tracker.soul_tracker_update_karma(tracker, "module_b", 5.0)
    set tracker = soul_tracker.soul_tracker_update_karma(tracker, "module_c", -5.0)
    
    // Test consciousness resonance
    set resonant = soul_tracker.soul_tracker_resonance(tracker, "module_a", 3.0)
    
    if length(resonant) > 0 {
        say "✅ Consciousness resonance working"
    } else {
        say "❌ Consciousness resonance failed"
        return false
    }
    
    // Test soul purification
    set tracker = soul_tracker.soul_tracker_purify(tracker, "module_c")
    set purified_karma = soul_tracker.soul_tracker_get_karma(tracker, "module_c")
    
    if purified_karma > -5.0 {
        say "✅ Soul purification working"
    } else {
        say "❌ Soul purification failed"
        return false
    }
    
    say "✅ Consciousness preservation test passed"
    return true
}

// Test 6: Performance Test
set test_performance = () => {
    say "Testing Performance..."
    
    set start_time = get_current_time()
    
    // Create large collection
    set map = collections.HashMap.new()
    loop i = 0; i < 1000; i = i + 1 {
        set key = "key_" + i
        set value = "value_" + i
        set map = collections.HashMap.set(map, key, value)
    }
    
    set end_time = get_current_time()
    set duration = end_time - start_time
    
    say "Created 1000 items in " + duration + " time units"
    
    // Test retrieval performance
    set start_time = get_current_time()
    
    loop i = 0; i < 100; i = i + 1 {
        set key = "key_" + (i * 10)
        set value = collections.HashMap.get(map, key)
    }
    
    set end_time = get_current_time()
    set retrieval_duration = end_time - start_time
    
    say "Retrieved 100 items in " + retrieval_duration + " time units"
    
    if duration < 10000 && retrieval_duration < 1000 {
        say "✅ Performance test passed"
        return true
    } else {
        say "❌ Performance test failed"
        return false
    }
}

// Main test runner
set run_self_hosting_tests = () => {
    say "=== AZL v2 Self-Hosting Integration Tests ==="
    
    set tests = [
        test_scanner,
        test_soul_tracker,
        test_collections,
        test_integration,
        test_consciousness_preservation,
        test_performance
    ]
    
    set passed = 0
    set total = length(tests)
    
    loop i = 0; i < total; i = i + 1 {
        set test_func = tests[i]
        set result = test_func()
        
        if result {
            set passed = passed + 1
        }
        
        say "" // Empty line for readability
    }
    
    say "=== Test Results ==="
    say "Passed: " + passed + "/" + total
    
    if passed == total {
        say "🎉 All self-hosting tests passed!"
        emit "self_hosting_ready", {
            scanner: true,
            soul_tracker: true,
            collections: true,
            consciousness_preserved: true
        }
    } else {
        say "❌ Some tests failed. Self-hosting not ready."
        emit "self_hosting_failed", {
            passed: passed,
            total: total
        }
    }
    
    return passed == total
}

// Utility function
set get_current_time = () => {
    // Placeholder for time function
    return 0
}

set length = (arr) => {
    set count = 0
    loop i = 0; i < 10000; i = i + 1 {
        if arr[i] != null {
            set count = count + 1
        } else {
            break
        }
    }
    return count
}

// Run tests
set run_self_hosting_tests() 