say "🎯 CONTROL FLOW TEST - AZL IF/ELSE AND LOOPS";
say "";

say "=== 1. BASIC IF STATEMENTS ===";
let x = 10;
let y = 5;

if x > y {
    say "✅ x is greater than y";
} else {
    say "❌ x is not greater than y";
}

if x < y {
    say "❌ x is less than y";
} else {
    say "✅ x is not less than y";
}

say "";
say "=== 2. IF/ELSE WITH VARIABLES ===";
let score = 85;

if score >= 90 {
    say "Grade: A";
} else if score >= 80 {
    say "Grade: B";
} else if score >= 70 {
    say "Grade: C";
} else {
    say "Grade: F";
}

say "";
say "=== 3. COMPLEX CONDITIONS ===";
let age = 25;
let has_license = true;

if age >= 18 && has_license {
    say "✅ Can drive";
} else {
    say "❌ Cannot drive";
}

if age < 18 || !has_license {
    say "❌ Cannot drive (alternative check)";
} else {
    say "✅ Can drive (alternative check)";
}

say "";
say "=== 4. LOOP WITH COUNTER ===";
let counter = 0;
let max_count = 5;

loop counter < max_count {
    say "Counter: ";
    say counter;
    let counter = counter + 1;
}

say "";
say "=== 5. LOOP WITH BREAK ===";
let i = 0;
let target = 3;

loop i < 10 {
    say "Loop iteration: ";
    say i;
    
    if i == target {
        say "Found target! Breaking...";
        break;
    }
    
    let i = i + 1;
}

say "";
say "=== 6. NESTED CONTROL FLOW ===";
let outer = 1;
let inner = 0;

if outer > 0 {
    say "Outer condition is true";
    
    if inner == 0 {
        say "Inner condition is also true";
    } else {
        say "Inner condition is false";
    }
} else {
    say "Outer condition is false";
}

say "";
say "=== 7. STRING COMPARISONS ===";
let name = "AZL";
let expected = "AZL";

if name == expected {
    say "✅ String comparison works!";
} else {
    say "❌ String comparison failed";
}

say "";
say "=== 8. ARITHMETIC IN CONDITIONS ===";
let a = 10;
let b = 5;
let c = 15;

if a + b == c {
    say "✅ Arithmetic in conditions works!";
} else {
    say "❌ Arithmetic in conditions failed";
}

if a * b == 50 {
    say "✅ Multiplication in conditions works!";
} else {
    say "❌ Multiplication in conditions failed";
}

say "";
say "🎉 CONTROL FLOW TEST COMPLETE!"; 