// Test Arrays and Objects functionality
say "Testing Arrays and Objects...";

// Test basic array creation and access
let arr = [1, 2, 3, 4, 5];
say "Array: " + arr;
say "Array length: " + arr;

// Test array with mixed types
let mixed_arr = [1, "hello", true, 3.14];
say "Mixed array: " + mixed_arr;

// Test array with variables
let x = 10;
let y = 20;
let dynamic_arr = [x, y, x + y];
say "Dynamic array: " + dynamic_arr;

// Test basic object creation and access
let person = {
    "name": "Alice",
    "age": 30,
    "city": "New York"
};
say "Person object: " + person;
say "Person name: " + person.name;
say "Person age: " + person.age;

// Test object with mixed types
let config = {
    "enabled": true,
    "port": 8080,
    "host": "localhost",
    "timeout": 30.5
};
say "Config object: " + config;
say "Config enabled: " + config.enabled;
say "Config port: " + config.port;

// Test object property assignment
person.age = 31;
say "Updated person age: " + person.age;

// Test nested objects
let company = {
    "name": "TechCorp",
    "employees": {
        "count": 100,
        "departments": ["Engineering", "Sales", "Marketing"]
    }
};
say "Company: " + company;
say "Employee count: " + company.employees.count;

// Test arrays of objects
let users = [
    {"name": "Bob", "age": 25},
    {"name": "Charlie", "age": 35},
    {"name": "Diana", "age": 28}
];
say "Users array: " + users;

// Test objects with arrays
let product = {
    "name": "Laptop",
    "tags": ["electronics", "computer", "portable"],
    "specs": {
        "cpu": "Intel i7",
        "ram": "16GB",
        "storage": ["256GB SSD", "1TB HDD"]
    }
};
say "Product: " + product;
say "Product tags: " + product.tags;

// Test complex nested structures
let data = {
    "users": [
        {"id": 1, "name": "Alice", "roles": ["admin", "user"]},
        {"id": 2, "name": "Bob", "roles": ["user"]},
        {"id": 3, "name": "Charlie", "roles": ["moderator", "user"]}
    ],
    "settings": {
        "theme": "dark",
        "notifications": {
            "email": true,
            "push": false,
            "sms": true
        }
    }
};
say "Complex data structure: " + data;

// Test array operations with objects
let scores = [
    {"player": "Alice", "score": 100},
    {"player": "Bob", "score": 85},
    {"player": "Charlie", "score": 120}
];

say "Scores: " + scores;

// Test object with function calls
fn get_greeting(name) {
    return "Hello, " + name + "!";
}

let user_profile = {
    "name": "Alice",
    "greeting": get_greeting("Alice")
};
say "User profile: " + user_profile;

// Test array indexing and object property access
let matrix = [
    [1, 2, 3],
    [4, 5, 6],
    [7, 8, 9]
];
say "Matrix: " + matrix;

let settings = {
    "display": {
        "width": 1920,
        "height": 1080,
        "refresh_rate": 60
    },
    "audio": {
        "volume": 75,
        "muted": false
    }
};
say "Settings: " + settings;
say "Display width: " + settings.display.width;
say "Audio volume: " + settings.audio.volume;

say "Arrays and Objects test complete!"; 