// Test Function Composition and Piping
// This test verifies that higher-order functions work properly

// Define some simple functions
let add = (x, y) => x + y
let multiply = (x, y) => x * y
let square = (x) => x * x
let double = (x) => x * 2
let increment = (x) => x + 1

// Test basic function calls
say "Testing basic function calls..."
say add(5, 3)
say multiply(4, 6)
say square(7)
say double(10)
say increment(15)

// Test function composition
let compose = (f, g) => (x) => f(g(x))

let addThenSquare = compose(square, add)
let doubleThenIncrement = compose(increment, double)

say "Testing function composition..."
say addThenSquare(3, 4)  // Should be (3+4)^2 = 49
say doubleThenIncrement(5)  // Should be (5*2)+1 = 11

// Test piping
let pipe = (value, ...functions) => {
    let result = value
    for (let i = 0; i < functions.length; i = i + 1) {
        result = functions[i](result)
    }
    return result
}

say "Testing piping..."
let result1 = pipe(5, double, increment, square)
say result1  // Should be ((5*2)+1)^2 = 121

let result2 = pipe(3, increment, square, double)
say result2  // Should be ((3+1)^2)*2 = 32

// Test with lambda expressions
let result3 = pipe(10, (x) => x * 3, (x) => x + 5, (x) => x * x)
say result3  // Should be ((10*3)+5)^2 = 1225

say "Function composition and piping tests completed!" 