say "🔍 STACK DEBUG TEST STARTING 🔍";

let x = 10;
let y = 5;

say "Before if statement - x = ";
say x;
say "Before if statement - y = ";
say y;

if x > y {
    say "✅ Inside if branch - x is greater than y";
} else {
    say "❌ Inside else branch - x is not greater than y";
}

say "After if statement - should reach here without stack underflow";
say "Final x value = ";
say x;
say "Final y value = ";
say y;

say "🔍 STACK DEBUG TEST COMPLETE 🔍"; 