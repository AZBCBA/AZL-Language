{
  "project_name": "AZL/AZME GPU-Accelerated Training System",
  "dataset": {
    "name": "azl_azme",
    "path": "datasets/azl_azme_training/azl_azme_training_data.txt",
    "type": "text",
    "preprocessing": {
      "min_length": 50,
      "max_length": 2000,
      "val_split": 0.1
    },
    "processed": {
      "train": "datasets/azl_azme_training/azl_azme_training_data.txt",
      "validation": "datasets/azl_azme_training/azl_azme_training_data.txt",
      "total_samples": 534
    }
  },
  "model": {
    "architecture": "gpt_mini",
    "custom_params": {},
    "save_name": "azl_azme_gpu_trained_model",
    "config": {
      "model_type": "transformer",
      "vocab_size": 32000,
      "hidden_size": 768,
      "num_layers": 12,
      "num_heads": 12,
      "max_seq_length": 1024,
      "dropout": 0.1,
      "activation": "gelu",
      "normalization": "layer_norm"
    }
  },
  "training": {
    "continuous": true,
    "max_epochs": 0,
    "steps_per_epoch": 5000,
    "learning_rate": 0.0001,
    "batch_size": 8,
    "checkpoint_every": 200,
    "gpu_acceleration": true,
    "multi_gpu": false,
    "gpu_memory_fraction": 0.7,
    "multi_gpu_similarity_threshold": 1.5,
    "prefer_gpu_index": 0,
    "use_torch_compile": true,
    "compile_mode": "max-autotune",
    "amp_dtype": "auto",
    "optimizer": {
      "fused": true,
      "betas": [
        0.9,
        0.95
      ],
      "weight_decay": 0.01
    }
  },
  "paths": {
    "weights_dir": "/mnt/ssd4t/azl-training/weights",
    "logs_dir": "/mnt/ssd4t/azl-training/logs",
    "checkpoints_dir": "/mnt/ssd4t/azl-training/checkpoints"
  },
  "tokenizer": {
    "type": "sentencepiece",
    "path": "tokenizers/azl_azme_spm.model",
    "vocab_size": 8000
  },
  "supervised": {
    "event_prediction": "tools/event_eval.jsonl",
    "weight": 0.7,
    "batch_size": 16,
    "max_len": 256,
    "only": true,
    "lha3_max_support": 2,
    "lha3_sep": "\n\n",
    "eval_max_tokens": 50,
    "eval_temperature": 0.5,
    "eval_top_k": 50,
    "eval_top_p": 0.9
  },
  "quantum": {
    "enabled": false,
    "endpoint": "",
    "timeout_ms": 1000
  }
}