component ::test.quantum_digital_signatures {
  init {
    set ::test_results = {}
  }

  behavior {
    on start {
      # Test complete quantum digital signatures protocol
      emit processor.run_quantum_digital_signatures
      
      # Test individual QDS methods
      emit processor.qds_generate_keys
      emit processor.qds_sign_message
      emit processor.qds_verify_signature
      emit processor.qds_detect_tampering
      emit processor.qds_detect_forgery
      emit processor.qds_authenticate_identity
    }

    on qds.key_generated {
      set ::key_info = $1
      set ::test_results.key_generation = {
        success: 1,
        sk: ::key_info.sk,
        vk: ::key_info.vk
      }
      emit test.key_generation.completed
    }

    on qds.message_signed {
      set ::sign_info = $1
      set ::test_results.message_signing = {
        message: ::sign_info.message,
        signature: ::sign_info.signature
      }
      emit test.message_signing.completed
    }

    on qds.signature_verified {
      set ::verify_info = $1
      set ::test_results.signature_verification = {
        message: ::verify_info.message,
        result: ::verify_info.result
      }
      emit test.signature_verification.completed
    }

    on qds.message_tampered_detected {
      set ::tamper_info = $1
      set ::test_results.tampering_detection = {
        original_message: ::tamper_info.original_message,
        tampered_message: ::tamper_info.tampered_message,
        signature: ::tamper_info.signature
      }
      emit test.tampering_detection.completed
    }

    on qds.forgery_detected {
      set ::forgery_info = $1
      set ::test_results.forgery_detection = {
        message: ::forgery_info.message,
        forged_signature: ::forgery_info.forged_signature,
        public_key: ::forgery_info.public_key
      }
      emit test.forgery_detection.completed
    }

    on qds.authenticated_identity {
      set ::identity_info = $1
      set ::test_results.identity_authentication = {
        identity: ::identity_info.identity,
        signature: ::identity_info.signature,
        public_key: ::identity_info.public_key
      }
      emit test.identity_authentication.completed
    }

    on qds.complete {
      set ::test_results.quantum_digital_signatures_complete = 1
      emit test.quantum_digital_signatures.completed with ::test_results
    }
  }
}

# Test quantum certificate authority
component ::test.quantum_certificate_authority {
  behavior {
    on start {
      # Test quantum certificate authority
      emit test.qca_operation
    }

    on test.qca_operation {
      emit processor.qds_quantum_certificate_authority
    }

    on qds.certificate_authority {
      set ::ca_info = $1
      set ::test_results.quantum_certificate_authority = {
        ca_public_key: ::ca_info.ca_public_key,
        user_public_key: ::ca_info.user_public_key,
        certificate_signature: ::ca_info.certificate_signature
      }
      emit test.quantum_certificate_authority.completed
    }
  }
}

