component ::test.post_quantum_key_exchange {
  init {
    set ::test_results = {}
  }

  behavior {
    on start {
      # Test complete post-quantum key exchange protocol
      emit processor.run_post_quantum_key_exchange
      
      # Test individual PQKE methods
      emit processor.pqke_generate_alice_keys
      emit processor.pqke_generate_bob_keys
      emit processor.pqke_initiate_kyber
      emit processor.pqke_derive_shared_secret
      emit processor.pqke_generate_dilithium_signature
      emit processor.pqke_verify_dilithium_signature
      emit processor.pqke_verify_shared_secret
      emit processor.pqke_check_classic_fallback
    }

    on pqke.alice_keys_generated {
      set ::alice_info = $1
      set ::test_results.alice_keys = {
        success: 1,
        alice_pk: ::alice_info.alice_pk,
        alice_sk: ::alice_info.alice_sk
      }
      emit test.alice_keys.completed
    }

    on pqke.bob_keys_generated {
      set ::bob_info = $1
      set ::test_results.bob_keys = {
        success: 1,
        bob_pk: ::bob_info.bob_pk,
        bob_sk: ::bob_info.bob_sk
      }
      emit test.bob_keys.completed
    }

    on pqke.kyber_initiated {
      set ::kyber_info = $1
      set ::test_results.kyber_initiation = {
        alice_pk: ::kyber_info.alice_pk,
        bob_pk: ::kyber_info.bob_pk,
        ciphertext: ::kyber_info.ciphertext
      }
      emit test.kyber_initiation.completed
    }

    on pqke.kyber_shared_secret_derived {
      set ::shared_info = $1
      set ::test_results.shared_secret_derivation = {
        shared_key: ::shared_info.shared_key,
        key_length: ::shared_info.key_length
      }
      emit test.shared_secret_derivation.completed
    }

    on pqke.dilithium_signature_generated {
      set ::signature_info = $1
      set ::test_results.dilithium_signature = {
        message: ::signature_info.message,
        signature: ::signature_info.signature,
        signer: ::signature_info.signer
      }
      emit test.dilithium_signature.completed
    }

    on pqke.dilithium_used_for_auth {
      set ::auth_info = $1
      set ::test_results.dilithium_authentication = {
        signature: ::auth_info.signature,
        verified: ::auth_info.verified
      }
      emit test.dilithium_authentication.completed
    }

    on pqke.shared_secret_verified {
      set ::verify_info = $1
      set ::test_results.shared_secret_verification = {
        key_id: ::verify_info.key_id,
        validity: ::verify_info.validity,
        key_length: ::verify_info.key_length
      }
      emit test.shared_secret_verification.completed
    }

    on pqke.classic_checked {
      set ::classic_info = $1
      set ::test_results.classic_fallback = {
        rsa_support: ::classic_info.rsa_support,
        ecc_support: ::classic_info.ecc_support,
        hybrid_mode: ::classic_info.hybrid_mode
      }
      emit test.classic_fallback.completed
    }

    on pqke.complete {
      set ::test_results.post_quantum_key_exchange_complete = 1
      emit test.post_quantum_key_exchange.completed with ::test_results
    }
  }
}

# Test quantum-resistant messaging
component ::test.quantum_resistant_messaging {
  behavior {
    on start {
      # Test quantum-resistant messaging
      emit test.quantum_resistant_messaging_operation
    }

    on test.quantum_resistant_messaging_operation {
      emit processor.pqke_quantum_resistant_messaging
    }

    on pqke.quantum_resistant_message_encrypted {
      set ::message_info = $1
      set ::test_results.quantum_resistant_messaging = {
        original_message: ::message_info.original_message,
        encrypted_message: ::message_info.encrypted_message,
        shared_key: ::message_info.shared_key
      }
      emit test.quantum_resistant_messaging.completed
    }
  }
}

