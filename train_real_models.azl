    say "✅ ALL EXISTING COMPONENTS INITIALIZED - STARTING COMPLETE ECOSYSTEM TRAINING"
    say "🧠 AZME Integration Status: 100% COMPLETE"
    say "🔗 Quantum Consciousness: ACTIVE"
    say "🧠 LHA3 Memory: ACTIVE"
    say "⚡ Quantum AI Pipeline: ACTIVE"
    say "🎯 Real Dataset Integration: ACTIVE"
    say "🚀 Orchestrator Pipeline: CONNECTED"
    say "🧠 AZME Neural Integration: ACTIVE"
    say "🎯 AZME ABA Integration: ACTIVE"
    say "⚡ AZME Quantum Optimizer: ACTIVE"
    say "📊 Utils Loss Plotter: ACTIVE"
    say "🚫 Redundant Components: REMOVED"
    # Prefer orchestrator-driven advanced pipeline over legacy local loop when datasets are available
    link ::azl.system_interface
    # Real dataset files (JSONL) local to repository
    set ::dataset_candidates = [
      "/home/abdulrahman-alzalameh/azl-language/mnt/data/wikipedia_en.jsonl",
      "/home/abdulrahman-alzalameh/azl-language/mnt/data/fineweb_edu.jsonl",
      "/home/abdulrahman-alzalameh/azl-language/mnt/data/c4_en.jsonl",
      "/home/abdulrahman-alzalameh/azl-language/mnt/data/wikitext.jsonl"
    ]
    set ::dataset_list = []
    # Use available datasets directly
    set ::dataset_list = [
      "/home/abdulrahman-alzalameh/azl-language/mnt/data/wikipedia_en.jsonl",
      "/home/abdulrahman-alzalameh/azl-language/mnt/data/fineweb_edu.jsonl"
    ]
    # Mode switch via env: orchestrator (default) or legacy local training loop
    set ::rm_mode = (::internal.env("AZL_TRAIN_RM_MODE") or "orchestrator")
    if (::rm_mode == "orchestrator" && ::dataset_list.length > 0) {
      say "🚀 Using orchestrator advanced pipeline for datasets ("; say ::dataset_list.length; say ")"
      emit "start_advanced_training_from_list"
    } else {
      emit "start_real_model_training"
    }
  }
  listen for "start_advanced_training_from_list" {
    # Configure from env (with sensible defaults)
    set ::adv_device = (::internal.env("AZL_DEVICE") or "cuda")
    set ::adv_gpu_limit = parseInt((::internal.env("AZL_GPU_LIMIT") or "95"))
    set ::adv_epochs = parseInt((::internal.env("AZL_EPOCHS") or "1"))
    set ::adv_batch = parseInt((::internal.env("AZL_BATCH") or "1"))
    set ::ds_index = 0
    say "📦 Dataset queue length: "; say ::dataset_list.length
    emit "rm.next_dataset"
  }

  listen for "rm.next_dataset" {
    if (::ds_index >= ::dataset_list.length) {
      say "🎉 All datasets completed via orchestrator advanced pipeline"
      return
    }
    set ::current_ds = ::dataset_list[::ds_index]
    say "🎯 Starting advanced pipeline on: "; say ::current_ds
    # Start REAL GPU training via FFI bridge for this dataset
    say "🚀 Launching real GPU training via FFI on: " + ::current_ds
    emit "train_file" to ::ffi.torch with {
      data_path: ::current_ds,
      device: (::adv_device or "cuda"),
      steps: parseInt((::internal.env("AZL_STEPS") or "200000")),
      batch_size: ::adv_batch,
      seq_len: parseInt((::internal.env("AZL_SEQ") or "2048")),
      lr: 0.0003,
      save: ("weights/mini_llm_ffi_" + ::ds_index.toString() + ".pt"),
      save_every: 10000,
      log_tsv: ("logs/mini_llm_ffi_" + ::ds_index.toString() + ".tsv"),
      num_gpus: parseInt((::internal.env("AZL_NUM_GPUS") or "1"))
    }
    # Advance to next dataset after current training session ends (heuristic: watch metrics.total_steps)
    set ::watch_steps = (::metrics.training.metrics && ::metrics.training.metrics.total_steps) || 0
    ::azl.stdlib.set_timeout(10000, () => { emit "rm.check_progress" })
  }

  listen for "rm.check_progress" {
    # Initialize attempt counter if not exists
    if !(::progress_check_attempts exists) { set ::progress_check_attempts = 0 }
    
    set cur_steps = (::metrics.training.metrics && ::metrics.training.metrics.total_steps) || 0
    if cur_steps > (::watch_steps or 0) {
      set ::watch_steps = cur_steps
      set ::progress_check_attempts = 0  # Reset counter on progress
      ::azl.stdlib.set_timeout(10000, () => { emit "rm.check_progress" })
      return
    }
    
    # Increment failed attempt counter
    set ::progress_check_attempts = ::progress_check_attempts + 1
    
    # Stop infinite loop after 3 failed attempts
    if ::progress_check_attempts >= 3 {
      say "🚨 CRITICAL ERROR: Training progress check failed 3 times!"
      say "🔍 DIAGNOSTIC INFO:"
      say "   - Current steps: " + cur_steps
      say "   - Watch steps: " + (::watch_steps or 0)
      say "   - Metrics exist: " + (::metrics.training.metrics != null)
      say "   - Training config: " + (::training_config != null)
      say "   - Models loaded: " + (::models != null ? ::models.keys.length : "NULL")
      
      emit "training_progress_check_failed" with {
        attempts: ::progress_check_attempts,
        current_steps: cur_steps,
        watch_steps: ::watch_steps,
        metrics_exist: (::metrics.training.metrics != null),
        training_config: ::training_config,
        models_count: (::models != null ? ::models.keys.length : 0)
      }
      
      say "🛑 STOPPING INFINITE LOOP - Training system needs fixing!"
      return  # Stop the loop
    }
    
    # If no progress but under limit, continue checking
    say "⚠️ No new steps observed (attempt " + ::progress_check_attempts + "/3); continuing to check..."
    ::azl.stdlib.set_timeout(10000, () => { emit "rm.check_progress" })
  }

  listen for "start_real_model_training" {
    say "🧠 COMPLETE CONSCIOUS TRAINING: Loading real models with ALL components integration"
    
    # Start LHA3 memory integration
    say "🧠 Starting LHA3 Memory Integration..."
    emit "memory_integration_start" to ::memory.lha3_quantum with {
      training_mode: "conscious",
      memory_depth: 8,
      quantum_states: true,
      fractal_compression: true
    }
    
    # Start quantum consciousness processing
    say "🔮 Starting Quantum Consciousness Processing..."
    emit "quantum_consciousness_start" to ::quantum.consciousness.quantum_consciousness with {
      training_mode: "active",
