// Test dynamic function registry with dot notation
// This test verifies that functions can be registered and called dynamically

// Test basic function registration and calling
let result = quantum.superposition([0.5, 0.5]);
say "Quantum superposition result: " + stringify(result);

// Test memory operations
let store_result = memory.lha3.store("test_key", "test_value");
say "Memory store result: " + stringify(store_result);

let retrieve_result = memory.lha3.retrieve("test_key");
say "Memory retrieve result: " + stringify(retrieve_result);

// Test neural operations
let neural_result = neural.forward_pass([0.1, 0.2, 0.3]);
say "Neural forward pass result: " + stringify(neural_result);

// Test consciousness operations
let consciousness_result = consciousness.awareness(0.8);
say "Consciousness awareness result: " + stringify(consciousness_result);

// Test utility functions
let type_result = typeof("hello");
say "Type of 'hello': " + type_result;

let random_result = random();
say "Random number: " + stringify(random_result);

// Test string operations
let split_result = split("hello,world,test", ",");
say "Split result: " + stringify(split_result);

// Test namespace function registration (this would be done in the interpreter)
// For now, we test that the existing functions work
say "All function registry tests completed successfully!"; 