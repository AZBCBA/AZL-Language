#!/usr/bin/env bash
set -euo pipefail
# Pure AZL runner scaffold: bundles core AZL modules and target into a single file
# Usage:
#   scripts/azl run <file.azl>
#   scripts/azl build <dir_or_file1> [file2 ...] [--native] [--workers N]

cmd="${1:-}"
TARGET=""
if [ "$cmd" = "run" ]; then
  if [ "${AZL_NATIVE_ONLY:-0}" = "1" ]; then
    echo "ERROR: 'scripts/azl run' uses Python host runner and is blocked by AZL_NATIVE_ONLY=1" >&2
    echo "Use native startup path: bash scripts/start_azl_native_mode.sh" >&2
    exit 64
  fi
  if [ $# -lt 2 ]; then
    echo "Usage: scripts/azl run <file.azl>" >&2
    exit 1
  fi
  TARGET="$2"
  if [ ! -f "$TARGET" ]; then
    echo "Target AZL file not found: $TARGET" >&2
    exit 1
  fi
elif [ "$cmd" = "build" ]; then
  shift
  BACKEND="bytecode"
  WORKERS="4"
  INPUTS=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --native) BACKEND="native" ; shift ;;
      --workers) WORKERS="$2" ; shift 2 ;;
      *) INPUTS+=("$1") ; shift ;;
    esac
  done
  if [ ${#INPUTS[@]} -eq 0 ]; then
    echo "Usage: scripts/azl build <dir_or_file1> [file2 ...] [--native] [--workers N]" >&2
    exit 1
  fi
  # Expand directories into file list
  FILES=()
  for x in "${INPUTS[@]}"; do
    if [ -d "$x" ]; then
      while IFS= read -r -d '' f; do FILES+=("$f"); done < <(find "$x" -type f -name '*.azl' -print0)
    elif [ -f "$x" ]; then
      FILES+=("$x")
    fi
  done
  # Emit manifest JSON for build orchestrator consumption by host interpreter
  : "${TMPDIR:=/tmp}"; mkdir -p "$TMPDIR"
  MANIFEST="${TMPDIR}/azl_build_manifest_$$.json"
  {
    printf '{"backend":"%s","workers":%s,"files":[' "$BACKEND" "$WORKERS"
    first=1
    for f in "${FILES[@]}"; do
      [ $first -eq 0 ] && printf ',' || first=0
      esc=$(printf '%s' "$f" | sed 's/\\/\\\\/g; s/"/\\"/g')
      printf '{"path":"%s"}' "$esc"
    done
    printf ']}'
  } > "$MANIFEST"
  echo "Build manifest written: $MANIFEST"
  echo "NOTE: Invoke your AZL runtime to read manifest and call ::azl.runtime_integration.build_project"
  exit 0
elif [ "$cmd" = "install" ]; then
  PKG="${2:-}"
  if [ -z "$PKG" ]; then
    echo "Usage: scripts/azl install <package>" >&2
    exit 1
  fi
  exec bash "$(dirname "$0")/azl_install.sh" "$PKG"
else
  echo "Usage: scripts/azl run <file.azl> | build <dir_or_file1> [file2 ...] [--native] [--workers N] | install <package>" >&2
  exit 1
fi

: "${TMPDIR:=/tmp}"; mkdir -p "$TMPDIR"
BOOT_FILE="${TMPDIR}/azl_boot_$$.azl"
COMBINED="${TMPDIR}/azl_combined_$$.azl"

# Bootstrap component: prefer interpreter path (VM/bytecode are design-only)
  cat > "$BOOT_FILE" <<AZL
component ::azl.selfhost.runner {
  init {
    # link ::azl.compiler   # design-only
    # link ::azl.vm         # design-only
      link ::azl.system_interface
    emit compile_target with { path: "__TARGET__" }
  }
  behavior {
    listen for "compile_target" then {
      set ::path = ::event.data.path
      set ::source = ::fs_store[::path] || ""
      emit "compile" with { source_code: ::source, component_name: "::file.main" }
    }
    listen for "generate_bytecode_complete" then {
      set ::bytecode = ::event.data.bytecode
      emit "execute_bytecode" with { bytecode: ::bytecode, component_name: "::file.main" }
    }
  }
}
AZL
sed -i "s#__TARGET__#${TARGET//\//\\/}#g" "$BOOT_FILE"

# Bundle core modules + target
CORE=(
  "azl/stdlib/core/azl_stdlib.azl"
  "azl/system/azl_system_interface.azl"
  "azl/system/platform.azl"
  "azl/system/process.azl"
  "azl/system/hw.azl"
  "azl/core/error_system.azl"
  # "azl/core/compiler/azl_compiler.azl"  # design-only
  # "azl/runtime/vm/azl_vm.azl"          # design-only
  "azl/runtime/interpreter/azl_interpreter.azl"
)
> "$COMBINED"
echo -e "# ===== FILE: ::bootstrap =====\n" >> "$COMBINED"
cat "$BOOT_FILE" >> "$COMBINED"
for f in "${CORE[@]}" "$TARGET"; do
  if [ -f "$f" ]; then
    echo -e "\n\n# ===== FILE: $f =====\n" >> "$COMBINED"
    cat "$f" >> "$COMBINED"
  fi
done

  if [ -n "$TARGET" ]; then
    echo "Combined AZL created at: $COMBINED"
    echo "Executing with AZL interpreter..."
    
    # Start the real AZL runtime and execute the file
    echo "🚀 Starting AZL runtime and executing file..."

    # Create a real host loader that starts the kernel
    HOST_LOADER="${TMPDIR}/azl_host_loader_$$.azl"
    cat > "$HOST_LOADER" <<AZL
component ::azl.host_loader {
  init {
    say "🔥 Starting AZL host loader..."
    
    # Start the kernel initialization
    emit kernel.init
    
    # Wait for kernel to be ready
    listen for "kernel.ready" then {
      say "✅ Kernel ready - starting interpreter..."
      
      # Kernel will automatically start interpreter
      # Wait for interpreter to be ready
      listen for "interpreter.ready" then {
        say "✅ Interpreter ready - executing file..."
        
        # Read and execute our combined file
        set file_content = ::azl.system_interface.read_file_host_sync("$COMBINED")
        emit interpret with { 
          code: file_content, 
          component_name: "::target.main" 
        }
      }
    }
    
    # Capture the execution result
    listen for "interpretation_complete" then {
      set result = ::event.data.result
      say "✅ Execution complete: " + result
      emit execution.complete with { result: result }
    }
  }
}
AZL

    # Execute the host loader which will start the real runtime
echo "🔥 Executing AZL host loader..."
cd "$(dirname "$0")/.."

# Host loader contains AZL code and must run through canonical executor.
echo "⚠️  Host loader created but needs AZL interpreter to execute"
echo "📁 Host loader: $HOST_LOADER"
echo "📁 Combined file: $COMBINED"
  fi
