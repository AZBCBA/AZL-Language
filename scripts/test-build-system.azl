# AZL Enterprise Build System Test
# Tests the build daemon functionality

component ::test.build.system {
  init {
    link ::build.daemon.enterprise
    link ::azl.stdlib
    link ::error.system
    
    say "🧪 Testing AZL Enterprise Build System..."
    
    # Test 1: Check daemon status
    emit test.daemon.status
  }
  
  behavior {
    listen for "test.daemon.status" then {
      set status = ::build.daemon.enterprise.get_status()
      say "📊 Daemon Status: " + status.status
      say "🆔 Daemon ID: " + status.daemon_id
      say "⏱️  Uptime: " + status.uptime + "ms"
      
      # Test 2: Start a test build
      emit test.build.simple
    }
    
    listen for "test.build.simple" then {
      say "🔨 Starting test build..."
      emit daemon.enterprise.build with {
        files: ["azl/core/error_system.azl"],
        options: {
          backend: "bytecode",
          workers: 1,
          incremental: false
        }
      }
    }
    
    listen for "build.daemon.enterprise.build.started" then {
      say "✅ Build started: " + ::event.data.build_id
    }
    
    listen for "build.daemon.enterprise.build.completed" then {
      say "🎉 Build completed: " + ::event.data.build_id
      say "📈 Result: " + ::event.data.result.status
      
      # Test 3: Check analytics
      emit test.analytics
    }
    
    listen for "test.analytics" then {
      set analytics = ::build.daemon.enterprise.get_analytics()
      say "📊 Analytics:"
      say "   Total builds: " + analytics.total_builds
      say "   Successful: " + analytics.successful_builds
      say "   Failed: " + analytics.failed_builds
      say "   Avg build time: " + analytics.average_build_time + "ms"
      
      say "✅ All tests completed successfully!"
      exit 0
    }
    
    listen for "build.daemon.enterprise.build.rejected" then {
      say "❌ Build rejected: " + ::event.data.reason
      exit 1
    }
    
    listen for "build.daemon.enterprise.error" then {
      say "❌ Daemon error: " + ::event.data.error
      exit 1
    }
  }
}
