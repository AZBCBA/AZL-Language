# Simple test for AZL Enterprise Build Daemon components

component ::test.simple {
  init {
    say "🧪 Testing AZL Enterprise Build Daemon components..."
    
    # Test 1: Check if core files exist
    set core_files = [
      "azl/build/build_daemon_enterprise.azl",
      "azl/build/build_orchestrator.azl", 
      "azl/build/worker_pool.azl",
      "azl/build/cache_manager.azl"
    ]
    
    set missing_files = []
    for file in core_files {
      if !::fs_store[file] {
        missing_files.push(file)
      }
    }
    
    if missing_files.length > 0 {
      say "❌ Missing core files:"
      for file in missing_files {
        say "   - " + file
      }
      exit 1
    } else {
      say "✅ All core files found"
    }
    
    # Test 2: Check configuration
    set config_file = "config/prod.azl.json"
    if ::fs_store[config_file] {
      say "✅ Configuration file found: " + config_file
    } else {
      say "❌ Configuration file missing: " + config_file
      exit 1
    }
    
    # Test 3: Check environment
    set api_token = ::internal.env("AZL_API_TOKEN")
    if api_token {
      say "✅ API token found: " + api_token.substring(0, 8) + "..."
    } else {
      say "⚠️  No API token set (will be auto-generated)"
    }
    
    say "🎉 Basic component test passed!"
    say "🚀 Ready to start enterprise daemon"
  }
}
