// Test Function Composition and Piping Implementation

// Basic functions for testing
let add = |x, y| x + y;
let multiply = |x, y| x * y;
let double = |x| x * 2;
let increment = |x| x + 1;
let square = |x| x * x;
let add_ten = |x| x + 10;
let subtract_five = |x| x - 5;

// Define function composition
fn compose(f, g) {
    return fn(x) {
        return f(g(x));
    };
}

// Define pipe function (simplified for 2 functions)
fn pipe(value, f, g) {
    let temp = f(value);
    return g(temp);
}

// Define pipe3 for 3 functions
fn pipe3(value, f, g, h) {
    let temp1 = f(value);
    let temp2 = g(temp1);
    return h(temp2);
}

// Define partial application and currying functions
fn partial(func, arg1) {
    return fn(arg2) {
        return func(arg1, arg2);
    };
}

fn curry(func) {
    return fn(arg1) {
        return fn(arg2) {
            return func(arg1, arg2);
        };
    };
}

say "=== Function Composition Tests ===";

// Test basic composition
let double_then_inc = compose(increment, double);
say "double_then_inc(5) = " + double_then_inc(5); // Should be 11 (5 * 2 + 1)

let inc_then_double = compose(double, increment);
say "inc_then_double(5) = " + inc_then_double(5); // Should be 12 ((5 + 1) * 2)

// Test composition with different types
let square_then_add_ten = compose(add_ten, square);
say "square_then_add_ten(3) = " + square_then_add_ten(3); // Should be 19 (3^2 + 10)

let add_ten_then_square = compose(square, add_ten);
say "add_ten_then_square(3) = " + add_ten_then_square(3); // Should be 169 ((3 + 10)^2)

say "=== Advanced Composition Tests ===";

// Test multiple function composition
let pipeline1 = compose(subtract_five, compose(double, add_ten));
say "pipeline1(3) = " + pipeline1(3); // Should be 21 (((3 + 10) * 2) - 5)

let pipeline2 = compose(compose(subtract_five, double), add_ten);
say "pipeline2(3) = " + pipeline2(3); // Should be 11 (((3 + 10) * 2) - 5)

// Test composition with partial application
let add_five = partial(add, 5);
let multiply_by_three = partial(multiply, 3);

let add_five_then_multiply_by_three = compose(multiply_by_three, add_five);
say "add_five_then_multiply_by_three(2) = " + add_five_then_multiply_by_three(2); // Should be 21 ((2 + 5) * 3)

say "=== Piping Tests ===";

// Test basic piping
let result1 = pipe(5, double, increment);
say "pipe(5, double, increment) = " + result1; // Should be 11

let result2 = pipe(3, add_ten, square);
say "pipe(3, add_ten, square) = " + result2; // Should be 169 ((3 + 10)^2)

// Test piping with 3 functions
let result3 = pipe3(10, |x| x * 2, |x| x + 5, |x| x - 3);
say "pipe3(10, |x| x * 2, |x| x + 5, |x| x - 3) = " + result3; // Should be 22

say "=== Complex Composition Patterns ===";

// Test composition with conditional functions
let is_even = |x| (x / 2) * 2 == x;
let is_positive = |x| x > 0;

// Define conditional processing function
fn process_positive(x) {
    if (is_positive(x)) {
        return x * 2;
    } else {
        return x;
    }
}

fn process_even(x) {
    if (is_even(x)) {
        return x + 1;
    } else {
        return x;
    }
}

let process_number = compose(process_even, process_positive);
say "process_number(5) = " + process_number(5); // Should be 11 (5 * 2 + 1)
say "process_number(4) = " + process_number(4); // Should be 9 (4 * 2 + 1)
say "process_number(-3) = " + process_number(-3); // Should be -3 (unchanged)

// Test composition with string operations
let to_upper = |s| "UPPER_" + s;
let add_exclamation = |s| s + "!";
let make_greeting = compose(add_exclamation, to_upper);

let greeting = make_greeting("hello");
say "make_greeting('hello') = " + greeting; // Should be "UPPER_hello!"

say "=== Composition with Currying ===";

// Test composition with curried functions
let curried_add = curry(add);
let curried_multiply = curry(multiply);

let add_five_then_multiply_by_two = compose(
    curried_multiply(2),
    curried_add(5)
);
say "add_five_then_multiply_by_two(3) = " + add_five_then_multiply_by_two(3); // Should be 16 ((3 + 5) * 2)

say "=== Error Handling in Composition ===";

// Test composition with edge cases
fn safe_divide(x, y) {
    if (y == 0) {
        return 0;
    } else {
        return x / y;
    }
}

fn safe_sqrt(x) {
    if (x < 0) {
        return 0;
    } else {
        return x * x; // Simplified sqrt
    }
}

let safe_pipeline = compose(safe_sqrt, partial(safe_divide, 100));
say "safe_pipeline(5) = " + safe_pipeline(5); // Should be 4 (100 / 25)
say "safe_pipeline(0) = " + safe_pipeline(0); // Should be 0 (division by zero)

say "All function composition and piping tests completed!"; 