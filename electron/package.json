{
  "name": "azl-desktop",
  "version": "1.0.1",
  "description": "AZL Desktop Launcher - Start/Stop AZL runtime and sysproxy with a click",
  "main": "main.js",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development ELECTRON_AUTO_DEVTOOLS=true electron .",
    "build": "electron-builder",
    "dist": "electron-builder -mwl",
    "dist:linux": "electron-builder -l deb AppImage",
    "dist:win": "electron-builder -w nsis",
    "dist:mac": "electron-builder -m dmg zip",
    "pack": "electron-builder --dir",
    "publish": "electron-builder -p always"
  },
  "dependencies": {
    "electron-updater": "^6.1.8",
    "electron-store": "^8.1.0",
    "ajv": "^8.12.0"
  },
  "devDependencies": {
    "electron": "^28.2.10",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.azl.desktop",
    "productName": "AZL Desktop",
    "icon": "build/icons/512x512.png",
    "files": [
      "**/*",
      "!node_modules/.cache/**"
    ],
    "directories": {
      "buildResources": "build"
    },
    "publish": {
      "provider": "github",
      "owner": "abdulrahman-alzalameh",
      "repo": "azl-language"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Utility",
      "icon": "build/icons",
      "executableName": "azl-desktop",
      "desktop": {
        "Name": "AZL Desktop Launcher",
        "Comment": "Start/Stop AZL runtime",
        "StartupWMClass": "azl-desktop"
      }
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/**"
    ],
    "protocols": [
      {
        "name": "AZL",
        "schemes": ["azl"]
      }
    ]
  },
  "keywords": [],
  "author": {
    "name": "Abdulrahman Alzalameh",
    "email": "abdulrahman.alzalameh@example.com"
  },
  "license": "ISC",
  "homepage": "https://github.com/abdulrahman-alzalameh/azl-language"
}