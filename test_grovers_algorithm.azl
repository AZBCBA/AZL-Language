component ::test.grovers_algorithm {
  init {
    set ::test_results = {}
  }

  behavior {
    on start {
      # Test 1: Run Grover's algorithm with target "10"
      emit processor.run_grover with {target: "10", iterations: 1}
      
      # Test 2: Run Grover's algorithm with target "01"
      emit processor.run_grover with {target: "01", iterations: 1}
      
      # Test 3: Run Grover's algorithm with multiple iterations
      emit processor.run_grover with {target: "11", iterations: 2}
      
      # Test 4: Measure Grover state
      emit processor.measure_grover_state
    }

    on grover.run_complete {
      set ::target = $1.target
      set ::iterations = $1.iterations
      set ::state = $1.state
      
      set ::test_results.grover_complete = 1
      emit test.grover.completed with ::test_results
    }

    on grover.oracle_applied {
      set ::target = $1.target
      set ::state = $1.state
      
      set ::test_results.oracle_applied = 1
      emit test.oracle.completed with ::test_results
    }

    on grover.diffusion_applied {
      set ::mean = $1.mean
      set ::state = $1.state
      
      set ::test_results.diffusion_applied = 1
      emit test.diffusion.completed with ::test_results
    }

    on grover.measurement_complete {
      set ::result = $1.result
      set ::probabilities = $1.probabilities
      
      set ::test_results.measurement = 1
      emit test.measurement.completed with ::test_results
    }
  }
}

# Test Grover's algorithm with different targets
component ::test.grovers_targets {
  behavior {
    on start {
      # Test different targets
      emit processor.run_grover with {target: "00", iterations: 1}
      emit processor.run_grover with {target: "01", iterations: 1}
      emit processor.run_grover with {target: "10", iterations: 1}
      emit processor.run_grover with {target: "11", iterations: 1}
    }

    on grover.run_complete {
      set ::target = $1.target
      set ::iterations = $1.iterations
      set ::state = $1.state
      
      # Calculate success probability for target
      set ::target_amplitude = ::state.(::target)
      set ::success_probability = (::target_amplitude.real * ::target_amplitude.real) + 
                                  (::target_amplitude.imag * ::target_amplitude.imag)
      
      set ::test_results.target_success = 1
      emit test.target.completed with ::test_results
    }
  }
}

# Test Grover's algorithm with multiple iterations
component ::test.grovers_iterations {
  behavior {
    on start {
      # Test different iteration counts
      emit processor.run_grover with {target: "10", iterations: 1}
      emit processor.run_grover with {target: "10", iterations: 2}
      emit processor.run_grover with {target: "10", iterations: 3}
    }

    on grover.run_complete {
      set ::target = $1.target
      set ::iterations = $1.iterations
      set ::state = $1.state
      
      # Calculate success probability for target
      set ::target_amplitude = ::state.(::target)
      set ::success_probability = (::target_amplitude.real * ::target_amplitude.real) + 
                                  (::target_amplitude.imag * ::target_amplitude.imag)
      
      set ::test_results.iteration_success = 1
      emit test.iteration.completed with ::test_results
    }
  }
}

# Main test runner
component ::test.grovers_runner {
  behavior {
    on start {
      # Run Grover's algorithm tests
      emit test.grovers_algorithm.start
      emit test.grovers_targets.start
      emit test.grovers_iterations.start
    }
  }
} 