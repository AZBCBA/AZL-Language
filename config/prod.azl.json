{
  "mode": "production",
  "orchestrator": { 
    "concurrency": { 
      "min": 2, 
      "max": 32 
    } 
  },
  "workers": {
    "isolation": "process",
    "limits": { 
      "cpu_percent": 85, 
      "rss_mb": 2048 
    }
  },
  "cache": {
    "type": "content_addressed",
    "path": ".azl/cache",
    "eviction": { 
      "strategy": "lru", 
      "target_gb": 50 
    }
  },
  "watch": { 
    "enabled": true, 
    "debounce_ms": 120 
  },
  "analytics": { 
    "enabled": true, 
    "export": { 
      "interval_s": 10, 
      "path": ".azl/metrics.ndjson" 
    } 
  },
  "api": {
    "bind": "0.0.0.0:8080",
    "auth": { 
      "type": "token", 
      "env": "AZL_API_TOKEN" 
    },
    "cors": { 
      "allowed_origins": [] 
    }
  },
  "logging": { 
    "level": "info", 
    "format": "json" 
  },
  "build": {
    "backend": "bytecode",
    "workers": 8,
    "incremental": true,
    "targets": {
      "daemon": "azl/build/build_daemon_enterprise.azl",
      "orchestrator": "azl/build/build_orchestrator.azl",
      "worker_pool": "azl/build/worker_pool.azl",
      "cache_manager": "azl/build/cache_manager.azl"
    }
  },
  "features": {
    "orchestrator_coexist": true,
    "unified_orchestrator_enabled": false
  },
  "quantum": {
      "enabled": true,
    "optimizer": {
      "budget_ms": 250,
      "max_qubits": 64
    }
  },
  "voice": {
    "offline_first": true,
    "remote_fallback": false
  },
  "plugins": {
    "governance_enforced": true,
    "require_signatures": true,
    "default_role": "external_agent"
  },
  "training": {
    "loss": {
      "default": "mse"
    },
    "augmentation": {
      "level": 1.0
    },
    "curriculum": {
      "mode": "auto"
    },
    "hybrid": {
      "enabled": true,
      "thresholds": { "difficulty": 3.0, "tokens": 32, "topo_geom": 4.0 }
    }
  }
}
