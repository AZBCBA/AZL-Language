say "🧪 Testing Try/Catch Functionality";

// Test 1: Basic try/catch
say "=== Test 1: Basic Try/Catch ===";
try {
    say "Inside try block";
    throw "Test exception";
    say "This should not execute";
} catch {
    say "Exception caught successfully";
}

// Test 2: Try/catch with error recovery
say "=== Test 2: Error Recovery ===";
let result = 0;
try {
    let division = 10 / 0;  // This should cause an error
    say "Division result";
} catch {
    say "Division by zero caught";
    set result = 42;
}
say "Final result";
say result;

// Test 3: Nested try/catch
say "=== Test 3: Nested Try/Catch ===";
try {
    say "Outer try block";
    try {
        say "Inner try block";
        throw "Inner exception";
    } catch {
        say "Inner exception caught";
        throw "Outer exception";
    }
} catch {
    say "Outer exception caught";
}

// Test 4: Try/catch with function calls
say "=== Test 4: Try/Catch with Functions ===";
fn risky_function() {
    throw "Function threw an exception";
}

try {
    risky_function();
    say "Function completed successfully";
} catch {
    say "Function exception caught";
}

say "✅ Try/Catch tests completed"; 