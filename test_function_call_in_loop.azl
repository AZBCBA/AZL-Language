// Test function calls within loops
fn double(n) {
    return n * 2;
}

let numbers = [1, 2, 3];
let result = [];

say "Testing function calls in loop:";
let i = 0;
while (i < 3) {
    let element = numbers[i];
    let doubled = double(element);
    say doubled;
    i = i + 1;
}

say "Function calls in loop completed!"; 