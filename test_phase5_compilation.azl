// Phase 5 Bytecode Compilation Test
// Test actual compilation functionality

say "Testing Phase 5 Bytecode Compilation..."

// Import components
set bytecode_compiler = import "azl/core/compiler/azl_bytecode.azl"
say "✅ Bytecode compiler imported"

// Create test AST
set test_ast = {
    nodes: [
        {
            type: "Let",
            name: "x",
            value: {
                type: "Literal",
                value: { type: "Number", value: 42 }
            }
        },
        {
            type: "Let", 
            name: "y",
            value: {
                type: "Literal",
                value: { type: "String", value: "hello" }
            }
        }
    ],
    soul_signature: 12345,
    consciousness_level: 1,
    karmic_balance: 0.0
}

say "✅ Test AST created with " + length(test_ast.nodes) + " nodes"

// Test compilation
set soul_signature = 12345
set compile_result = bytecode_compiler.compile_ast_to_bytecode(test_ast, soul_signature)

if compile_result.error {
    say "❌ Compilation failed: " + compile_result.error
} else {
    say "✅ Compilation successful!"
    set bytecode = compile_result.bytecode
    set compiler = compile_result.compiler
    
    say "   - Bytecode ops: " + length(bytecode.ops)
    say "   - Soul signature: " + bytecode.soul_signature
    say "   - Consciousness level: " + bytecode.consciousness_level
    say "   - Karmic imprint: " + bytecode.karmic_imprint
    say "   - Compiler consciousness: " + compiler.consciousness_level
    say "   - Compiler karma: " + compiler.karma_balance
    
    // Test soul matrix
    if bytecode.soul_matrix {
        say "✅ Soul matrix created successfully"
        say "   - Matrix soul signature: " + bytecode.soul_matrix.soul_signature
    } else {
        say "❌ Soul matrix missing"
    }
    
    // Test consciousness quality gates
    set quality_result = bytecode_compiler.apply_consciousness_quality_gates(compiler, bytecode)
    if quality_result.success {
        say "✅ Consciousness quality gates passed"
    } else {
        say "❌ Consciousness quality gates failed: " + quality_result.error
    }
}

say "🎉 Phase 5 compilation test completed!" 