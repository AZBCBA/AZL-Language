let number_literal = 42.5;
let boolean_literal = true;
let null_literal = null;
say "✅ Literals working";

// ✅ Function and method calls
let result = quantum.superposition(0.5, 0.5);
say "✅ Function calls working";

// ✅ Dot access and chaining
let memory_result = memory.lha3.store("key", "value");
say "✅ Dot access working";

// ✅ Variable declarations
let variable = "test";
say "✅ Variable declarations working";

// ✅ Control flow
if (true) {
    say "✅ If statements working";
} else {
    say "Else branch";
}

// ✅ Try/catch/finally
try {
    let test = quantum.superposition(0.5, 0.5);
    say "✅ Try/catch syntax working";
} catch (error) {
    say "Error caught: " + error;
} finally {
    say "Finally block executed";
}

// ✅ Emit, on statements
emit "test" with {data: "value"};
on "test" do {
    say "✅ Event statements working";
};

