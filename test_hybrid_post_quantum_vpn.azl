# Main test runner
component ::test.hybrid_post_quantum_vpn_runner {
  behavior {
    on start {
      # Run all hybrid post-quantum VPN tests
      emit test.hybrid_post_quantum_vpn.start
      emit test.quantum_safe_vpn.start
      emit test.hybrid_protocol_support.start
      emit test.future_proof_security.start
      emit test.iot_edge_tunneling.start
      emit test.secure_ai_agent_channels.start
