    on hpqvpn.future_proof_security_verified {
      set ::security_info = $1
      set ::test_results.future_proof_security = {
        rsa_immune: ::security_info.rsa_immune,
        ecc_immune: ::security_info.ecc_immune,
        quantum_resistant: ::security_info.quantum_resistant,
        lattice_based: ::security_info.lattice_based
      }
      emit test.future_proof_security.completed
    }
  }
}

