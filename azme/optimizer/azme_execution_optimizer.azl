# AZME Execution Optimizer - Core Optimization Engine
# Tracks performance metrics, scores execution paths, and restructures inefficient paths

# Core state variables for execution optimization
set ::execution_score_map = {}
set ::execution_path_registry = {}
set ::execution_feedback_history = {}
set ::execution_resource_cost_map = {}
set ::execution_time_map = {}
set ::preferred_execution_paths = {}
set ::restructured_path_versions = {}
set ::optimization_cycle_count = 0

# Event handlers for execution optimization
on azme.task_completed with ::task ::path ::reward_value ::execution_time ::success:
  set reward = reward_value or 0
  set execution_time = execution_time or 0
  set success = success or false
  
  emit azme.update_path_score with task path reward execution_time success

on azme.update_path_score with ::task ::path ::reward ::execution_time ::success:
  # Calculate score
  set base_score = reward
  set time_penalty = execution_time * 0.1
  set success_bonus = 0
  if success:
    set success_bonus = 2
  set final_score = base_score - time_penalty + success_bonus
  
  # Initialize task entry if needed
  if not task in ::execution_score_map:
    set ::execution_score_map[task] = {}
  
  # Initialize path entry if needed
  if not path in ::execution_score_map[task]:
    set ::execution_score_map[task][path] = 0
  
  # Update score
  set ::execution_score_map[task][path] = ::execution_score_map[task][path] + final_score
  
  # Store feedback history
  if not path in ::execution_feedback_history:
    set ::execution_feedback_history[path] = []
  
  set feedback_entry = { task: task, path: path, score: final_score, success: success, execution_time: execution_time }
  set ::execution_feedback_history[path] = ::execution_feedback_history[path] + [feedback_entry]
  
  # Check if path needs optimization
  emit azme.check_path_optimization with path final_score

on azme.check_path_optimization with ::path ::score:
  # Check for low score
  if score < -5:
    emit azme.restructure_path with path "low_score"
  
  # Check for high failure rate
  if path in ::execution_feedback_history:
    set history = ::execution_feedback_history[path]
    emit azme.count_failures with path history 0 history.length 0

on azme.count_failures with ::path ::history ::index ::total ::failures:
  if index >= total:
    set failure_rate = 0
    if total > 0:
      set failure_rate = failures / total
    if failure_rate > 0.5:
      emit azme.restructure_path with path "high_failure_rate"
  
  if index < total:
    set entry = history[index]
    set new_failures = failures
    if not entry.success:
      set new_failures = failures + 1
    set next_index = index + 1
    emit azme.count_failures with path history next_index total new_failures

on azme.restructure_path with ::path ::reason:
  # Decompose path into components
  set components = []
  set current = ""
  emit azme.decompose_path with path components current 0

on azme.decompose_path with ::path ::components ::current ::index:
  if index >= path.length:
    set components = components + [current]
    emit azme.optimize_components with components 0
  
  if index < path.length:
    set char = path[index]
    if char == "+":
      set new_components = components + [current]
      set new_current = ""
      set next_index = index + 1
      emit azme.decompose_path with path new_components new_current next_index
    
    if char != "+":
      set new_current = current + char
      set next_index = index + 1
      emit azme.decompose_path with path components new_current next_index

on azme.optimize_components with ::components ::index:
  set optimized_components = []
  
  if index >= components.length:
    emit azme.reassemble_path with optimized_components 0 ""
  
  if index < components.length:
    set component = components[index]
    emit azme.optimize_single_component with component components index optimized_components

on azme.optimize_single_component with ::component ::components ::index ::optimized_components:
  set optimized = component
  if component == "mistral":
    set optimized = "deepseek"
  if component == "formatter":
    set optimized = "memory_writer"
  if component == "math_engine":
    set optimized = "quantum_math_engine"
  
  set new_optimized = optimized_components + [optimized]
  set next_index = index + 1
  emit azme.optimize_components with components next_index

on azme.reassemble_path with ::optimized_components ::index ::new_path:
  if index >= optimized_components.length:
    # Register new path
    set ::execution_path_registry[new_path] = true
    set ::execution_score_map[new_path] = 0
    set ::execution_resource_cost_map[new_path] = optimized_components.length * 10
    
    # Store restructure history
    if not path in ::restructured_path_versions:
      set ::restructured_path_versions[path] = []
    set ::restructured_path_versions[path] = ::restructured_path_versions[path] + [new_path]
    
    emit azme.path_restructured with path new_path reason
  
  if index < optimized_components.length:
    set component = optimized_components[index]
    set path_part = component
    if index > 0:
      set path_part = "+" + component
    set updated_path = new_path + path_part
    set next_index = index + 1
    emit azme.reassemble_path with optimized_components next_index updated_path

on azme.update_preferred_paths with ::task:
  set task_name = task.name
  set task_scores = ::execution_score_map[task_name]
  
  if task_scores:
    emit azme.find_best_path with task_name 0 "" -999999

on azme.find_best_path with ::task_name ::index ::best_path ::best_score:
  set task_scores = ::execution_score_map[task_name]
  set paths = task_scores.keys()
  
  if index >= paths.length:
    if best_path != "":
      set ::preferred_execution_paths[task_name] = best_path
      emit azme.path_promoted with task_name best_path best_score
  
  if index < paths.length:
    set path = paths[index]
    set score = ::execution_score_map[task_name][path]
    set new_best_path = best_path
    set new_best_score = best_score
    if score > best_score:
      set new_best_path = path
      set new_best_score = score
    set next_index = index + 1
    emit azme.find_best_path with task_name next_index new_best_path new_best_score

on azme.execution_optimizer_cycle_complete:
  set ::optimization_cycle_count = ::optimization_cycle_count + 1
  emit azme.optimization_cycle_logged with ::optimization_cycle_count 