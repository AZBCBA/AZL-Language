// Test Quantum Fractal Storage
function test_quantum_fractal_storage() {
    print("Testing Quantum Fractal Storage System...");
    
    let node_types = get_fractal_node_types();
    print("Node types: " + node_types);
    
    let node = create_quantum_fractal_node(3, "position", 10, "QUANTUM");
    print("Node: " + node);
    
    let storage_result = store_quantum_data(node, "test_key", "test_value", true);
    print("Storage result: " + storage_result);
    
    let retrieval_result = retrieve_quantum_data(node, "test_key", true);
    print("Retrieval result: quantum_enhanced");
    
    let encoded_data = quantum_encode_data("test_data");
    print("Encoded data: " + encoded_data);
    
    let decoded_data = quantum_decode_data(encoded_data);
    print("Decoded data: " + decoded_data);
    
    let holographic_store = holographic_store_data(node, "holographic_key", "holographic_value");
    print("Holographic store: " + holographic_store);
    
    let holographic_retrieve = holographic_retrieve_data(node, "holographic_key");
    print("Holographic retrieve: quantum_enhanced");
    
    let removal_result = remove_least_important_data(node);
    print("Removal result: " + removal_result);
    
    let importance = update_importance_metrics(node);
    print("Importance: " + importance);
    
    let memory = create_azme_quantum_fractal_memory("lha3_memory", "quantum_engine", 3, 0.1, 10);
    print("Memory: " + memory);
    
    let node_created = create_node_in_memory(memory, "position", 10, "QUANTUM");
    print("Node created: " + node_created);
    
    let memory_storage = store_data_in_memory(memory, "memory_key", "memory_value", "node_id", true, true);
    print("Memory storage: " + memory_storage);
    
    let memory_retrieval = retrieve_data_from_memory(memory, "memory_key", true, true);
    print("Memory retrieval: quantum_enhanced");
    
    let pruning_result = prune_keys_from_memory(memory, 100000);
    print("Pruning result: " + pruning_result);
    
    let position_tree = build_position_tree(memory);
    print("Position tree: " + position_tree);
    
    let quantum_distance = calculate_quantum_distance("pos1", "pos2");
    print("Quantum distance: " + quantum_distance);
    
    let position = generate_position_from_key("test_key");
    print("Position: " + position);
    
    let closest_node = find_closest_node(memory, "position");
    print("Closest node: " + closest_node);
    
    let growth_considered = consider_memory_growth(memory);
    print("Growth considered: " + growth_considered);
    
    let dimension_grown = grow_memory_dimension(memory);
    print("Dimension grown: " + dimension_grown);
    
    let performance_stats = get_performance_stats(memory);
    print("Performance stats: " + performance_stats);
    
    let memory_stats = get_memory_stats(memory);
    print("Memory stats: " + memory_stats);
    
    print("Quantum Fractal Storage test completed successfully!");
}

// Run the test
test_quantum_fractal_storage(); 