}

# Test QBER calculation
component ::test.qber_calculation {
  behavior {
    on start {
      # Test QBER calculation
      emit test.qber_calculation_operation
    }

    on test.qber_calculation_operation {
      emit processor.calculate_qber
    }

    on qkd.qber_calculated {
      set ::qber_info = $1
      set ::test_results.qber_calculation = {
        total_bits: ::qber_info.total_bits,
        error_bits: ::qber_info.error_bits,
        qber: ::qber_info.qber
      }
      emit test.qber_calculation.completed
    }
  }
}

# Test different QKD scenarios
component ::test.qkd_scenarios {
  behavior {
    on start {
      # Test different QKD scenarios
      emit test.qkd_no_eavesdropping
      emit test.qkd_with_eavesdropping
      emit test.qkd_high_qber
    }

    on test.qkd_no_eavesdropping {
      # Test QKD with no eavesdropping
      emit processor.run_bb84_qkd
    }

    on test.qkd_with_eavesdropping {
      # Test QKD with eavesdropping (simulated)
      emit processor.run_bb84_qkd
    }

    on test.qkd_high_qber {
      # Test QKD with high QBER
      emit processor.run_bb84_qkd
    }
  }
}

# Test QKD performance and security
component ::test.qkd_performance {
  behavior {
    on start {
      # Test QKD performance metrics
      emit test.qkd_security_advantages
      emit test.quantum_cryptography
      emit test.unbreakable_encryption
    }

    on test.qkd_security_advantages {
      set ::test_results.qkd_security = {
        physics_based_security: true,
        eavesdropping_detection: true,
        unbreakable_keys: true,
        quantum_advantage: true
      }
      emit test.qkd_security.completed
    }

    on test.quantum_cryptography {
      set ::test_results.quantum_cryptography = {
        bb84_protocol: true,
        e91_protocol: true,
        privacy_amplification: true,
        authentication: true
      }
      emit test.quantum_cryptography.completed
    }

    on test.unbreakable_encryption {
      set ::test_results.unbreakable_encryption = {
        quantum_keys: true,
        eavesdropping_detection: true,
        secure_communication: true,
        quantum_internet: true
      }
      emit test.unbreakable_encryption.completed
    }
  }
}

# Main test runner
component ::test.qkd_runner {
  behavior {
    on start {
      # Run all QKD tests
      emit test.quantum_key_distribution.start
      emit test.entangled_qkd.start
      emit test.privacy_amplification.start
      emit test.qkd_authentication.start
      emit test.qber_calculation.start
      emit test.qkd_scenarios.start
      emit test.qkd_performance.start
    }
  }
} 