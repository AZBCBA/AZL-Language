component ::test.quantum_key_distribution {
  init {
    set ::test_results = {}
  }

  behavior {
    on start {
      # Test complete BB84 QKD protocol
      emit processor.run_bb84_qkd
      
      # Test individual steps
      emit processor.alice_prepare_qubits
      emit processor.bob_measure_qubits
      emit processor.reconcile_bases
      emit processor.extract_shared_key
      emit processor.detect_eavesdropping
      emit processor.verify_qkd_key
    }

    on qkd.alice_prepared {
      set ::alice_info = $1
      set ::test_results.alice_preparation = {
        success: 1,
        bits: ::alice_info.bits,
        bases: ::alice_info.bases
      }
      emit test.qkd_alice_preparation.completed
    }

    on qkd.bob_measured {
      set ::bob_info = $1
      set ::test_results.bob_measurement = {
        bases: ::bob_info.bases,
        measurements: ::bob_info.measurements
      }
      emit test.qkd_bob_measurement.completed
    }

    on qkd.basis_reconciled {
      set ::reconciliation_info = $1
      set ::test_results.basis_reconciliation = {
        match_indices: ::reconciliation_info.match_indices,
        match_count: ::reconciliation_info.match_count
      }
      emit test.qkd_basis_reconciliation.completed
    }

    on qkd.key_extracted {
      set ::key_info = $1
      set ::test_results.key_extraction = {
        raw_key: ::key_info.raw_key,
        key_length: ::key_info.key_length
      }
      emit test.qkd_key_extraction.completed
    }

    on qkd.eavesdrop_check {
      set ::eavesdrop_info = $1
      set ::test_results.eavesdropping_detection = {
        sample_match: ::eavesdrop_info.sample_match,
        qber: ::eavesdrop_info.qber,
        sample_size: ::eavesdrop_info.sample_size,
        mismatch_count: ::eavesdrop_info.mismatch_count
      }
      emit test.qkd_eavesdropping_detection.completed
    }

    on qkd.verified {
      set ::verification_info = $1
      set ::test_results.qkd_verification = {
        success: ::verification_info.success,
        final_key: ::verification_info.final_key,
        key_length: ::verification_info.key_length,
        qber: ::verification_info.qber
      }
      emit test.qkd_verification.completed
    }

    on qkd.complete {
      set ::test_results.qkd_complete = 1
      emit test.qkd.completed with ::test_results
    }
  }
}

# Test entangled QKD protocol (E91)
component ::test.entangled_qkd {
  behavior {
    on start {
      # Test entangled QKD protocol
      emit test.entangled_qkd_operation
    }

    on test.entangled_qkd_operation {
      emit processor.run_entangled_qkd
    }

    on qkd.entangled_protocol {
      set ::entangled_info = $1
      set ::test_results.entangled_qkd = {
        epr_pairs: ::entangled_info.epr_pairs,
        alice_measurements: ::entangled_info.alice_measurements,
        bob_measurements: ::entangled_info.bob_measurements
      }
      emit test.entangled_qkd.completed
    }
  }
}

