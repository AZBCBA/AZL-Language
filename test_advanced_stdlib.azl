# Advanced AZL v2 Standard Library Test

# Array operations
let numbers = [1, 2, 3, 4, 5]
say "Original array: " + stringify(numbers)

let pushed = push(numbers, 6)
say "After push: " + stringify(pushed)

let popped = pop(pushed)
say "Popped value: " + stringify(popped)

let sliced = slice(numbers, 1, 3)
say "Slice [1:3]: " + stringify(sliced)

# Math functions
let x = -5.7
let y = 16.0
let z = 2.5

say "Absolute value of " + stringify(x) + " is " + stringify(abs(x))
say "Square root of " + stringify(y) + " is " + stringify(sqrt(y))
say "Power " + stringify(z) + "^3 is " + stringify(pow(z, 3))

# Trigonometry
let angle = 0.5
say "sin(" + stringify(angle) + ") = " + stringify(sin(angle))
say "cos(" + stringify(angle) + ") = " + stringify(cos(angle))
say "tan(" + stringify(angle) + ") = " + stringify(tan(angle))

# Logarithms and exponentials
let num = 2.718
say "ln(" + stringify(num) + ") = " + stringify(log(num))
say "e^" + stringify(z) + " = " + stringify(exp(z))

# Rounding
let pi = 3.14159
say "Floor of " + stringify(pi) + " is " + stringify(floor(pi))
say "Ceil of " + stringify(pi) + " is " + stringify(ceil(pi))
say "Round of " + stringify(pi) + " is " + stringify(round(pi))

# Min/Max
say "Min of 5 and 3 is " + stringify(min(5, 3))
say "Max of 5 and 3 is " + stringify(max(5, 3))

# Time
let current_time = now()
say "Current timestamp: " + stringify(current_time)

# Complex calculation example
let a = 3.0
let b = 4.0
let hypotenuse = sqrt(pow(a, 2) + pow(b, 2))
say "Hypotenuse of triangle with sides " + stringify(a) + " and " + stringify(b) + " is " + stringify(hypotenuse)

# Array math
let data = [1, 2, 3, 4, 5]
let sum = 0
loop for item in data {
  set sum = sum + item
}
say "Sum of array " + stringify(data) + " is " + stringify(sum)

# String and array combination
let words = ["hello", "world", "from", "azl"]
let sentence = join(words, " ")
say "Joined sentence: " + sentence

let parts = split(sentence, " ")
say "Split back: " + stringify(parts) 