// Simple test to debug map function issue
fn double(n) {
    return n * 2;
}

fn map(array, transform) {
    let result = [];
    let length = array.length(array);
    let i = 0;
    
    say "Starting map function";
    say "Array length:";
    say length;
    
    while (i < length) {
        say "Loop iteration:";
        say i;
        
        let element = array[i];
        say "Element:";
        say element;
        
        let transformed = transform(element);
        say "Transformed:";
        say transformed;
        
        result = array.push(result, transformed);
        say "Result array:";
        say result;
        
        i = i + 1;
        say "New i value:";
        say i;
    }
    
    return result;
}

let numbers = [1, 2];
say "Testing map debug:";
let doubled = map(numbers, double);
say "Final result:";
say doubled; 