// Test array variable indexing
let numbers = [1, 2, 3, 4, 5];

// This should work (literal index)
say numbers[0];

// This should work (literal index)
say numbers[2];

// This should work but currently doesn't (variable index)
let i = 1;
say numbers[i];

// This should also work (variable index)
let index = 3;
say numbers[index];

// Test array assignment with variable index
numbers[i] = 10;
say numbers[i]; 